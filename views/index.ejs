<script>
async function claimDailyLogin() {
  const btn = document.getElementById('btnDailyLogin');
  const originalHtml = btn.innerHTML;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin" style="font-size: 0.85rem;"></i> Proses...';
  btn.disabled = true;
  btn.style.opacity = '0.7';
  btn.style.cursor = 'not-allowed';

  try {
    const res = await fetch('/api/claim-daily-login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' }
    });
    const data = await res.json();
    
    if (data.success) {
      if (window.showToast) {
        showToast('Yeay! Berhasil klaim reward harian Rp ' + data.amount.toLocaleString('id-ID'), 'success');
      } else {
        alert('Yeay! Berhasil klaim reward harian Rp ' + data.amount.toLocaleString('id-ID'));
      }
      
      // Update balance UI
      const balEl = document.getElementById('heroWalletBalance');
      if (balEl) {
        const currentStr = balEl.innerText.replace(/[^0-9]/g, '');
        const currentNum = parseInt(currentStr) || 0;
        balEl.innerText = 'Rp ' + (currentNum + data.amount).toLocaleString('id-ID');
      }

      // Reload to update the 7-day streak UI
      setTimeout(() => {
        window.location.reload();
      }, 1500);
    } else {
      if (window.showToast) {
        showToast(data.message || 'Gagal klaim', 'error');
      } else {
        alert(data.message || 'Gagal klaim');
      }
      btn.innerHTML = originalHtml;
      btn.disabled = false;
      btn.style.opacity = '1';
      btn.style.cursor = 'pointer';
    }
  } catch (err) {
    if (window.showToast) {
      showToast('Terjadi kesalahan jaringan', 'error');
    } else {
      alert('Terjadi kesalahan jaringan');
    }
    btn.innerHTML = originalHtml;
    btn.disabled = false;
    btn.style.opacity = '1';
    btn.style.cursor = 'pointer';
  }
}

document.addEventListener('DOMContentLoaded', function() {
  const slider = document.getElementById('daysSlider');
  if (slider) {
    const nameEl = document.getElementById('customDaysName');
    const priceEl = document.getElementById('customDaysPrice');
    const periodEl = document.getElementById('customDaysPeriod');
    const valTextEl = document.getElementById('sliderValueText');
    const btnEl = document.getElementById('customDaysBtn');

    function updateCustomDays() {
      const days = parseInt(slider.value);
      const price = days * 7000;
      
      nameEl.innerText = `Sewa Harian (${days} Hari)`;
      priceEl.innerText = `Rp ${price.toLocaleString('id-ID')}`;
      periodEl.innerText = `akses selama ${days} hari`;
      valTextEl.innerText = `${days} Hari`;
      
      if (btnEl) {
        btnEl.href = `/order/custom_royal?days=${days}`;
      }
    }

    slider.addEventListener('input', updateCustomDays);
    updateCustomDays(); // run once initially
  }
});
</script>

