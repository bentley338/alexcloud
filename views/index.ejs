<%- include('partials/header') %>

<!-- HERO -->
<section class="hero" id="main-content" aria-label="Hero utama">
  <div class="hero-bg"></div>
  <div class="hero-grid-overlay"></div>
  <div class="hero-particles" aria-hidden="true"></div>
  <div class="hero-container">
    <!-- Pengumuman dari admin — tampil di atas beranda (bukan banner fixed seluruh situs) -->
    <% if (typeof announcement !== 'undefined' && announcement) { %>
    <div class="home-announce home-announce--<%= announcement.type || 'info' %>" id="siteAnnounce" data-ann-id="<%= announcement.id || 'default' %>">
      <i class="fas fa-<%= announcement.type === 'promo' ? 'gift' : (announcement.type === 'warn' ? 'triangle-exclamation' : 'bullhorn') %>" aria-hidden="true"></i>
      <span class="home-announce-text"><%= announcement.text %></span>
      <% if (announcement.link && announcement.linkText) { %>
        <a href="<%= announcement.link %>" class="home-announce-link"><%= announcement.linkText %> →</a>
      <% } %>
      <button class="home-announce-close" type="button" onclick="dismissAnnounce()" aria-label="Tutup pengumuman">✕</button>
    </div>
    <style>
      .home-announce{grid-column:1/-1;display:flex;align-items:center;gap:0.7rem;width:100%;margin-bottom:2rem;padding:0.85rem 1.1rem;border-radius:14px;font-family:var(--font-ui);font-size:0.92rem;font-weight:500;color:#fff;background:var(--gradient-main);box-shadow:0 8px 24px rgba(0,0,0,0.30);border:1px solid rgba(255,255,255,0.12)}
      .home-announce--promo{background:linear-gradient(135deg,#7c3aed 0%,#db2777 100%)}
      .home-announce--warn{background:linear-gradient(135deg,#d97706 0%,#dc2626 100%)}
      .home-announce > i{flex-shrink:0;font-size:1.05rem}
      .home-announce-text{flex:1;min-width:0;line-height:1.45}
      .home-announce-link{color:#fff;font-weight:700;text-decoration:underline;white-space:nowrap;flex-shrink:0}
      .home-announce-close{flex-shrink:0;background:rgba(255,255,255,0.2);border:none;color:#fff;width:26px;height:26px;border-radius:50%;cursor:pointer;font-size:0.8rem;line-height:1;display:flex;align-items:center;justify-content:center;transition:background 0.2s}
      .home-announce-close:hover{background:rgba(255,255,255,0.38)}
      @media(max-width:768px){.home-announce{font-size:0.84rem;margin-bottom:1.25rem;padding:0.7rem 0.9rem}}
    </style>
    <script>
      (function () {
        var el = document.getElementById('siteAnnounce');
        if (!el) return;
        var id = el.getAttribute('data-ann-id') || 'default';
        try { if (localStorage.getItem('annDismissed') === id) { el.remove(); } } catch (e) {}
      })();
      function dismissAnnounce() {
        var el = document.getElementById('siteAnnounce');
        if (!el) return;
        var id = el.getAttribute('data-ann-id') || 'default';
        try { localStorage.setItem('annDismissed', id); } catch (e) {}
        el.remove();
      }
    </script>
    <% } %>
    <div class="hero-content">
      <div class="hero-badge">
        <i class="fas fa-bolt"></i>
        <span>Platform Cloud Gaming #1 Indonesia</span>
      </div>
      <h1 class="hero-title">
        Main Game AAA<br><span class="accent">Tanpa PC Mahal</span>
      </h1>
      <p class="hero-subtitle">
        AlexCloud menghadirkan pengalaman gaming premium langsung dari cloud. 
        Akses ratusan game terbaru dengan koneksi internet biasa. 
        Mulai dari Rp 40.000/minggu!
      </p>

      <div class="hero-actions">
        <a href="/pricing?ref_=home_hero_pricing" class="btn-primary">
          <i class="fas fa-gamepad"></i> Mulai Sekarang
        </a>
        <a href="/games?ref_=home_hero_games" class="btn-secondary">
          <i class="fas fa-search"></i> Cari &amp; Lihat Game
        </a>
      </div>
      <% if (user) { %>
      <div class="hero-wallet-widget">
        <div style="display: flex; align-items: center; gap: 0.85rem;">
          <div class="hero-wallet-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a8 8 0 0 1-5.3 7.7 2 2 0 0 1-2.7-1.4l-1-4.2a2 2 0 0 0-1.7-1.5L5 16a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h14"></path>
              <path d="M21 11v4h-3a2 2 0 0 1 0-4h3z"></path>
            </svg>
          </div>
          <div>
            <div class="hero-wallet-label">Saldo Dompet</div>
            <div id="heroWalletBalance" class="hero-wallet-amount">Rp <%= balance.toLocaleString('id-ID') %></div>
          </div>
        </div>
        <a href="/wallet?ref_=home_wallet_topup" class="btn-primary hero-wallet-topup-btn">
          <i class="fas fa-plus" style="font-size: 0.8rem;"></i> Top Up
        </a>
      </div>

      <% 
         let today = new Date();
         today.setUTCHours(0,0,0,0);
         let todayDate = today.toISOString().split('T')[0];
         let alreadyClaimed = lastDailyLogin === todayDate;
         
         let currentStreak = loginStreak || 0;
         let nextStreak = alreadyClaimed ? currentStreak : (currentStreak + 1 > 7 ? 1 : currentStreak + 1);

         // Cek apakah bolong
         let lastClaim = null;
         if (lastDailyLogin) {
            lastClaim = new Date(lastDailyLogin);
            lastClaim.setUTCHours(0,0,0,0);
         }
         let isMissed = false;
         if (lastClaim) {
            let diffDays = Math.round((today.getTime() - lastClaim.getTime()) / (1000*60*60*24));
            if (diffDays > 1) {
               isMissed = true;
               nextStreak = 1;
            }
         }
         if (!lastDailyLogin) nextStreak = 1;

         const rewardMap = { 1: '1k', 2: '2k', 3: '3k', 4: '4k', 5: '5k', 6: '7k', 7: '10k' };
      %>
      <div id="streakWidget" class="hero-streak-widget">
        <div class="streak-header-row">
          <div>
            <div class="streak-mini-label">Reward Harian</div>
            <div class="streak-title-text">7-Day Login Streak</div>
          </div>
          <% if (alreadyClaimed) { %>
            <button class="btn-secondary streak-btn" disabled>
              <i class="fas fa-check"></i> Hari Ini Diklaim
            </button>
          <% } else { %>
            <button id="btnDailyLogin" onclick="claimDailyLogin()" class="btn-primary streak-claim-btn">
              <i class="fas fa-gift"></i> Klaim Sekarang
            </button>
          <% } %>
        </div>
        
        <div class="streak-days-row" style="display: flex; gap: 0.4rem; justify-content: space-between; overflow-x: auto; padding-bottom: 0.5rem; user-select: none;">
          <% for(let i=1; i<=7; i++) { 
             let status = 'future';
             if (i < nextStreak || (i === nextStreak && alreadyClaimed)) status = 'passed';
             else if (i === nextStreak && !alreadyClaimed) status = 'today';
             
             let bg = 'rgba(255,255,255,0.05)';
             let border = '1px solid rgba(255,255,255,0.05)';
             let color = 'rgba(255,255,255,0.4)';
             let icon = '<i class="fas fa-lock"></i>';
             let glow = 'none';

             if (status === 'passed') {
                bg = 'rgba(16,185,129,0.15)';
                border = '1px solid rgba(16,185,129,0.3)';
                color = '#10b981';
                icon = '<i class="fas fa-check-circle"></i>';
             } else if (status === 'today') {
                bg = 'linear-gradient(135deg, rgba(16,185,129,0.8), rgba(5,150,105,0.8))';
                border = '1px solid #10b981';
                color = '#fff';
                icon = '<i class="fas fa-gift"></i>';
                glow = '0 0 10px rgba(16,185,129,0.5)';
             }
          %>
          <div class="streak-day-item" style="flex: 1; min-width: 42px; text-align: center; border-radius: 8px; padding: 0.5rem 0; background: <%= bg %>; border: <%= border %>; color: <%= color %>; box-shadow: <%= glow %>; transition: all 0.3s ease;">
            <div class="day-num" style="font-size: 0.65rem; font-weight: 700; margin-bottom: 0.3rem;">H<%= i %></div>
            <div class="day-icon" style="font-size: 0.9rem; margin-bottom: 0.3rem;"><%- icon %></div>
            <div class="day-reward" style="font-size: 0.75rem; font-weight: 800;"><%= rewardMap[i] %></div>
          </div>
          <% } %>
        </div>
        <% if (isMissed && !alreadyClaimed) { %>
          <div class="streak-missed-alert">
            <i class="fas fa-exclamation-triangle"></i>
            <div>Anda melewatkan login harian kemarin. Streak hangus & saldo bonus akan dipotong penalti saat Anda melakukan klaim.</div>
          </div>
        <% } %>
      </div>
      <% } %>
      <div class="hero-stats">
        <div class="stat-item glass">
          <span class="stat-num" data-count="<%= allGames.length %>">0</span>
          <span class="stat-label">Game Tersedia</span>
        </div>
        <div class="stat-item glass">
          <span class="stat-num">4K</span>
          <span class="stat-label">Resolusi Max</span>
        </div>
        <div class="stat-item glass">
          <span class="stat-num">60fps</span>
          <span class="stat-label">Smooth Gaming</span>
        </div>
        <div class="stat-item glass">
          <span class="stat-num">24/7</span>
          <span class="stat-label">Support</span>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-card-stack">
        <div class="floating-badge badge-price">Mulai Rp 40.000</div>
        <div class="hero-main-card">
          <div class="hero-card-header">
            <div class="hero-card-icon"><i class="fas fa-gamepad"></i></div>
            <div>
              <div class="hero-card-title">AlexCloud Gaming</div>
              <div class="hero-card-sub">Server Online • Low Latency</div>
            </div>
          </div>
          <div class="hero-game-list">
            <% games.slice(0, 4).forEach((game, i) => { %>
            <div class="hero-game-item">
              <div class="game-dot <%= ['blue','purple','green','orange'][i % 4] %>"></div>
              <span class="game-name"><%= game.name %></span>
              <span class="game-status">● Online</span>
            </div>
            <% }) %>
          </div>
        </div>
        <div class="floating-badge badge-users">Ribuan Gamer Aktif</div>
      </div>
    </div>
  </div>
</section>

<!-- AI TRENDING SECTION -->
<section class="trending-section">
  <div class="trending-container">
    <div class="section-header">
      <div class="section-tag">Trending</div>
      <h2 class="section-title">Game <span class="accent">Trending Minggu Ini</span></h2>
      <p class="section-desc">Rekomendasi cerdas AI berdasarkan rating & popularitas terkini</p>
    </div>
    <div class="trending-scroll">
      <% trendingGames.forEach((game, idx) => { %>
      <div class="trending-card">
        <div class="trending-rank">#<%= idx + 1 %></div>
        <img src="<%= game.image %>" alt="<%= game.name %>" class="trending-img" width="200" height="300" loading="lazy" decoding="async">
        <div class="trending-info">
          <div class="trending-name"><%= game.name %></div>
          <div class="trending-genre"><%= game.genre %></div>
          <div class="trending-rating">
            <% for(let i=0;i<5;i++){%><i class="fas fa-star" style="color:<%= i < Math.floor(game.rating) ? '#fbbf24' : '#333' %>;font-size:0.65rem;"></i><%}%>
            <span><%= game.rating %></span>
          </div>
        </div>
        <span class="trending-tag"><%= game.tag %></span>
      </div>
      <% }) %>
    </div>
  </div>
</section>

