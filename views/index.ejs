<%- include('partials/header') %>

<!-- HERO -->
<section class="hero" id="main-content" aria-label="Hero utama">
  <div class="hero-bg"></div>
  <div class="hero-grid-overlay"></div>
  <div class="hero-particles" aria-hidden="true"></div>
  <div class="hero-container">
    <div class="hero-content">
      <div class="hero-badge">
        <i class="fas fa-bolt"></i>
        <span>Platform Cloud Gaming #1 Indonesia</span>
      </div>
      <h1 class="hero-title">
        Main Game AAA<br><span class="accent">Tanpa PC Mahal</span>
      </h1>
      <p class="hero-subtitle">
        AlexCloud menghadirkan pengalaman gaming premium langsung dari cloud. 
        Akses ratusan game terbaru dengan koneksi internet biasa. 
        Mulai dari Rp 40.000/minggu!
      </p>
      <div class="hero-actions">
        <a href="/pricing" class="btn-primary">
          <i class="fas fa-gamepad"></i> Mulai Sekarang
        </a>
        <a href="/games" class="btn-secondary">
          <i class="fas fa-th-large"></i> Lihat Game
        </a>
      </div>
      <div class="hero-stats">
        <div class="stat-item glass">
          <span class="stat-num" data-count="<%= allGames.length %>">0</span>
          <span class="stat-label">Game Tersedia</span>
        </div>
        <div class="stat-item glass">
          <span class="stat-num">4K</span>
          <span class="stat-label">Resolusi Max</span>
        </div>
        <div class="stat-item glass">
          <span class="stat-num">60fps</span>
          <span class="stat-label">Smooth Gaming</span>
        </div>
        <div class="stat-item glass">
          <span class="stat-num">24/7</span>
          <span class="stat-label">Support</span>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-card-stack">
        <div class="floating-badge badge-price">Mulai Rp 40.000</div>
        <div class="hero-main-card">
          <div class="hero-card-header">
            <div class="hero-card-icon"><i class="fas fa-gamepad"></i></div>
            <div>
              <div class="hero-card-title">AlexCloud Gaming</div>
              <div class="hero-card-sub">Server Online • Low Latency</div>
            </div>
          </div>
          <div class="hero-game-list">
            <% games.slice(0, 4).forEach((game, i) => { %>
            <div class="hero-game-item">
              <div class="game-dot <%= ['blue','purple','green','orange'][i % 4] %>"></div>
              <span class="game-name"><%= game.name %></span>
              <span class="game-status">● Online</span>
            </div>
            <% }) %>
          </div>
        </div>
        <div class="floating-badge badge-users">Ribuan Gamer Aktif</div>
      </div>
    </div>
  </div>
</section>

<!-- AI TRENDING SECTION -->
<section class="trending-section">
  <div class="trending-container">
    <div class="section-header">
      <div class="section-tag">Trending</div>
      <h2 class="section-title">Game <span class="accent">Trending Minggu Ini</span></h2>
      <p class="section-desc">Rekomendasi cerdas AI berdasarkan rating & popularitas terkini</p>
    </div>
    <div class="trending-scroll">
      <% trendingGames.forEach((game, idx) => { %>
      <div class="trending-card">
        <div class="trending-rank">#<%= idx + 1 %></div>
        <img src="<%= game.image %>" alt="<%= game.name %>" class="trending-img" width="200" height="300" loading="lazy" decoding="async">
        <div class="trending-info">
          <div class="trending-name"><%= game.name %></div>
          <div class="trending-genre"><%= game.genre %></div>
          <div class="trending-rating">
            <% for(let i=0;i<5;i++){%><i class="fas fa-star" style="color:<%= i < Math.floor(game.rating) ? '#fbbf24' : '#333' %>;font-size:0.65rem;"></i><%}%>
            <span><%= game.rating %></span>
          </div>
        </div>
        <span class="trending-tag"><%= game.tag %></span>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section class="features-section">
  <div class="features-container">
    <div class="section-header animate-on-scroll">
      <div class="section-tag">Kenapa AlexCloud?</div>
      <h2 class="section-title">Gaming <span class="accent">Tanpa Batas</span></h2>
      <p class="section-desc">Nikmati game AAA terbaru dengan kualitas terbaik tanpa perlu investasi hardware mahal.</p>
    </div>
    <div class="features-grid">
      <div class="feature-card animate-on-scroll" data-delay="0">
        <div class="feature-icon blue"><i class="fas fa-bolt" style="color:var(--accent-blue)"></i></div>
        <div class="feature-title">Latency Ultra Rendah</div>
        <p class="feature-desc">Server dioptimalkan untuk Indonesia dengan ping di bawah 30ms untuk pengalaman gaming yang mulus.</p>
      </div>
      <div class="feature-card animate-on-scroll" data-delay="80">
        <div class="feature-icon purple"><i class="fas fa-gamepad" style="color:#F43F5E"></i></div>
        <div class="feature-title">100+ Game Premium</div>
        <p class="feature-desc">Akses game AAA terbaru seperti EA FC 26, MotoGP 25, Hogwarts Legacy, dan masih banyak lagi.</p>
      </div>
      <div class="feature-card animate-on-scroll" data-delay="160">
        <div class="feature-icon green"><i class="fas fa-tv" style="color:var(--accent-green)"></i></div>
        <div class="feature-title">Streaming 4K / 60fps</div>
        <p class="feature-desc">Kualitas visual maksimal dengan resolusi hingga 4K dan framerate stabil 60fps bahkan di HP.</p>
      </div>
      <div class="feature-card animate-on-scroll" data-delay="0">
        <div class="feature-icon orange"><i class="fas fa-robot" style="color:var(--accent-orange)"></i></div>
        <div class="feature-title">AI Assistant 24/7</div>
        <p class="feature-desc">AlexBot AI siap menjawab pertanyaanmu, merekomendasikan game, dan membantu masalah kapanpun.</p>
      </div>
      <div class="feature-card animate-on-scroll" data-delay="80">
        <div class="feature-icon blue"><i class="fas fa-save" style="color:var(--accent-blue)"></i></div>
        <div class="feature-title">Cloud Save</div>
        <p class="feature-desc">Progress game tersimpan di cloud. Main di HP, lanjut di TV, atau sebaliknya tanpa kehilangan data.</p>
      </div>
      <div class="feature-card animate-on-scroll" data-delay="160">
        <div class="feature-icon purple"><i class="fas fa-tags" style="color:#F43F5E"></i></div>
        <div class="feature-title">Harga Terjangkau</div>
        <p class="feature-desc">Mulai dari Rp 40.000/minggu saja! Jauh lebih hemat dibanding beli PC gaming jutaan rupiah.</p>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS / CARA PAKAI -->
<section class="how-section" id="how-it-works">
  <div class="how-container">
    <div class="section-header animate-on-scroll">
      <div class="section-tag">Cara Pakai</div>
      <h2 class="section-title">Mulai Main dalam <span class="accent">3 Langkah</span></h2>
      <p class="section-desc">Tanpa download berat, tanpa install ribet. Cukup punya internet — langsung gas.</p>
    </div>
    <div class="how-steps">
      <div class="how-step animate-on-scroll" data-delay="0">
        <div class="how-step-num">1</div>
        <div class="how-step-icon"><i class="fas fa-shopping-cart" aria-hidden="true"></i></div>
        <h3 class="how-step-title">Pilih Paket</h3>
        <p class="how-step-desc">Daftar gratis, lalu pilih paket mulai Rp 40.000/minggu sesuai kebutuhanmu.</p>
      </div>
      <div class="how-step animate-on-scroll" data-delay="130">
        <div class="how-step-num">2</div>
        <div class="how-step-icon"><i class="fas fa-laptop" aria-hidden="true"></i></div>
        <h3 class="how-step-title">Buka di Perangkat Apa Saja</h3>
        <p class="how-step-desc">HP, laptop, tablet, atau Smart TV — cukup lewat browser, tanpa PC mahal.</p>
      </div>
      <div class="how-step animate-on-scroll" data-delay="260">
        <div class="how-step-num">3</div>
        <div class="how-step-icon"><i class="fas fa-play" aria-hidden="true"></i></div>
        <h3 class="how-step-title">Langsung Main</h3>
        <p class="how-step-desc">Game AAA jalan instan dari cloud — 4K 60fps, ping rendah, tanpa loading lama.</p>
      </div>
    </div>
  </div>
</section>

<!-- POPULAR GAMES with View Mode Toggle -->
<section class="games-section" id="games-section">
  <div class="games-container">
    <div class="section-header animate-on-scroll">
      <div class="section-tag">Game Terpopuler</div>
      <h2 class="section-title">Pilihan <span class="accent">Game Terbaik</span></h2>
      <p class="section-desc">Dari sepak bola, balap, hingga RPG epik — semua ada di AlexCloud!</p>
    </div>

    <!-- View Mode Toggle -->
    <div class="view-mode-bar">
      <span class="view-mode-label"><i class="fas fa-eye"></i> Mode Tampilan:</span>
      <div class="view-mode-btns">
        <button class="view-mode-btn active" id="btn-grid" onclick="setViewMode('grid')" title="Grid View" aria-label="Tampilan Grid" aria-pressed="true">
          <i class="fas fa-th-large" aria-hidden="true"></i> Grid
        </button>
        <button class="view-mode-btn" id="btn-list" onclick="setViewMode('list')" title="List View" aria-label="Tampilan List" aria-pressed="false">
          <i class="fas fa-list" aria-hidden="true"></i> List
        </button>
        <button class="view-mode-btn" id="btn-compact" onclick="setViewMode('compact')" title="Compact View" aria-label="Tampilan Compact" aria-pressed="false">
          <i class="fas fa-grip-horizontal" aria-hidden="true"></i> Compact
        </button>
      </div>
    </div>

    <div class="games-grid" id="gamesDisplay">
      <% games.slice(0, 8).forEach((game, i) => { %>
      <div class="game-card animate-on-scroll" data-delay="<%= (i % 4) * 70 %>">
        <div class="game-img-wrap">
          <img src="<%= game.image %>" alt="<%= game.name %>" width="300" height="450" loading="lazy" decoding="async">
          <% if (game.tag) { %><span class="game-tag"><%= game.tag %></span><% } %>
        </div>
        <div class="game-body">
          <div class="game-title"><%= game.name %></div>
          <div class="game-genre"><i class="fas fa-tag"></i> <%= game.genre %></div>
          <p class="game-desc"><%= game.description %></p>
        </div>
        <div class="game-footer">
          <div class="game-rating"><i class="fas fa-star"></i> <%= game.rating %></div>
          <span class="game-platform"><i class="fas fa-cloud"></i> Cloud</span>
        </div>
      </div>
      <% }) %>
    </div>
    <div class="games-cta">
      <a href="/games" class="btn-primary"><i class="fas fa-th-large"></i> Lihat Semua Game</a>
    </div>
</section>

<!-- TIKTOK GAMEPLAY SECTION -->
