<%- include('partials/header') %>

<!-- HERO -->
<section class="hero" id="main-content" aria-label="Hero utama">
  <div class="hero-bg"></div>
  <div class="hero-grid-overlay"></div>
  <div class="hero-particles" aria-hidden="true"></div>
  <div class="hero-container">
    <!-- Pengumuman dari admin — tampil di atas beranda (bukan banner fixed seluruh situs) -->
    <% if (typeof announcement !== 'undefined' && announcement) { %>
    <div class="home-announce home-announce--<%= announcement.type || 'info' %>" id="siteAnnounce" data-ann-id="<%= announcement.id || 'default' %>">
      <i class="fas fa-<%= announcement.type === 'promo' ? 'gift' : (announcement.type === 'warn' ? 'triangle-exclamation' : 'bullhorn') %>" aria-hidden="true"></i>
      <span class="home-announce-text"><%= announcement.text %></span>
      <% if (announcement.link && announcement.linkText) { %>
        <a href="<%= announcement.link %>" class="home-announce-link"><%= announcement.linkText %> →</a>
      <% } %>
      <button class="home-announce-close" type="button" onclick="dismissAnnounce()" aria-label="Tutup pengumuman">✕</button>
    </div>
    <style>
      .home-announce{grid-column:1/-1;display:flex;align-items:center;gap:0.7rem;width:100%;margin-bottom:2rem;padding:0.85rem 1.1rem;border-radius:14px;font-family:var(--font-ui);font-size:0.92rem;font-weight:500;color:#fff;background:var(--gradient-main);box-shadow:0 8px 24px rgba(0,0,0,0.30);border:1px solid rgba(255,255,255,0.12)}
      .home-announce--promo{background:linear-gradient(135deg,#7c3aed 0%,#db2777 100%)}
      .home-announce--warn{background:linear-gradient(135deg,#d97706 0%,#dc2626 100%)}
      .home-announce > i{flex-shrink:0;font-size:1.05rem}
      .home-announce-text{flex:1;min-width:0;line-height:1.45}
      .home-announce-link{color:#fff;font-weight:700;text-decoration:underline;white-space:nowrap;flex-shrink:0}
      .home-announce-close{flex-shrink:0;background:rgba(255,255,255,0.2);border:none;color:#fff;width:26px;height:26px;border-radius:50%;cursor:pointer;font-size:0.8rem;line-height:1;display:flex;align-items:center;justify-content:center;transition:background 0.2s}
      .home-announce-close:hover{background:rgba(255,255,255,0.38)}
      @media(max-width:768px){.home-announce{font-size:0.84rem;margin-bottom:1.25rem;padding:0.7rem 0.9rem}}
    </style>
    <script>
      (function () {
        var el = document.getElementById('siteAnnounce');
        if (!el) return;
        var id = el.getAttribute('data-ann-id') || 'default';
        try { if (localStorage.getItem('annDismissed') === id) { el.remove(); } } catch (e) {}
      })();
      function dismissAnnounce() {
        var el = document.getElementById('siteAnnounce');
        if (!el) return;
        var id = el.getAttribute('data-ann-id') || 'default';
        try { localStorage.setItem('annDismissed', id); } catch (e) {}
        el.remove();
      }
    </script>
    <% } %>
    <div class="hero-content">
      <div class="hero-badge">
        <i class="fas fa-bolt"></i>
        <span>Platform Cloud Gaming #1 Indonesia</span>
      </div>
      <h1 class="hero-title">
        Main Game AAA<br><span class="accent">Tanpa PC Mahal</span>
      </h1>
      <p class="hero-subtitle">
        AlexCloud menghadirkan pengalaman gaming premium langsung dari cloud. 
        Akses ratusan game terbaru dengan koneksi internet biasa. 
        Mulai dari Rp 40.000/minggu!
      </p>
      <div class="hero-actions">
        <a href="/pricing?ref_=home_hero_pricing" class="btn-primary">
          <i class="fas fa-gamepad"></i> Mulai Sekarang
        </a>
        <a href="/games?ref_=home_hero_games" class="btn-secondary">
          <i class="fas fa-th-large"></i> Lihat Game
        </a>
      </div>
      <% if (user) { %>
      <div style="margin: 2.5rem auto 0; display: flex; align-items: center; justify-content: space-between; gap: 1rem; background: rgba(255,255,255,0.06); padding: 1.25rem 1.5rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.12); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); max-width: 480px; text-align: left;">
        <div style="display: flex; align-items: center; gap: 1rem;">
          <div style="width: 50px; height: 50px; border-radius: 14px; background: linear-gradient(135deg, #00d4ff, #007bff); display: flex; align-items: center; justify-content: center; font-size: 1.4rem; color: #fff; box-shadow: 0 4px 15px rgba(0,212,255,0.4); flex-shrink: 0;">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a8 8 0 0 1-5.3 7.7 2 2 0 0 1-2.7-1.4l-1-4.2a2 2 0 0 0-1.7-1.5L5 16a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h14"></path>
              <path d="M21 11v4h-3a2 2 0 0 1 0-4h3z"></path>
            </svg>
          </div>
          <div>
            <div style="font-family: var(--font-ui); font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.3rem; font-weight: 600;">Saldo Dompet</div>
            <div id="heroWalletBalance" style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 800; color: #fff; line-height: 1;">Rp <%= balance.toLocaleString('id-ID') %></div>
          </div>
        </div>
        <a href="/wallet?ref_=home_wallet_topup" class="btn-primary" style="padding: 0.75rem 1.25rem; font-size: 0.95rem; box-shadow: 0 4px 15px rgba(255,107,53,0.3); border-radius: 12px; flex-shrink: 0; display: flex; align-items: center; gap: 0.5rem;">
          <i class="fas fa-plus" style="font-size: 0.85rem;"></i> Top Up
        </a>
      </div>

      <% 
         let today = new Date();
         today.setUTCHours(0,0,0,0);
         let todayDate = today.toISOString().split('T')[0];
         let alreadyClaimed = lastDailyLogin === todayDate;
         
         let currentStreak = loginStreak || 0;
         let nextStreak = alreadyClaimed ? currentStreak : (currentStreak + 1 > 7 ? 1 : currentStreak + 1);

         // Cek apakah bolong
         let lastClaim = null;
         if (lastDailyLogin) {
            lastClaim = new Date(lastDailyLogin);
            lastClaim.setUTCHours(0,0,0,0);
         }
         let isMissed = false;
         if (lastClaim) {
            let diffDays = Math.round((today.getTime() - lastClaim.getTime()) / (1000*60*60*24));
            if (diffDays > 1) {
               isMissed = true;
               nextStreak = 1;
            }
         }
         if (!lastDailyLogin) nextStreak = 1;

         const rewardMap = { 1: '1k', 2: '2k', 3: '3k', 4: '4k', 5: '5k', 6: '7k', 7: '10k' };
      %>
      <div id="streakWidget" style="margin: 1rem auto 0; background: rgba(255,255,255,0.06); padding: 1.25rem 1.5rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.12); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); box-shadow: 0 8px 32px rgba(0,0,0,0.3); max-width: 480px; text-align: left;">
        <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin-bottom: 1rem;">
          <div>
            <div style="font-family: var(--font-ui); font-size: 0.8rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.3rem; font-weight: 600;">Reward Harian</div>
            <div style="font-family: var(--font-display); font-size: 1.1rem; font-weight: 800; color: #fff; line-height: 1.2;">7-Day Login Streak</div>
          </div>
          <% if (alreadyClaimed) { %>
            <button class="btn-secondary" disabled style="padding: 0.5rem 1rem; font-size: 0.85rem; border-radius: 8px; opacity: 0.6; cursor: not-allowed; display: flex; align-items: center; gap: 0.4rem; outline: none; border-color: rgba(255,255,255,0.1);">
              <i class="fas fa-check"></i> Hari Ini Diklaim
            </button>
          <% } else { %>
            <button id="btnDailyLogin" onclick="claimDailyLogin()" class="btn-primary" style="background: linear-gradient(135deg, #10b981, #059669); padding: 0.5rem 1rem; font-size: 0.85rem; box-shadow: 0 4px 15px rgba(16,185,129,0.3); border-radius: 8px; border: none; color: white; cursor: pointer; display: flex; align-items: center; gap: 0.4rem;">
              <i class="fas fa-gift"></i> Klaim Sekarang
            </button>
          <% } %>
        </div>
        
        <div style="display: flex; gap: 0.4rem; justify-content: space-between; overflow-x: auto; padding-bottom: 0.5rem; user-select: none;">
          <% for(let i=1; i<=7; i++) { 
             let status = 'future';
             if (i < nextStreak || (i === nextStreak && alreadyClaimed)) status = 'passed';
             else if (i === nextStreak && !alreadyClaimed) status = 'today';
             
             let bg = 'rgba(255,255,255,0.05)';
             let border = '1px solid rgba(255,255,255,0.05)';
             let color = 'rgba(255,255,255,0.4)';
             let icon = '<i class="fas fa-lock"></i>';
             let glow = 'none';

             if (status === 'passed') {
                bg = 'rgba(16,185,129,0.15)';
                border = '1px solid rgba(16,185,129,0.3)';
                color = '#10b981';
                icon = '<i class="fas fa-check-circle"></i>';
             } else if (status === 'today') {
                bg = 'linear-gradient(135deg, rgba(16,185,129,0.8), rgba(5,150,105,0.8))';
                border = '1px solid #10b981';
                color = '#fff';
                icon = '<i class="fas fa-gift"></i>';
                glow = '0 0 10px rgba(16,185,129,0.5)';
             }
          %>
          <div style="flex: 1; min-width: 45px; background: <%= bg %>; border: <%= border %>; border-radius: 8px; padding: 0.5rem 0; text-align: center; color: <%= color %>; box-shadow: <%= glow %>; transition: all 0.3s ease;">
            <div style="font-size: 0.65rem; font-weight: 700; margin-bottom: 0.3rem;">H<%= i %></div>
            <div style="font-size: 0.9rem; margin-bottom: 0.3rem;"><%- icon %></div>
            <div style="font-size: 0.75rem; font-weight: 800;"><%= rewardMap[i] %></div>
          </div>
          <% } %>
        </div>
        <% if (isMissed && !alreadyClaimed) { %>
          <div style="margin-top: 0.5rem; font-size: 0.75rem; color: #f87171; background: rgba(248,113,113,0.1); padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(248,113,113,0.2); display: flex; align-items: flex-start; gap: 0.5rem; line-height: 1.4;">
            <i class="fas fa-exclamation-triangle" style="margin-top: 0.15rem;"></i>
            <div>Anda melewatkan login harian kemarin. Streak hangus & terkena penalti saldo bonus.</div>
          </div>
        <% } %>
      </div>
      <% } %>
      <div class="hero-stats">
        <div class="stat-item glass">
          <span class="stat-num" data-count="<%= allGames.length %>">0</span>
          <span class="stat-label">Game Tersedia</span>
        </div>
        <div class="stat-item glass">
          <span class="stat-num">4K</span>
          <span class="stat-label">Resolusi Max</span>
        </div>
        <div class="stat-item glass">
          <span class="stat-num">60fps</span>
          <span class="stat-label">Smooth Gaming</span>
        </div>
        <div class="stat-item glass">
          <span class="stat-num">24/7</span>
          <span class="stat-label">Support</span>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-card-stack">
        <div class="floating-badge badge-price">Mulai Rp 40.000</div>
        <div class="hero-main-card">
          <div class="hero-card-header">
            <div class="hero-card-icon"><i class="fas fa-gamepad"></i></div>
            <div>
              <div class="hero-card-title">AlexCloud Gaming</div>
              <div class="hero-card-sub">Server Online • Low Latency</div>
            </div>
          </div>
          <div class="hero-game-list">
            <% games.slice(0, 4).forEach((game, i) => { %>
            <div class="hero-game-item">
              <div class="game-dot <%= ['blue','purple','green','orange'][i % 4] %>"></div>
              <span class="game-name"><%= game.name %></span>
              <span class="game-status">● Online</span>
            </div>
            <% }) %>
          </div>
        </div>
        <div class="floating-badge badge-users">Ribuan Gamer Aktif</div>
      </div>
    </div>
  </div>
</section>

<!-- AI TRENDING SECTION -->
<section class="trending-section">
  <div class="trending-container">
    <div class="section-header">
      <div class="section-tag">Trending</div>
      <h2 class="section-title">Game <span class="accent">Trending Minggu Ini</span></h2>
      <p class="section-desc">Rekomendasi cerdas AI berdasarkan rating & popularitas terkini</p>
    </div>
    <div class="trending-scroll">
      <% trendingGames.forEach((game, idx) => { %>
      <div class="trending-card">
        <div class="trending-rank">#<%= idx + 1 %></div>
        <img src="<%= game.image %>" alt="<%= game.name %>" class="trending-img" width="200" height="300" loading="lazy" decoding="async">
        <div class="trending-info">
          <div class="trending-name"><%= game.name %></div>
          <div class="trending-genre"><%= game.genre %></div>
          <div class="trending-rating">
            <% for(let i=0;i<5;i++){%><i class="fas fa-star" style="color:<%= i < Math.floor(game.rating) ? '#fbbf24' : '#333' %>;font-size:0.65rem;"></i><%}%>
            <span><%= game.rating %></span>
          </div>
        </div>
        <span class="trending-tag"><%= game.tag %></span>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section class="features-section">
  <div class="features-container">
    <div class="section-header animate-on-scroll">
      <div class="section-tag">Kenapa AlexCloud?</div>
      <h2 class="section-title">Gaming <span class="accent">Tanpa Batas</span></h2>
      <p class="section-desc">Nikmati game AAA terbaru dengan kualitas terbaik tanpa perlu investasi hardware mahal.</p>
    </div>
    <div class="features-grid">
      <div class="feature-card animate-on-scroll" data-delay="0">
        <div class="feature-icon blue"><i class="fas fa-bolt" style="color:var(--accent-blue)"></i></div>
        <div class="feature-title">Latency Ultra Rendah</div>
        <p class="feature-desc">Server dioptimalkan untuk Indonesia dengan ping di bawah 30ms untuk pengalaman gaming yang mulus.</p>
      </div>
      <div class="feature-card animate-on-scroll" data-delay="80">
        <div class="feature-icon purple"><i class="fas fa-gamepad" style="color:#a3a3a3"></i></div>
        <div class="feature-title">100+ Game Premium</div>
        <p class="feature-desc">Akses game AAA terbaru seperti EA FC 26, MotoGP 25, Hogwarts Legacy, dan masih banyak lagi.</p>
      </div>
      <div class="feature-card animate-on-scroll" data-delay="160">
        <div class="feature-icon green"><i class="fas fa-tv" style="color:var(--accent-green)"></i></div>
        <div class="feature-title">Streaming 4K / 60fps</div>
        <p class="feature-desc">Kualitas visual maksimal dengan resolusi hingga 4K dan framerate stabil 60fps bahkan di HP.</p>
      </div>
      <div class="feature-card animate-on-scroll" data-delay="0">
        <div class="feature-icon orange"><i class="fas fa-robot" style="color:var(--accent-orange)"></i></div>
        <div class="feature-title">AI Assistant 24/7</div>
        <p class="feature-desc">AlexBot AI siap menjawab pertanyaanmu, merekomendasikan game, dan membantu masalah kapanpun.</p>
      </div>
      <div class="feature-card animate-on-scroll" data-delay="80">
        <div class="feature-icon blue"><i class="fas fa-save" style="color:var(--accent-blue)"></i></div>
        <div class="feature-title">Cloud Save</div>
        <p class="feature-desc">Progress game tersimpan di cloud. Main di HP, lanjut di TV, atau sebaliknya tanpa kehilangan data.</p>
      </div>
      <div class="feature-card animate-on-scroll" data-delay="160">
        <div class="feature-icon purple"><i class="fas fa-tags" style="color:#a3a3a3"></i></div>
        <div class="feature-title">Harga Terjangkau</div>
        <p class="feature-desc">Mulai dari Rp 40.000/minggu saja! Jauh lebih hemat dibanding beli PC gaming jutaan rupiah.</p>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS / CARA PAKAI -->
<section class="how-section" id="how-it-works">
  <div class="how-container">
    <div class="section-header animate-on-scroll">
      <div class="section-tag">Cara Pakai</div>
      <h2 class="section-title">Mulai Main dalam <span class="accent">3 Langkah</span></h2>
      <p class="section-desc">Tanpa download berat, tanpa install ribet. Cukup punya internet — langsung gas.</p>
    </div>
    <div class="how-steps">
      <div class="how-step animate-on-scroll" data-delay="0">
        <div class="how-step-num">1</div>
        <div class="how-step-icon"><i class="fas fa-shopping-cart" aria-hidden="true"></i></div>
        <h3 class="how-step-title">Pilih Paket</h3>
        <p class="how-step-desc">Daftar gratis, lalu pilih paket mulai Rp 40.000/minggu sesuai kebutuhanmu.</p>
      </div>
      <div class="how-step animate-on-scroll" data-delay="130">
        <div class="how-step-num">2</div>
        <div class="how-step-icon"><i class="fas fa-laptop" aria-hidden="true"></i></div>
        <h3 class="how-step-title">Buka di Perangkat Apa Saja</h3>
        <p class="how-step-desc">HP, laptop, tablet, atau Smart TV — cukup lewat browser, tanpa PC mahal.</p>
      </div>
      <div class="how-step animate-on-scroll" data-delay="260">
        <div class="how-step-num">3</div>
        <div class="how-step-icon"><i class="fas fa-play" aria-hidden="true"></i></div>
        <h3 class="how-step-title">Langsung Main</h3>
        <p class="how-step-desc">Game AAA jalan instan dari cloud — 4K 60fps, ping rendah, tanpa loading lama.</p>
      </div>
    </div>
  </div>
</section>

<!-- POPULAR GAMES with View Mode Toggle -->
<section class="games-section" id="games-section">
  <div class="games-container">
    <div class="section-header animate-on-scroll">
      <div class="section-tag">Game Terpopuler</div>
      <h2 class="section-title">Pilihan <span class="accent">Game Terbaik</span></h2>
      <p class="section-desc">Dari sepak bola, balap, hingga RPG epik — semua ada di AlexCloud!</p>
    </div>

    <!-- View Mode Toggle -->
    <div class="view-mode-bar">
      <span class="view-mode-label"><i class="fas fa-eye"></i> Mode Tampilan:</span>
      <div class="view-mode-btns">
        <button class="view-mode-btn active" id="btn-grid" onclick="setViewMode('grid')" title="Grid View" aria-label="Tampilan Grid" aria-pressed="true">
          <i class="fas fa-th-large" aria-hidden="true"></i> Grid
        </button>
        <button class="view-mode-btn" id="btn-list" onclick="setViewMode('list')" title="List View" aria-label="Tampilan List" aria-pressed="false">
          <i class="fas fa-list" aria-hidden="true"></i> List
        </button>
        <button class="view-mode-btn" id="btn-compact" onclick="setViewMode('compact')" title="Compact View" aria-label="Tampilan Compact" aria-pressed="false">
          <i class="fas fa-grip-horizontal" aria-hidden="true"></i> Compact
        </button>
      </div>
    </div>

    <div class="games-grid" id="gamesDisplay">
      <% games.slice(0, 8).forEach((game, i) => { %>
      <div class="game-card animate-on-scroll" data-delay="<%= (i % 4) * 70 %>">
        <div class="game-img-wrap">
          <img src="<%= game.image %>" alt="<%= game.name %>" width="300" height="450" loading="lazy" decoding="async">
          <% if (game.tag) { %><span class="game-tag"><%= game.tag %></span><% } %>
        </div>
        <div class="game-body">
          <div class="game-title"><%= game.name %></div>
          <div class="game-genre"><i class="fas fa-tag"></i> <%= game.genre %></div>
          <p class="game-desc"><%= game.description %></p>
        </div>
        <div class="game-footer">
          <div class="game-rating"><i class="fas fa-star"></i> <%= game.rating %></div>
          <span class="game-platform"><i class="fas fa-cloud"></i> Cloud</span>
        </div>
      </div>
      <% }) %>
    </div>
    <div class="games-cta">
      <a href="/games?ref_=home_explore_games" class="btn-primary"><i class="fas fa-th-large"></i> Lihat Semua Game</a>
    </div>
</section>

<!-- TIKTOK GAMEPLAY SECTION -->
<section class="tiktok-section" id="tiktok-section">
  <div class="tiktok-card-container animate-on-scroll">
    <div class="section-header text-center">
      <div class="section-tag">Bukti Nyata</div>
      <h2 class="section-title">Bukti <span class="accent">Nyata</span></h2>
      <p class="section-desc">Lihat sendiri gameplay FC26 smooth di HP — banyak video di TikTok kami</p>
    </div>

    <div class="tiktok-card-wrapper">
      <div class="tiktok-premium-card">
        <div class="tiktok-card-glow"></div>
        <div class="tiktok-card-inner">
          <div class="tiktok-card-logo">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.75a8.27 8.27 0 004.84 1.55V6.84a4.85 4.85 0 01-1.07-.15z"/></svg>
          </div>
          
