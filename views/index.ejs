  <div class="tiktok-card-container animate-on-scroll">
    <div class="section-header text-center">
      <div class="section-tag">Bukti Nyata</div>
      <h2 class="section-title">Bukti <span class="accent">Nyata</span></h2>
      <p class="section-desc">Lihat sendiri gameplay FC26 smooth di HP — banyak video di TikTok kami</p>
    </div>

    <div class="tiktok-card-wrapper">
      <div class="tiktok-premium-card">
        <div class="tiktok-card-glow"></div>
        <div class="tiktok-card-inner">
          <div class="tiktok-card-logo">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.75a8.27 8.27 0 004.84 1.55V6.84a4.85 4.85 0 01-1.07-.15z"/></svg>
