<!-- TRUST / GARANSI -->
<section class="trust-section" id="trust">
  <div class="trust-container">
    <div class="section-header animate-on-scroll">
      <div class="section-tag">Aman &amp; Terpercaya</div>
      <h2 class="section-title">Belanja dengan <span class="accent">Tenang</span></h2>
      <p class="section-desc">Kami tahu kamu mengeluarkan uang. Karena itu, setiap transaksi di AlexCloud dirancang aman, transparan, dan bergaransi.</p>
    </div>
    <div class="trust-grid">
      <div class="trust-card animate-on-scroll" data-delay="0">
        <div class="trust-icon"><i class="fas fa-shield-halved"></i></div>
        <h3 class="trust-title">Pembayaran Aman</h3>
        <p class="trust-desc">Lewat QRIS resmi (DANA, GoPay, OVO, ShopeePay, m-banking). Tanpa biaya tersembunyi.</p>
      </div>
      <div class="trust-card animate-on-scroll" data-delay="80">
        <div class="trust-icon"><i class="fas fa-sync-alt"></i></div>
        <h3 class="trust-title">Garansi Refund</h3>
        <p class="trust-desc">Kalau kendala murni dari sisi kami, dana kamu kami kembalikan. <a href="/refund">Lihat kebijakan</a>.</p>
      </div>
      <div class="trust-card animate-on-scroll" data-delay="160">
        <div class="trust-icon"><i class="fas fa-bolt"></i></div>
        <h3 class="trust-title">Aktivasi Instan</h3>
        <p class="trust-desc">Akun langsung aktif otomatis begitu pembayaran terkonfirmasi. Tanpa nunggu lama.</p>
      </div>
      <div class="trust-card animate-on-scroll" data-delay="240">
        <div class="trust-icon"><i class="fas fa-comments"></i></div>
        <h3 class="trust-title">Support 24/7</h3>
        <p class="trust-desc">Tim &amp; AI kami siap bantu lewat WhatsApp, Telegram, dan live chat kapan saja.</p>
      </div>
    </div>
    <div class="trust-links">
      <a href="/about"><i class="fas fa-circle-info"></i> Tentang Kami</a>
      <a href="/terms"><i class="fas fa-file-contract"></i> Syarat &amp; Ketentuan</a>
      <a href="/privacy"><i class="fas fa-user-shield"></i> Kebijakan Privasi</a>
      <a href="/refund"><i class="fas fa-rotate-left"></i> Kebijakan Refund</a>
    </div>
  </div>
</section>

<!-- PRICING -->
<section class="pricing-section" id="pricing">
  <div class="pricing-container">
    <div class="section-header animate-on-scroll">
      <div class="section-tag">Harga</div>
      <h2 class="section-title">Pilih <span class="accent">Paket Terbaik</span></h2>
      <p class="section-desc">Harga bersahabat untuk semua kalangan gamer. Semakin lama, semakin hemat!</p>
    </div>
    <div class="pricing-grid">
      <% plans.forEach((plan, i) => { %>
      <div class="plan-card <%= plan.popular ? 'popular' : '' %> animate-on-scroll" data-delay="<%= i * 90 %>">
        <% if (plan.popular) { %><div class="popular-badge">PALING POPULER</div><% } %>
        <div class="plan-name"><%= plan.name %></div>
        <div class="plan-price <%= plan.popular ? 'popular-price' : '' %>"><%= plan.priceDisplay %></div>
        <div class="plan-period">per <%= plan.name.toLowerCase() %></div>
        <ul class="plan-features">
          <li><i class="fas fa-check"></i> Akses 100+ Game Premium</li>
          <li><i class="fas fa-check"></i> Streaming 4K / 60fps</li>
          <li><i class="fas fa-check"></i> Cloud Save</li>
          <li><i class="fas fa-check"></i> AI Assistant 24/7</li>
          <li><i class="fas fa-check"></i> Support WhatsApp 24/7</li>
          <% if (plan.duration >= 30) { %><li><i class="fas fa-check"></i> Prioritas Antrian Server</li><% } %>
          <% if (plan.duration >= 60) { %><li><i class="fas fa-check"></i> Bonus 5 Hari Gratis</li><% } %>
          <% if (plan.duration >= 90) { %><li><i class="fas fa-star" style="color:#fbbf24"></i> Akses Game Baru Early</li><% } %>
        </ul>
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/order/<%= plan.id %>" class="plan-btn <%= plan.popular ? 'filled' : 'outline' %>">
            Pilih Paket Ini
          </a>
        <% } else { %>
          <a href="/login" class="plan-btn <%= plan.popular ? 'filled' : 'outline' %>">
            Login untuk Order
          </a>
        <% } %>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- TESTIMONIALS SECTION -->
<section class="testimonials-section" id="testimonials">
  <div class="testi-container">
    <div class="section-header">
      <div class="section-tag">Testimoni</div>
      <h2 class="section-title">Apa Kata <span class="accent">Gamer Kita?</span></h2>
      <p class="section-desc">Ribuan gamer puas bermain bersama AlexCloud. Ini cerita mereka.</p>
    </div>
    <% if (testimonials && testimonials.length > 0) { %>
    <div class="testi-slider-wrap">
      <button class="testi-nav testi-prev" onclick="testiPrev()" aria-label="Testimoni sebelumnya"><i class="fas fa-chevron-left" aria-hidden="true"></i></button>
      <div class="testi-slider" id="testiSlider">
        <% testimonials.forEach((t, idx) => { %>
        <div class="testi-card <%= idx === 0 ? 'active' : '' %>" data-idx="<%= idx %>">
          <% if (t.image) { %>
            <img src="<%= t.image %>" alt="Testimoni <%= t.name %>" class="testi-img" width="400" height="250" loading="lazy" decoding="async" fetchpriority="low">
          <% } %>
          <div class="testi-content">
            <div class="testi-stars">
              <% for(let i=0;i<5;i++){%><i class="fas fa-star" style="color:<%= i < t.rating ? '#fbbf24' : '#333' %>"></i><%}%>
            </div>
            <p class="testi-text"><span class="testi-quote-mark" aria-hidden="true">❝</span><%= t.text %></p>
            <div class="testi-author">
              <% if (t.avatar && !t.avatar.includes('dicebear.com')) { %>
                <img src="<%= t.avatar %>" alt="<%= t.name %>" class="testi-avatar" width="44" height="44" loading="lazy" decoding="async">
              <% } else { %>
                <div class="testi-avatar-placeholder" aria-hidden="true"><%= t.name.charAt(0).toUpperCase() %></div>
              <% } %>
              <div>
                <div class="testi-name"><%= t.name %></div>
                <div class="testi-role"><%= t.role %></div>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <button class="testi-nav testi-next" onclick="testiNext()" aria-label="Testimoni berikutnya"><i class="fas fa-chevron-right" aria-hidden="true"></i></button>
    </div>
    <div class="testi-dots" id="testiDots">
      <% testimonials.forEach((t, idx) => { %>
      <span class="testi-dot <%= idx === 0 ? 'active' : '' %>" onclick="goToTesti(<%= idx %>)"></span>
      <% }) %>
    </div>
    <% } %>
    <div class="testi-cta">
      <a href="/testimonials" class="btn-secondary"><i class="fas fa-star"></i> Lihat Semua Testimoni</a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section" id="cta">
  <div class="container">
    <div class="cta-card">
      <div class="cta-bg" aria-hidden="true"></div>
      <div class="cta-content">
        <div class="section-tag" style="margin-bottom: 1.5rem;">Mulai Sekarang</div>
        <h2 class="section-title">Siap Masuk ke Dunia <span class="accent">Cloud Gaming?</span></h2>
        <p class="section-desc" style="margin-bottom: 2.5rem;">Daftar gratis sekarang dan nikmati pengalaman gaming premium tanpa batas!</p>
        <div class="cta-actions">
          <a href="/register" class="btn-primary"><i class="fas fa-user-plus"></i> Daftar Gratis</a>
          <a href="https://wa.me/62<%= process.env.WA_NUMBER ? process.env.WA_NUMBER.replace(/^0/, '') : '82328437656' %>" target="_blank" class="btn-secondary">
            <i class="fab fa-whatsapp"></i> Hubungi Admin
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
