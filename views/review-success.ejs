<%- include('partials/header') %>

<style>
  .success-page { min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 2rem 1rem; }
  .success-card {
    background: var(--bg-card);
    border: 1px solid rgba(251,191,36,0.3);
    border-radius: var(--radius-xl, 1.25rem);
    padding: 3rem 2rem;
    max-width: 480px;
    width: 100%;
    text-align: center;
    box-shadow: 0 0 40px rgba(251,191,36,0.08), 0 0 80px rgba(0,0,0,0.3);
    animation: popIn 0.5s cubic-bezier(0.34,1.56,0.64,1);
  }
  @keyframes popIn {
    from { opacity: 0; transform: scale(0.85) translateY(30px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
  .success-icon {
    font-size: 4rem; margin-bottom: 1rem;
    animation: starPulse 1.5s ease-in-out infinite alternate;
  }
  @keyframes starPulse {
    from { text-shadow: 0 0 10px rgba(251,191,36,0.4); transform: scale(1); }
    to   { text-shadow: 0 0 30px rgba(251,191,36,0.8); transform: scale(1.08); }
  }
  .success-title { font-family: var(--font-display); font-size: 1.8rem; font-weight: 800; margin-bottom: 0.5rem; color: #fbbf24; }
  .success-desc { color: var(--text-muted); font-size: 0.95rem; line-height: 1.7; margin-bottom: 2rem; }
  .success-order-info {
    background: rgba(251,191,36,0.07); border: 1px solid rgba(251,191,36,0.15);
    border-radius: 0.75rem; padding: 1rem 1.25rem; margin-bottom: 2rem;
    font-family: var(--font-ui); font-size: 0.88rem; text-align: left;
  }
  .success-order-info span { color: var(--text-muted); }
  .success-order-info strong { color: #fbbf24; }
  .btn-go-back {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    background: linear-gradient(90deg, #fbbf24, #d97706);
    color: #111; border: none; border-radius: 0.625rem;
    font-family: var(--font-ui); font-size: 0.95rem; font-weight: 800;
    text-decoration: none; transition: opacity 0.2s, transform 0.15s;
  }
  .btn-go-back:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn-go-back-secondary {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.7rem 1.2rem; margin-top: 0.75rem;
    background: transparent; color: var(--text-muted);
    border: 1px solid var(--border); border-radius: 0.5rem;
    font-family: var(--font-ui); font-size: 0.85rem;
    text-decoration: none; transition: color 0.2s, border-color 0.2s;
  }
  .btn-go-back-secondary:hover { color: var(--text-primary); border-color: var(--text-muted); }
  .confetti { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; overflow: hidden; z-index: 9999; }
</style>

<div class="confetti" id="confetti"></div>

<div class="success-page">
  <div class="success-card">
    <div class="success-icon">⭐</div>
    <h1 class="success-title">Ulasan Terkirim!</h1>
    <p class="success-desc">
      Terima kasih sudah meluangkan waktu untuk berbagi pengalamanmu. Ulasanmu sudah langsung tampil di halaman testimoni AlexCloud! 🎉
    </p>

    <% if (order && order.orderId) { %>
    <div class="success-order-info">
      <div style="margin-bottom:0.35rem;"><span>Order: </span><strong>#<%= order.orderId %></strong></div>
      <div><span>Paket: </span><strong><%= order.planName %></strong></div>
    </div>
    <% } %>

    <div style="display:flex; flex-direction:column; align-items:center; gap:0.75rem;">
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/dashboard" class="btn-go-back"><i class="fas fa-tachometer-alt"></i> Ke Dashboard</a>
      <% } else { %>
        <a href="/" class="btn-go-back"><i class="fas fa-home"></i> Ke Beranda</a>
      <% } %>
      <a href="/testimonials" class="btn-go-back-secondary"><i class="fas fa-star"></i> Lihat Semua Ulasan</a>
    </div>
  </div>
</div>

<script>
  // Simple confetti
  (function() {
    const container = document.getElementById('confetti');
    const colors = ['#fbbf24', '#d97706', '#34d399', '#60a5fa', '#a78bfa', '#f472b6'];
    for (let i = 0; i < 60; i++) {
      const el = document.createElement('div');
      el.style.cssText = `
        position: absolute;
        width: ${Math.random() * 10 + 6}px;
        height: ${Math.random() * 10 + 6}px;
        background: ${colors[Math.floor(Math.random() * colors.length)]};
        left: ${Math.random() * 100}%;
        top: -20px;
        border-radius: ${Math.random() > 0.5 ? '50%' : '2px'};
        opacity: ${Math.random() * 0.8 + 0.2};
        animation: fall ${Math.random() * 2 + 1.5}s linear ${Math.random() * 2}s forwards;
      `;
      container.appendChild(el);
    }
    const style = document.createElement('style');
    style.textContent = `
      @keyframes fall {
        to { transform: translateY(110vh) rotate(720deg); opacity: 0; }
      }
    `;
    document.head.appendChild(style);
    setTimeout(() => container.remove(), 5000);
  })();
</script>

<%- include('partials/footer') %>
