          <tbody>
            <tr><td>🟡 Minimum</td><td>5 Mbps</td><td>720p</td><td>30fps</td></tr>
            <tr><td>🟢 Standar</td><td>10 Mbps</td><td>1080p</td><td>60fps</td></tr>
            <tr><td>🔵 HD</td><td>15 Mbps</td><td>1440p</td><td>60fps</td></tr>
            <tr class="highlight-row"><td>⭐ Ultra 4K</td><td>25 Mbps</td><td>4K</td><td>60fps</td></tr>
