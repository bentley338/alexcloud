.faq-hidden { display: none !important; }
</style>

<script>
function toggleFAQ(btn) {
  const item = btn.closest('.faq-item');
  const isOpen = item.classList.contains('open');
  // Close all
  document.querySelectorAll('.faq-item.open').forEach(el => el.classList.remove('open'));
  if (!isOpen) item.classList.add('open');
}

function filterTab(cat) {
  // Update active tab
  document.querySelectorAll('.faq-tab').forEach(t => t.classList.remove('active'));
  event.currentTarget.classList.add('active');

  document.getElementById('faqSearch').value = '';

  document.querySelectorAll('.faq-item, .faq-section-title').forEach(el => {
    if (cat === 'all') {
      el.classList.remove('faq-hidden');
    } else {
      el.classList.toggle('faq-hidden', el.dataset.cat !== cat);
    }
  });
  checkEmpty();
}

function filterFAQ(q) {
  q = q.toLowerCase().trim();
  // Reset tabs
  document.querySelectorAll('.faq-tab').forEach(t => t.classList.remove('active'));
  document.querySelector('.faq-tab').classList.add('active');

  if (!q) {
    document.querySelectorAll('.faq-item, .faq-section-title').forEach(el => el.classList.remove('faq-hidden'));
    checkEmpty();
    return;
  }
  document.querySelectorAll('.faq-item').forEach(item => {
    const text = (item.querySelector('.faq-question span').textContent + ' ' + (item.dataset.keywords || '') + ' ' + item.textContent).toLowerCase();
    item.classList.toggle('faq-hidden', !text.includes(q));
  });
  // Hide section titles
  document.querySelectorAll('.faq-section-title').forEach(t => t.classList.add('faq-hidden'));
  checkEmpty();
}

function checkEmpty() {
  const visible = document.querySelectorAll('.faq-item:not(.faq-hidden)').length;
  document.getElementById('faqEmpty').style.display = visible === 0 ? 'block' : 'none';
}
</script>

