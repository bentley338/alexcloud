<% currentPage = 'referrals'; %>
<%- include('layout-header') %>

<h1 class="admin-page-title"><i class="fas fa-user-plus"></i> Kelola Referral / Affiliate</h1>

<% if (typeof success !== 'undefined' && success && success.length > 0) { %>
<% success.forEach(s => { %><div class="alert alert-success" style="margin-bottom:1rem;"><i class="fas fa-check-circle"></i> <%= s %></div><% }) %>
<% } %>
<% if (typeof error !== 'undefined' && error && error.length > 0) { %>
<% error.forEach(e => { %><div class="alert alert-error" style="margin-bottom:1rem;"><i class="fas fa-exclamation-circle"></i> <%= e %></div><% }) %>
<% } %>

<!-- Stats -->
<div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(150px, 1fr)); gap:1rem; margin-bottom:2rem;">
  <div class="card" style="padding:1.2rem;">
    <div style="color:var(--text-muted); font-size:0.8rem; font-family:var(--font-ui);">Total Diajak</div>
    <div style="font-size:1.8rem; font-weight:700; color:var(--accent-blue); font-family:var(--font-display);"><%= stats.total %></div>
  </div>
  <div class="card" style="padding:1.2rem;">
    <div style="color:var(--text-muted); font-size:0.8rem; font-family:var(--font-ui);">Menunggu Bayar</div>
    <div style="font-size:1.8rem; font-weight:700; color:#ffb020; font-family:var(--font-display);"><%= stats.pending %></div>
  </div>
  <div class="card" style="padding:1.2rem;">
    <div style="color:var(--text-muted); font-size:0.8rem; font-family:var(--font-ui);">Reward Cair</div>
    <div style="font-size:1.8rem; font-weight:700; color:var(--accent-green); font-family:var(--font-display);"><%= stats.rewarded %></div>
  </div>
  <div class="card" style="padding:1.2rem;">
    <div style="color:var(--text-muted); font-size:0.8rem; font-family:var(--font-ui);">Diblokir (Abuse)</div>
    <div style="font-size:1.8rem; font-weight:700; color:#ff4444; font-family:var(--font-display);"><%= stats.blocked %></div>
  </div>
</div>

<!-- Settings -->
<div class="card" style="margin-bottom:2rem;">
  <div class="card-header">
    <div class="card-title"><i class="fas fa-sliders-h"></i> Setelan Program Referral</div>
  </div>
  <div style="padding:1.5rem; border-top:1px solid var(--border);">
    <form action="/admin/referrals/settings" method="POST">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem; margin-bottom:1rem;">
        <div class="form-group" style="margin:0;">
          <label class="form-label">Diskon Welcome (Rp)</label>
          <input type="number" name="welcomeDiscount" class="form-input" value="<%= cfg.welcomeDiscount %>" min="0" step="1000" required>
          <small style="color:var(--text-muted); font-size:0.78rem;">Kupon single-use untuk teman yang baru daftar via link.</small>
        </div>
        <div class="form-group" style="margin:0;">
          <label class="form-label">Reward Pengajak (Rp)</label>
          <input type="number" name="referrerReward" class="form-input" value="<%= cfg.referrerReward %>" min="0" step="1000" required>
          <small style="color:var(--text-muted); font-size:0.78rem;">Kupon untuk pengajak, cair setelah teman bayar & order di-confirm.</small>
        </div>
      </div>
      <div class="form-group" style="margin-bottom:1rem;">
        <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer;">
          <input type="checkbox" name="enabled" <%= cfg.enabled ? 'checked' : '' %>>
          <span>Aktifkan program referral</span>
        </label>
        <small style="color:var(--text-muted); font-size:0.78rem;">Jika nonaktif, kode referral diabaikan & reward tidak diterbitkan.</small>
      </div>
      <button type="submit" class="btn-primary"><i class="fas fa-save"></i> Simpan Setelan</button>
    </form>
  </div>
</div>

<!-- Referral List -->
<div class="card">
  <div class="card-header">
    <div class="card-title"><i class="fas fa-list"></i> Riwayat Referral (<%= referrals.length %>)</div>
  </div>
  <% if (referrals.length === 0) { %>
  <div style="padding:2rem; text-align:center; color:var(--text-muted);">
    <i class="fas fa-user-plus" style="font-size:2rem; opacity:0.3; margin-bottom:0.5rem; display:block;"></i>
    Belum ada aktivitas referral.
  </div>
  <% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Pengajak</th>
          <th>Teman Diajak</th>
          <th>Status</th>
          <th>Kupon Welcome</th>
          <th>Kupon Reward</th>
          <th>Tanggal</th>
        </tr>
      </thead>
      <tbody>
        <% referrals.forEach(r => { %>
        <tr>
          <td>
            <span style="font-weight:600;"><%= r.referrerName %></span>
            <% if (r.referrerCode) { %><br><small style="color:var(--accent-blue); font-family:var(--font-display); letter-spacing:1px;"><%= r.referrerCode %></small><% } %>
          </td>
          <td>
            <span style="font-weight:600;"><%= r.referredName || '-' %></span>
            <% if (r.signupIp) { %><br><small style="color:var(--text-muted); font-size:0.78rem;">IP: <%= r.signupIp %></small><% } %>
          </td>
          <td>
            <% if (r.status === 'rewarded') { %>
              <span class="status-badge status-active">🎁 Reward Cair</span>
            <% } else if (r.status === 'pending') { %>
              <span class="status-badge" style="background:rgba(255,176,32,0.12); color:#ffb020; border:1px solid rgba(255,176,32,0.3);">⏳ Menunggu Bayar</span>
            <% } else { %>
              <span class="status-badge status-rejected">🚫 Diblokir</span>
              <% if (r.reason) { %><br><small style="color:var(--text-muted); font-size:0.75rem;"><%= r.reason %></small><% } %>
            <% } %>
          </td>
          <td>
            <% if (r.welcomeCode) { %>
              <span style="font-family:var(--font-display); color:var(--accent-green); letter-spacing:1px;"><%= r.welcomeCode %></span>
            <% } else { %>
              <span style="color:var(--text-muted);">—</span>
            <% } %>
          </td>
          <td>
            <% if (r.rewardCode) { %>
              <span style="font-family:var(--font-display); color:var(--accent-green); letter-spacing:1px;"><%= r.rewardCode %></span>
            <% } else { %>
              <span style="color:var(--text-muted);">—</span>
            <% } %>
          </td>
          <td style="font-size:0.82rem; color:var(--text-muted);">
            <%= moment(r.createdAt).format('DD/MM/YY HH:mm') %>
            <% if (r.rewardedAt) { %><br><small style="color:var(--accent-green);">cair <%= moment(r.rewardedAt).format('DD/MM/YY') %></small><% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<%- include('layout-footer') %>
