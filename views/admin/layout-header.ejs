<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Admin - AlexCloud' %></title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=Rajdhani:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/fontawesome.min.css?v=1">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <nav class="navbar" id="navbar">
    <div class="nav-container">
      <a href="/" class="nav-logo">
        <svg class="logo-icon-svg" width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="filter: drop-shadow(0 0 8px rgba(232, 115, 42, 0.45)); flex-shrink:0;">
          <defs>
            <linearGradient id="logoIconGradAdmin" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#e8732a" />
              <stop offset="100%" stop-color="#c0392b" />
            </linearGradient>
          </defs>
          <!-- Stylized Cloud outline -->
          <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z" fill="url(#logoIconGradAdmin)" opacity="0.12" />
          <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z" stroke="url(#logoIconGradAdmin)" stroke-width="1.5" stroke-linejoin="round" opacity="0.35" fill="none" />
          <!-- Sharp Central Lightning Bolt representing cloud speed -->
          <path d="M14 2L7 13H12L10 22L17 11H12L14 2Z" fill="url(#logoIconGradAdmin)" />
        </svg>
        <span class="logo-text">ALEX<span class="logo-accent">CLOUD</span></span>
      </a>
      <div style="margin-left:auto; display:flex; align-items:center; gap:1rem;">
        <span style="font-family:var(--font-ui); font-size:0.85rem; color:var(--accent-orange); background:rgba(255,107,53,0.1); border:1px solid rgba(255,107,53,0.3); padding:0.3rem 0.8rem; border-radius:50px;">
          ⚙ Admin Panel
        </span>
        <div class="nav-user-menu">
          <button class="nav-user-btn" onclick="toggleUserMenu()">
            <div class="nav-avatar-placeholder"><%= user.name.charAt(0).toUpperCase() %></div>
            <span><%= user.name.split(' ')[0] %></span>
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="user-dropdown" id="userDropdown">
            <a href="/dashboard"><i class="fas fa-chart-line"></i> Dashboard User</a>
            <a href="/profile"><i class="fas fa-user"></i> Profil</a>
            <hr>
            <a href="/logout" class="logout-link"><i class="fas fa-sign-out-alt"></i> Logout</a>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <div class="admin-layout">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="sidebar-section">
        <div class="sidebar-section-label">Overview</div>
        <a href="/admin" class="sidebar-link <%= currentPage === 'dashboard' ? 'active' : '' %>">
          <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-section-label">Management</div>
        <a href="/admin/orders" class="sidebar-link <%= currentPage === 'orders' ? 'active' : '' %>">
          <i class="fas fa-shopping-cart"></i> Kelola Order
        </a>
        <a href="/admin/subscriptions" class="sidebar-link <%= currentPage === 'subscriptions' ? 'active' : '' %>">
          <i class="fas fa-id-card"></i> Subscriptions
        </a>
        <a href="/admin/users" class="sidebar-link <%= currentPage === 'users' ? 'active' : '' %>">
          <i class="fas fa-users"></i> Kelola User
        </a>
        <a href="/admin/games" class="sidebar-link <%= currentPage === 'games' ? 'active' : '' %>">
          <i class="fas fa-gamepad"></i> Kelola Game
        </a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-section-label">Marketing</div>
        <a href="/admin/promo" class="sidebar-link <%= currentPage === 'promo' ? 'active' : '' %>">
          <i class="fas fa-tag"></i> Kode Promo
        </a>
        <a href="/admin/plans" class="sidebar-link <%= currentPage === 'plans' ? 'active' : '' %>">
          <i class="fas fa-dollar-sign"></i> Edit Harga Paket
        </a>
        <a href="/admin/testimonials" class="sidebar-link <%= currentPage === 'testimonials' ? 'active' : '' %>">
          <i class="fas fa-star"></i> Kelola Testimoni
        </a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-section-label">Community</div>
        <a href="/admin/community" class="sidebar-link <%= currentPage === 'community' ? 'active' : '' %>">
          <i class="fas fa-comments"></i> Moderasi Chat
        </a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-section-label">Site</div>
        <a href="/admin/settings/whatsapp" class="sidebar-link <%= currentPage === 'settings-whatsapp' ? 'active' : '' %>">
          <i class="fab fa-whatsapp"></i> Setelan WhatsApp
        </a>
        <a href="/" class="sidebar-link" target="_blank">
          <i class="fas fa-external-link-alt"></i> Lihat Website
        </a>
        <a href="/logout" class="sidebar-link" style="color:#ff6666;">
          <i class="fas fa-sign-out-alt"></i> Logout
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-content">
