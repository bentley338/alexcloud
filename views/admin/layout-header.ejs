    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="sidebar-section">
        <div class="sidebar-section-label">Overview</div>
        <a href="/admin" class="sidebar-link <%= currentPage === 'dashboard' ? 'active' : '' %>">
          <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-section-label">Management</div>
        <a href="/admin/orders" class="sidebar-link <%= currentPage === 'orders' ? 'active' : '' %>">
          <i class="fas fa-shopping-cart"></i> Kelola Order
        </a>
        <a href="/admin/wallet" class="sidebar-link <%= currentPage === 'wallet' ? 'active' : '' %>">
          <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: text-bottom; margin-right: 0.2rem;"><path d="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a8 8 0 0 1-5.3 7.7 2 2 0 0 1-2.7-1.4l-1-4.2a2 2 0 0 0-1.7-1.5L5 16a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h14"></path><path d="M21 11v4h-3a2 2 0 0 1 0-4h3z"></path></svg> Kelola Saldo
        </a>
        <a href="/admin/subscriptions" class="sidebar-link <%= currentPage === 'subscriptions' ? 'active' : '' %>">
          <i class="fas fa-id-card"></i> Subscriptions
        </a>
        <a href="/admin/users" class="sidebar-link <%= currentPage === 'users' ? 'active' : '' %>">
          <i class="fas fa-users"></i> Kelola User
        </a>
        <a href="/admin/royal" class="sidebar-link <%= currentPage === 'royal' ? 'active' : '' %>">
          <i class="fas fa-crown" style="color:#fbbf24;"></i> Royal Club
        </a>
        <a href="/admin/games" class="sidebar-link <%= currentPage === 'games' ? 'active' : '' %>">
          <i class="fas fa-gamepad"></i> Kelola Game
        </a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-section-label">Marketing</div>
        <a href="/admin/marketing" class="sidebar-link <%= currentPage === 'marketing' ? 'active' : '' %>">
          <i class="fas fa-bullhorn"></i> Marketing & Campaign
        </a>
        <a href="/admin/promo" class="sidebar-link <%= currentPage === 'promo' ? 'active' : '' %>">
          <i class="fas fa-tag"></i> Kode Promo
        </a>
        <a href="/admin/referrals" class="sidebar-link <%= currentPage === 'referrals' ? 'active' : '' %>">
          <i class="fas fa-user-plus"></i> Referral
        </a>
        <a href="/admin/plans" class="sidebar-link <%= currentPage === 'plans' ? 'active' : '' %>">
          <i class="fas fa-dollar-sign"></i> Edit Harga Paket
        </a>
        <a href="/admin/testimonials" class="sidebar-link <%= currentPage === 'testimonials' ? 'active' : '' %>">
          <i class="fas fa-star"></i> Kelola Testimoni
        </a>
        <a href="/admin/reviews" class="sidebar-link <%= currentPage === 'reviews' ? 'active' : '' %>">
          <i class="fas fa-pen-to-square"></i> Izinkan Ulasan
        </a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-section-label">Community</div>
        <a href="/admin/community" class="sidebar-link <%= currentPage === 'community' ? 'active' : '' %>">
          <i class="fas fa-comments"></i> Moderasi Chat
        </a>
      </div>
      <div class="sidebar-section">
        <div class="sidebar-section-label">Site</div>
        <a href="/admin/announcement" class="sidebar-link <%= currentPage === 'announcement' ? 'active' : '' %>">
          <i class="fas fa-bullhorn"></i> Pengumuman
        </a>
