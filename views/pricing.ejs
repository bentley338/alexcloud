<%- include('partials/header') %>

<style>
  /* Balanced, spacious pricing card overrides */
  .pricing-grid {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)) !important;
    gap: 1.25rem !important;
  }
  .plan-card {
    padding: 2.25rem 1.75rem !important;
    border-radius: var(--radius-lg) !important;
  }
  .plan-name {
    font-size: 1.15rem !important;
    margin-bottom: 0.5rem !important;
    margin-top: 0.5rem !important;
  }
  .plan-price {
    font-size: 2.5rem !important;
  }
  .plan-price.popular-price {
    font-size: 2.7rem !important;
  }
  .plan-period {
    font-size: 0.9rem !important;
    margin-bottom: 1.25rem !important;
  }
  .plan-features {
    gap: 0.65rem !important;
    margin-bottom: 1.5rem !important;
  }
  .plan-features li {
    font-size: 0.92rem !important;
    line-height: 1.4 !important;
  }
  .plan-features li i {
    font-size: 0.85rem !important;
  }
  .plan-btn {
    padding: 0.85rem 1.25rem !important;
    font-size: 0.95rem !important;
  }
</style>

<div class="page-wrap">
  <div style="padding: 4rem 0 3rem; background: linear-gradient(180deg, rgba(255, 255, 255,0.04) 0%, transparent 100%);">
    <div class="container text-center">
      <div class="section-tag" style="margin-bottom:1rem;">Harga</div>
      <h1 class="section-title">Paket <span class="accent">Terjangkau</span></h1>
      <p class="section-desc">Pilih paket yang sesuai kebutuhanmu. Semakin lama, semakin hemat!</p>
    </div>
  </div>

  <section class="pricing-section" style="padding-top: 2rem;">
    <div class="pricing-container">
      <div class="pricing-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; align-items: stretch;">
        <% plans.forEach(plan => { %>
          <% if (plan.id === 'royal_access') { %>
            <!-- VIP Royal Access Pass Card -->
            <div class="plan-card royal-card" style="background: linear-gradient(135deg, rgba(251, 191, 36, 0.15) 0%, rgba(217, 119, 6, 0.05) 100%); border: 2px solid #fbbf24; box-shadow: 0 0 25px rgba(251, 191, 36, 0.15); position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: space-between; height: 100%;">
              <div>
                <div class="popular-badge" style="background: linear-gradient(90deg, #fbbf24, #d97706); color: #111; font-weight: 800; font-size: 0.75rem; letter-spacing: 0.05em; box-shadow: 0 4px 10px rgba(251, 191, 36, 0.3);">👑 VIP CLUB UPGRADE</div>
                <div style="position: absolute; top: -50px; right: -50px; width: 150px; height: 150px; background: radial-gradient(circle, rgba(251, 191, 36, 0.3) 0%, transparent 70%); pointer-events: none;"></div>
                
                <div class="plan-name" style="color: #fbbf24; font-weight: 800; font-size: 1.5rem;"><%= plan.name %></div>
                <div class="plan-price" style="color: #fff; font-size: 2.2rem; text-shadow: 0 0 15px rgba(251,191,36,0.2);"><%= plan.priceDisplay %></div>
                <div class="plan-period" style="color: #fbbf24; font-weight: 600;">Lifetime / Sekali Bayar</div>
                
                <ul class="plan-features" style="text-align: left; margin-bottom: 1.5rem;">
                  <li><i class="fas fa-unlock" style="color:#fbbf24;"></i> <strong>Buka Sewa Harian (Rp 7.000)</strong></li>
                  <li><i class="fas fa-server" style="color:#fbbf24;"></i> Server Premium Latensi Terendah</li>
                  <li><i class="fas fa-crown" style="color:#fbbf24;"></i> Badge Mahkota Emas Profil 👑</li>
                  <li><i class="fas fa-coins" style="color:#fbbf24;"></i> Bonus Klaim Harian Saldo +Rp 500</li>
                  <li><i class="fas fa-star" style="color:#fbbf24;"></i> Akses Game Early Release &amp; Beta</li>
                  <li><i class="fas fa-hdd" style="color:#fbbf24;"></i> Cloud Save Storage Lebih Besar</li>
                  <li><i class="fas fa-video" style="color:#fbbf24;"></i> Bitrate Streaming Maksimal 100 Mbps</li>
                  <li><i class="fas fa-gamepad" style="color:#fbbf24;"></i> Prioritas Request Game Baru</li>
                  <li><i class="fas fa-user-shield" style="color:#fbbf24;"></i> CS VIP Fast-response 24/7</li>
                  <li><i class="fas fa-percentage" style="color:#fbbf24;"></i> Cashback Top-up Saldo +5%</li>
                  <li><i class="fas fa-sliders-h" style="color:#fbbf24;"></i> Layout Kontroler Virtual Kustom</li>
                </ul>
              </div>
              <% if (typeof user !== 'undefined' && user) { %>
                <% if (user.isRoyal) { %>
                  <div class="plan-btn" style="background: linear-gradient(90deg, #10b981, #059669); color: white; cursor: default; border: none; font-weight: 700; display: flex; align-items: center; justify-content: center; gap: 0.4rem; padding: 0.85rem 1.5rem; border-radius: var(--radius-md);">
                    <i class="fas fa-check-circle"></i> Sudah Aktif
                  </div>
                <% } else { %>
                  <a href="/order/<%= plan.id %>?ref_=pricing_buy_royal" class="plan-btn filled" style="background: linear-gradient(90deg, #fbbf24, #d97706); color: #111; border: none; font-weight: 800; box-shadow: 0 4px 15px rgba(251,191,36,0.3);">
                    <i class="fas fa-crown"></i> Beli Royal Access
                  </a>
                <% } %>
              <% } else { %>
                <a href="/login?ref_=pricing_login_royal" class="plan-btn filled" style="background: linear-gradient(90deg, #fbbf24, #d97706); color: #111; border: none; font-weight: 800;">
                  Login untuk Order
                </a>
              <% } %>
            </div>
          <% } else if (plan.id === 'custom_royal') { %>
            <!-- Daily Royal Plan Card with Day Slider -->
            <div class="plan-card" style="<%= (typeof user !== 'undefined' && user && user.isRoyal) ? 'border: 1px solid var(--accent-blue);' : 'opacity: 0.85; position: relative;' %> display: flex; flex-direction: column; justify-content: space-between; height: 100%;">
              <div>
                <% if (typeof user === 'undefined' || !user || !user.isRoyal) { %>
                  <div style="position: absolute; top: 12px; left: 12px; display: inline-flex; align-items: center; gap: 0.35rem; background: rgba(239, 68, 68, 0.15); border: 1px solid rgba(239, 68, 68, 0.3); color: #ef4444; font-family: var(--font-ui); font-size: 0.75rem; font-weight: 700; padding: 0.25rem 0.6rem; border-radius: 100px; z-index: 2;">
                    <i class="fas fa-lock"></i> ROYAL ONLY
                  </div>
                <% } else { %>
                  <div style="position: absolute; top: 12px; left: 12px; display: inline-flex; align-items: center; gap: 0.35rem; background: rgba(251, 191, 36, 0.15); border: 1px solid rgba(251, 191, 36, 0.3); color: #fbbf24; font-family: var(--font-ui); font-size: 0.75rem; font-weight: 700; padding: 0.25rem 0.6rem; border-radius: 100px; z-index: 2;">
                    <i class="fas fa-unlock"></i> ROYAL UNLOCKED
                  </div>
                <% } %>
                
                <div class="plan-name" id="customDaysName">Sewa Harian (1 Hari)</div>
                <div class="plan-price" id="customDaysPrice">Rp 7.000</div>
                <div class="plan-period" id="customDaysPeriod">akses selama 1 hari</div>

                <!-- SLIDER SECTION -->
                <div style="margin: 1.5rem 0 1rem; text-align: left;">
                  <label for="daysSlider" style="display: block; font-family: var(--font-ui); font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.5rem; display: flex; justify-content: space-between;">
                    <span>Durasi Sewa:</span>
                    <strong style="color: var(--accent-blue);" id="sliderValueText">1 Hari</strong>
                  </label>
                  <input type="range" id="daysSlider" min="1" max="6" value="1" style="width: 100%; accent-color: var(--accent-blue); background: rgba(255,255,255,0.1); border-radius: var(--radius-sm); outline: none; cursor: pointer;">
                  <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem; font-family: var(--font-ui);">
                    <span>1 Hari</span>
                    <span>2H</span>
                    <span>3H</span>
                    <span>4H</span>
                    <span>5H</span>
                    <span>6 Hari</span>
                  </div>
                </div>
                
                <ul class="plan-features" style="margin-top: 0.5rem;">
                  <li><i class="fas fa-check"></i> Akses 100+ Game Premium Terpopuler</li>
                  <li><i class="fas fa-check"></i> Streaming 4K / Resolusi Ultra HD 60fps</li>
                  <li><i class="fas fa-check"></i> Cloud Save Progress (Simpan Otomatis)</li>
                  <li><i class="fas fa-check"></i> Multi-device (HP, Laptop, Smart TV, Web)</li>
                  <li><i class="fas fa-check"></i> Bebas Pilih Durasi Hari Kustom</li>
                  <li><i class="fas fa-check"></i> Tanpa Kontrak / Bebas Perpanjang</li>
                  <li><i class="fas fa-check"></i> Main Langsung Tanpa Download Game</li>
                  <li><i class="fas fa-check"></i> Support Kontroler Fisik &amp; Touch Layout</li>
                  <li><i class="fas fa-check"></i> Kualitas Audio Surround Terjernih</li>
                  <li><i class="fas fa-check"></i> Latensi Rendah Stabil Internet Standar</li>
                </ul>
              </div>
              <% if (typeof user !== 'undefined' && user) { %>
                <% if (user.isRoyal) { %>
                  <a href="/order/<%= plan.id %>?days=1" id="customDaysBtn" class="plan-btn filled">
                    <i class="fas fa-shopping-cart"></i> Pilih Paket Ini
                  </a>
                <% } else { %>
                  <a href="/order/royal_access?ref_=pricing_unlock_daily" class="plan-btn outline" style="border-color: #fbbf24; color: #fbbf24; font-weight: 700;">
                    <i class="fas fa-crown"></i> Unlock via Royal Club
                  </a>
                <% } %>
              <% } else { %>
                <a href="/login?ref_=pricing_login" class="plan-btn outline">
                  Login untuk Order
                </a>
              <% } %>
            </div>
          <% } else { %>
            <!-- Normal Plans -->
            <div class="plan-card <%= plan.popular ? 'popular' : '' %>" style="display: flex; flex-direction: column; justify-content: space-between; height: 100%;">
              <div>
                <% if (plan.popular) { %><div class="popular-badge">⭐ PALING POPULER</div><% } %>
                <div class="plan-name"><%= plan.name %></div>
                <div class="plan-price <%= plan.popular ? 'popular-price' : '' %>"><%= plan.priceDisplay %></div>
                <div class="plan-period">akses selama <%= plan.duration %> hari</div>
                <ul class="plan-features">
                  <li><i class="fas fa-check"></i> Akses 100+ Game Premium</li>
                  <li><i class="fas fa-check"></i> Streaming 4K / 60fps</li>
                  <li><i class="fas fa-check"></i> Cloud Save Progress</li>
                  <li><i class="fas fa-check"></i> Multi-device Support</li>
                  <li><i class="fas fa-check"></i> Support WhatsApp 24/7</li>
                  <% if (plan.duration >= 30) { %>
                  <li><i class="fas fa-check"></i> Akses Beta Game Baru</li>
                  <% } %>
                  <% if (plan.duration >= 60) { %>
                  <li><i class="fas fa-check"></i> 🔥 Bonus 5 Hari Gratis</li>
                  <li><i class="fas fa-check"></i> Custom Game Request</li>
                  <% } %>
                  <% if (plan.duration >= 90) { %>
                  <li><i class="fas fa-star" style="color:#fbbf24"></i> Akses Game Early Release</li>
                  <li><i class="fas fa-star" style="color:#fbbf24"></i> VIP Support Priority</li>
                  <% } %>
                </ul>
              </div>
              <% if (typeof user !== 'undefined' && user) { %>
                <a href="/order/<%= plan.id %>?ref_=pricing_buy" class="plan-btn <%= plan.popular ? 'filled' : 'outline' %>">
                  <i class="fas fa-shopping-cart"></i> Pilih Paket Ini
                </a>
              <% } else { %>
                <a href="/login?ref_=pricing_login" class="plan-btn <%= plan.popular ? 'filled' : 'outline' %>">
                  Login untuk Order
                </a>
              <% } %>
            </div>
          <% } %>
        <% }) %>
      </div>

      <!-- FAQ / Info -->
      <div style="margin-top:4rem; display:grid; grid-template-columns:repeat(auto-fit, minmax(280px,1fr)); gap:1.5rem;">
        <div style="background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1.75rem;">
          <div style="font-size:1.5rem; margin-bottom:0.75rem;">💳</div>
          <h4 style="font-family:var(--font-ui); margin-bottom:0.5rem;">Metode Pembayaran</h4>
          <p style="color:var(--text-muted); font-size:0.9rem;">QRIS (GoPay, OVO, DANA, ShopeePay, M-Banking, dan semua e-wallet yang mendukung QRIS)</p>
        </div>
        <div style="background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1.75rem;">
          <div style="font-size:1.5rem; margin-bottom:0.75rem;">⚡</div>
          <h4 style="font-family:var(--font-ui); margin-bottom:0.5rem;">Aktivasi Cepat</h4>
          <p style="color:var(--text-muted); font-size:0.9rem;">Akun diaktifkan dalam 1-15 menit setelah konfirmasi pembayaran via WhatsApp.</p>
        </div>
        <div style="background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1.75rem;">
          <div style="font-size:1.5rem; margin-bottom:0.75rem;">🔄</div>
          <h4 style="font-family:var(--font-ui); margin-bottom:0.5rem;">Perpanjangan Mudah</h4>
          <p style="color:var(--text-muted); font-size:0.9rem;">Perpanjang kapanpun lewat dashboard. Order baru otomatis menggantikan subscription lama.</p>
        </div>
        <div style="background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1.75rem;">
          <div style="font-size:1.5rem; margin-bottom:0.75rem;">🎮</div>
          <h4 style="font-family:var(--font-ui); margin-bottom:0.5rem;">Semua Game Termasuk</h4>
          <p style="color:var(--text-muted); font-size:0.9rem;">Satu paket untuk semua game. Tidak ada biaya tambahan per game!</p>
        </div>
      </div>

      <!-- CTA WhatsApp -->
      <div style="text-align:center; margin-top:3rem; padding:2.5rem; background:rgba(37,211,102,0.05); border:1px solid rgba(37,211,102,0.2); border-radius:var(--radius-lg);">
        <h3 style="font-family:var(--font-display); margin-bottom:0.5rem;">Ada Pertanyaan?</h3>
        <p style="color:var(--text-muted); margin-bottom:1.5rem;">Chat langsung dengan admin AlexCloud via WhatsApp</p>
        <a href="https://wa.me/62<%= process.env.WA_NUMBER ? process.env.WA_NUMBER.replace(/^0/,'') : '82328437656' %>" target="_blank" class="wa-btn" style="display:inline-flex; width:auto; padding:0.85rem 2rem;">
          <i class="fab fa-whatsapp" style="font-size:1.2rem;"></i> Chat Admin WhatsApp
        </a>
      </div>
    </div>
  </section>
</div>

<%- include('partials/footer') %>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const slider = document.getElementById('daysSlider');
    if (slider) {
      const nameEl = document.getElementById('customDaysName');
      const priceEl = document.getElementById('customDaysPrice');
      const periodEl = document.getElementById('customDaysPeriod');
      const valTextEl = document.getElementById('sliderValueText');
      const btnEl = document.getElementById('customDaysBtn');

      function updateCustomDays() {
        const days = parseInt(slider.value);
        const price = days * 7000;
        
        nameEl.innerText = `Sewa Harian (${days} Hari)`;
        priceEl.innerText = `Rp ${price.toLocaleString('id-ID')}`;
        periodEl.innerText = `akses selama ${days} hari`;
        valTextEl.innerText = `${days} Hari`;
        
        if (btnEl) {
          btnEl.href = `/order/custom_royal?days=${days}`;
        }
      }

      slider.addEventListener('input', updateCustomDays);
      updateCustomDays(); // run once initially
    }
  });
</script>
