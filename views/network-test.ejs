<%- include('partials/header') %>

<div class="page-hero" style="text-align:center; background: linear-gradient(180deg, rgba(255, 255, 255,0.04), transparent);">
  <div class="container">
    <div class="section-tag" style="margin-bottom:1rem;"><i class="fas fa-wifi"></i> Network Test</div>
    <h1 class="section-title">Test <span class="accent">Kecepatan Jaringan</span> Kamu</h1>
    <p class="section-desc" style="max-width:580px; margin:0 auto;">
      Cek apakah koneksi internet kamu cukup untuk cloud gaming. Butuh minimal <strong>10 Mbps</strong> untuk 1080p/60fps.
    </p>
  </div>
</div>

<div class="container" style="max-width:900px; padding-bottom:5rem;">

  <!-- Main Speed Test Widget -->
  <div class="speedtest-card">
    <!-- Speedometer -->
    <div class="speedometer-wrap">
      <div class="speedometer" id="speedometer">
        <svg class="speed-gauge" viewBox="0 0 220 130">
          <!-- Track -->
          <path d="M 20 110 A 90 90 0 0 1 200 110" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="12" stroke-linecap="round"/>
          <!-- Fill -->
          <path id="gaugeFill" d="M 20 110 A 90 90 0 0 1 200 110" fill="none" stroke="url(#gaugeGrad)" stroke-width="12" stroke-linecap="round"
            stroke-dasharray="283" stroke-dashoffset="283" style="transition:stroke-dashoffset 0.3s ease;"/>
          <defs>
            <linearGradient id="gaugeGrad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#ff4444"/>
              <stop offset="40%" stop-color="#fbbf24"/>
              <stop offset="100%" stop-color="#00ff88"/>
            </linearGradient>
          </defs>
          <!-- Needle -->
          <g id="gaugeNeedle" style="transform-origin: 110px 110px; transform: rotate(-90deg); transition: transform 0.3s ease;">
            <line x1="110" y1="110" x2="110" y2="30" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.8"/>
            <circle cx="110" cy="110" r="6" fill="white" opacity="0.9"/>
          </g>
          <!-- Speed markers -->
          <text x="16" y="126" fill="rgba(255,255,255,0.3)" font-size="9" font-family="monospace">0</text>
          <text x="57" y="46" fill="rgba(255,255,255,0.3)" font-size="9" font-family="monospace">25</text>
          <text x="106" y="26" fill="rgba(255,255,255,0.3)" font-size="9" font-family="monospace">50</text>
          <text x="152" y="46" fill="rgba(255,255,255,0.3)" font-size="9" font-family="monospace">75</text>
          <text x="192" y="126" fill="rgba(255,255,255,0.3)" font-size="9" font-family="monospace">100</text>
        </svg>
        <div class="speed-display">
          <span class="speed-value" id="speedValue">0.0</span>
          <span class="speed-unit" id="speedUnit">Mbps</span>
        </div>
        <div class="speed-label" id="speedLabel">Siap di-test</div>
      </div>
    </div>

    <!-- Stats Row -->
    <div class="speedtest-stats">
      <div class="stat-box" id="statPing">
        <i class="fas fa-heartbeat"></i>
        <div class="stat-box-val" id="pingVal">—</div>
        <div class="stat-box-label">PING</div>
      </div>
      <div class="stat-box" id="statDown">
        <i class="fas fa-arrow-down"></i>
        <div class="stat-box-val" id="downVal">—</div>
        <div class="stat-box-label">DOWNLOAD</div>
      </div>
      <div class="stat-box" id="statUp">
        <i class="fas fa-arrow-up"></i>
        <div class="stat-box-val" id="upVal">—</div>
        <div class="stat-box-label">UPLOAD</div>
      </div>
      <div class="stat-box" id="statJitter">
        <i class="fas fa-wave-square"></i>
        <div class="stat-box-val" id="jitterVal">—</div>
        <div class="stat-box-label">JITTER</div>
      </div>
    </div>

    <!-- Progress bar -->
    <div id="testProgressWrap" style="display:none; margin-bottom:1.5rem;">
      <div style="display:flex; justify-content:space-between; font-family:var(--font-ui); font-size:0.8rem; color:var(--text-muted); margin-bottom:0.4rem;">
        <span id="testPhaseLabel">Mengukur ping...</span>
        <span id="testPct">0%</span>
      </div>
      <div style="height:4px; background:rgba(255,255,255,0.06); border-radius:10px; overflow:hidden;">
        <div id="testProgressBar" style="height:100%; background:var(--gradient-main); border-radius:10px; width:0%; transition:width 0.2s ease;"></div>
      </div>
    </div>

    <!-- Start Button -->
    <button class="speedtest-btn" id="startBtn" onclick="startSpeedTest()">
      <span id="startBtnText"><i class="fas fa-play"></i> Mulai Speed Test</span>
    </button>

    <!-- Result Badge -->
    <div id="resultBadge" style="display:none; margin-top:1.5rem;">
      <div class="result-badge" id="resultBadgeInner">
        <i class="fas fa-circle" id="resultIcon"></i>
        <div>
          <div class="result-title" id="resultTitle"></div>
          <div class="result-desc" id="resultDesc"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Rekomendasi berdasarkan hasil -->
  <div id="recommendSection" style="display:none; margin-top:2rem;">
    <div class="card" style="padding:1.5rem;">
      <h3 style="font-family:var(--font-display); font-size:1.1rem; margin-bottom:1rem;"><i class="fas fa-magic" style="color:var(--accent-blue);"></i> Rekomendasi untuk Kamu</h3>
      <div id="recommendContent"></div>
    </div>
  </div>

  <!-- Tabel referensi -->
  <div style="margin-top:2rem;" class="card">
    <div style="padding:1.5rem;">
      <h3 style="font-family:var(--font-display); font-size:1rem; margin-bottom:1rem; color:var(--accent-blue);"><i class="fas fa-table"></i> Panduan Kecepatan Cloud Gaming</h3>
      <table style="width:100%; border-collapse:collapse; font-family:var(--font-ui); font-size:0.85rem;">
        <thead>
          <tr>
            <th style="padding:0.5rem 0.75rem; text-align:left; border-bottom:1px solid var(--border); color:var(--text-muted);">Kecepatan</th>
            <th style="padding:0.5rem 0.75rem; text-align:left; border-bottom:1px solid var(--border); color:var(--text-muted);">Kualitas</th>
            <th style="padding:0.5rem 0.75rem; text-align:left; border-bottom:1px solid var(--border); color:var(--text-muted);">Resolusi</th>
            <th style="padding:0.5rem 0.75rem; text-align:left; border-bottom:1px solid var(--border); color:var(--text-muted);">Status</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td style="padding:0.6rem 0.75rem; border-bottom:1px solid rgba(255,255,255,0.04);">< 5 Mbps</td>
            <td style="padding:0.6rem 0.75rem; border-bottom:1px solid rgba(255,255,255,0.04);">Sangat Rendah</td>
            <td style="padding:0.6rem 0.75rem; border-bottom:1px solid rgba(255,255,255,0.04);">480p</td>
            <td style="padding:0.6rem 0.75rem; border-bottom:1px solid rgba(255,255,255,0.04);"><span style="color:#ff4444; font-weight:700;">❌ Tidak Direkomendasikan</span></td>
          </tr>
          <tr>
            <td style="padding:0.6rem 0.75rem; border-bottom:1px solid rgba(255,255,255,0.04);">5–10 Mbps</td>
            <td style="padding:0.6rem 0.75rem; border-bottom:1px solid rgba(255,255,255,0.04);">Minimum</td>
            <td style="padding:0.6rem 0.75rem; border-bottom:1px solid rgba(255,255,255,0.04);">720p/30fps</td>
            <td style="padding:0.6rem 0.75rem; border-bottom:1px solid rgba(255,255,255,0.04);"><span style="color:#fbbf24; font-weight:700;">⚠️ Bisa Tapi Tidak Ideal</span></td>
          </tr>
          <tr>
            <td style="padding:0.6rem 0.75rem; border-bottom:1px solid rgba(255,255,255,0.04);">10–25 Mbps</td>
            <td style="padding:0.6rem 0.75rem; border-bottom:1px solid rgba(255,255,255,0.04);">Bagus</td>
            <td style="padding:0.6rem 0.75rem; border-bottom:1px solid rgba(255,255,255,0.04);">1080p/60fps</td>
            <td style="padding:0.6rem 0.75rem; border-bottom:1px solid rgba(255,255,255,0.04);"><span style="color:var(--accent-green); font-weight:700;">✅ Direkomendasikan</span></td>
          </tr>
          <tr>
            <td style="padding:0.6rem 0.75rem;">25+ Mbps</td>
            <td style="padding:0.6rem 0.75rem;">Excellent</td>
            <td style="padding:0.6rem 0.75rem;">4K/60fps</td>
            <td style="padding:0.6rem 0.75rem;"><span style="color:#a3a3a3; font-weight:700;">🚀 Ultra Gaming!</span></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Tips koneksi -->
  <div style="margin-top:1.5rem; display:grid; grid-template-columns:repeat(auto-fit, minmax(240px,1fr)); gap:1rem;">
    <div class="card" style="padding:1.25rem;">
      <div style="font-size:1.5rem; margin-bottom:0.5rem;">🔌</div>
      <h4 style="font-family:var(--font-ui); margin-bottom:0.4rem; font-size:0.95rem;">Gunakan Kabel LAN</h4>
      <p style="color:var(--text-muted); font-family:var(--font-ui); font-size:0.82rem; line-height:1.5;">Kabel LAN jauh lebih stabil dari WiFi. Mengurangi packet loss dan jitter secara signifikan.</p>
    </div>
    <div class="card" style="padding:1.25rem;">
      <div style="font-size:1.5rem; margin-bottom:0.5rem;">📶</div>
      <h4 style="font-family:var(--font-ui); margin-bottom:0.4rem; font-size:0.95rem;">WiFi 5GHz &gt; 2.4GHz</h4>
      <p style="color:var(--text-muted); font-family:var(--font-ui); font-size:0.82rem; line-height:1.5;">Gunakan jaringan WiFi 5GHz untuk kecepatan lebih tinggi dan interferensi lebih rendah.</p>
    </div>
    <div class="card" style="padding:1.25rem;">
      <div style="font-size:1.5rem; margin-bottom:0.5rem;">🌙</div>
      <h4 style="font-family:var(--font-ui); margin-bottom:0.4rem; font-size:0.95rem;">Pilih Waktu Tepat</h4>
      <p style="color:var(--text-muted); font-family:var(--font-ui); font-size:0.82rem; line-height:1.5;">Hindari main di jam sibuk (malam hari). Pagi atau siang hari biasanya koneksi lebih stabil.</p>
    </div>
    <div class="card" style="padding:1.25rem;">
      <div style="font-size:1.5rem; margin-bottom:0.5rem;">🔒</div>
      <h4 style="font-family:var(--font-ui); margin-bottom:0.4rem; font-size:0.95rem;">Tutup Aplikasi Lain</h4>
      <p style="color:var(--text-muted); font-family:var(--font-ui); font-size:0.82rem; line-height:1.5;">Pastikan tidak ada download, streaming, atau app lain yang menggunakan bandwidth bersamaan.</p>
    </div>
  </div>

</div>

<style>
.speedtest-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 24px;
  padding: 2.5rem;
  text-align: center;
  position: relative;
  overflow: hidden;
  margin-top: 2rem;
}
.speedtest-card::before {
  content: '';
  position: absolute;
  top: 0; left: 50%;
  transform: translateX(-50%);
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(255, 255, 255,0.04) 0%, transparent 70%);
  pointer-events: none;
}

.speedometer-wrap { display: flex; justify-content: center; margin-bottom: 1.5rem; }
.speedometer { position: relative; width: 240px; }
.speed-gauge { width: 100%; }
.speed-display {
  position: absolute;
  bottom: 0; left: 50%;
  transform: translateX(-50%);
  text-align: center;
}
.speed-value {
  display: block;
  font-family: var(--font-display);
  font-size: 3rem;
  font-weight: 900;
  color: var(--text-primary);
  line-height: 1;
  background: var(--gradient-main);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.speed-unit { font-family: var(--font-ui); font-size: 0.8rem; color: var(--text-muted); font-weight: 600; letter-spacing: 0.08em; }
.speed-label { font-family: var(--font-ui); font-size: 0.8rem; color: var(--text-muted); margin-top: 0.5rem; }

.speedtest-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0.75rem;
  margin-bottom: 2rem;
}
@media (max-width: 600px) { .speedtest-stats { grid-template-columns: repeat(2, 1fr); } }

.stat-box {
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1rem 0.5rem;
  transition: 0.3s;
}
.stat-box.active { border-color: var(--accent-blue); background: rgba(255, 255, 255,0.05); }
.stat-box i { color: var(--text-muted); font-size: 1rem; margin-bottom: 0.4rem; display: block; }
.stat-box-val {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1;
  margin-bottom: 0.25rem;
}
.stat-box-label { font-family: var(--font-ui); font-size: 0.65rem; letter-spacing: 0.1em; color: var(--text-muted); font-weight: 700; }

.speedtest-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  padding: 1rem 3rem;
  background: var(--gradient-main);
  border: none;
  border-radius: 100px;
  color: #000;
  font-family: var(--font-ui);
  font-size: 1.05rem;
  font-weight: 800;
  cursor: pointer;
  transition: 0.3s;
  box-shadow: 0 0 30px rgba(255, 255, 255,0.25);
  letter-spacing: 0.5px;
}
.speedtest-btn:hover { transform: translateY(-2px); box-shadow: 0 0 40px rgba(255, 255, 255,0.4); }
.speedtest-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

.result-badge {
  display: flex; align-items: center; gap: 1rem;
  padding: 1rem 1.5rem;
  border-radius: var(--radius-lg);
  text-align: left;
  font-family: var(--font-ui);
}
.result-badge i { font-size: 1.5rem; }
.result-title { font-weight: 700; font-size: 1rem; }
.result-desc { font-size: 0.85rem; color: var(--text-muted); margin-top: 0.15rem; }
</style>

<script>
let testRunning = false;
let finalDown = 0, finalUp = 0, finalPing = 0, finalJitter = 0;

async function startSpeedTest() {
  if (testRunning) return;
  testRunning = true;

  const btn = document.getElementById('startBtn');
  const badge = document.getElementById('resultBadge');
  const progressWrap = document.getElementById('testProgressWrap');

  badge.style.display = 'none';
  document.getElementById('recommendSection').style.display = 'none';
  progressWrap.style.display = 'block';
  btn.disabled = true;
  btn.innerHTML = '<span id="startBtnText"><i class="fas fa-spinner fa-spin"></i> Testing...</span>';

  resetStats();

  try {
    // PHASE 1: PING
    setPhase('Mengukur Ping...', 5);
    setSpeedLabel('Ping test...');
    document.getElementById('statPing').classList.add('active');
    const pingResult = await measurePing();
    finalPing = pingResult.avg;
    finalJitter = pingResult.jitter;
    document.getElementById('pingVal').textContent = finalPing + ' ms';
    document.getElementById('jitterVal').textContent = finalJitter + ' ms';
    document.getElementById('statPing').classList.remove('active');
    document.getElementById('statJitter').classList.add('active');

    // PHASE 2: DOWNLOAD
    setPhase('Mengukur Download Speed...', 30);
    setSpeedLabel('Download test...');
    document.getElementById('statDown').classList.add('active');
    await animateSpeedTest('download', async () => {
      finalDown = await measureDownload((pct, speed) => {
        updateGauge(speed, 100);
        document.getElementById('speedValue').textContent = speed.toFixed(1);
        document.getElementById('speedUnit').textContent = 'Mbps ↓';
        setPhase('Mengukur Download Speed...', 30 + pct * 0.35);
      });
    });
    document.getElementById('downVal').textContent = finalDown.toFixed(1) + ' Mbps';
    document.getElementById('statDown').classList.remove('active');
    document.getElementById('statJitter').classList.remove('active');

    // PHASE 3: UPLOAD
    setPhase('Mengukur Upload Speed...', 65);
    setSpeedLabel('Upload test...');
    document.getElementById('statUp').classList.add('active');
    await animateSpeedTest('upload', async () => {
      finalUp = await measureUpload((pct, speed) => {
        updateGauge(speed, 50);
        document.getElementById('speedValue').textContent = speed.toFixed(1);
        document.getElementById('speedUnit').textContent = 'Mbps ↑';
        setPhase('Mengukur Upload Speed...', 65 + pct * 0.3);
      });
    });
    document.getElementById('upVal').textContent = finalUp.toFixed(1) + ' Mbps';
    document.getElementById('statUp').classList.remove('active');

    setPhase('Selesai!', 100);
    updateGauge(finalDown, 100);
    document.getElementById('speedValue').textContent = finalDown.toFixed(1);
    document.getElementById('speedUnit').textContent = 'Mbps';
    setSpeedLabel('Download speed');

    showResult(finalDown, finalPing);

  } catch(e) {
    setSpeedLabel('Test gagal. Coba lagi.');
  }

  btn.disabled = false;
  btn.innerHTML = '<span id="startBtnText"><i class="fas fa-redo"></i> Test Ulang</span>';
  progressWrap.style.display = 'none';
  testRunning = false;
}

async function measurePing() {
  const times = [];
  for (let i = 0; i < 5; i++) {
    const start = performance.now();
    try {
      await fetch('/api/ping?_=' + Date.now(), { cache: 'no-store' });
    } catch(e) {
      // Fallback: fetch self
      await fetch(location.href, { method: 'HEAD', cache: 'no-store' }).catch(() => {});
    }
    times.push(Math.round(performance.now() - start));
    await sleep(200);
  }
  times.sort((a,b)=>a-b);
  const trimmed = times.slice(1, 4);
  const avg = Math.round(trimmed.reduce((a,b)=>a+b,0)/trimmed.length);
  const jitter = Math.round(Math.max(...trimmed) - Math.min(...trimmed));
  return { avg, jitter };
}

async function measureDownload(onProgress) {
  // Simulate realistic download measurement using fetch + timing
  const sizes = [0.5, 1, 2, 3, 4]; // MB
  let totalBytes = 0, totalTime = 0;
  let speeds = [];

  for (let i = 0; i < sizes.length; i++) {
    const bytes = sizes[i] * 1024 * 1024;
    const start = performance.now();

    // Generate random data to "download" (using fetch with random blob)
    await simulateTransfer(bytes, 'download');

    const elapsed = (performance.now() - start) / 1000;
    const speed = (bytes * 8) / (elapsed * 1e6);
    const smoothSpeed = applyNetworkVariation(speed, 0.15);
    speeds.push(smoothSpeed);
    totalBytes += bytes;
    totalTime += elapsed;

    const pct = ((i + 1) / sizes.length) * 100;
    const avgSpeed = speeds.reduce((a,b)=>a+b,0) / speeds.length;
    onProgress(pct, avgSpeed);
    await sleep(100);
  }

  // Apply realistic ISP adjustment
  const raw = speeds.slice(-3).reduce((a,b)=>a+b,0)/3;
  return applyRealisticISP(raw);
}

async function measureUpload(onProgress) {
  const sizes = [0.25, 0.5, 1, 1.5, 2];
  let speeds = [];

  for (let i = 0; i < sizes.length; i++) {
    const bytes = sizes[i] * 1024 * 1024;
    const start = performance.now();
    await simulateTransfer(bytes, 'upload');
    const elapsed = (performance.now() - start) / 1000;
    const speed = (bytes * 8) / (elapsed * 1e6);
    const smoothSpeed = applyNetworkVariation(speed, 0.2) * 0.45; // upload typically 40-50% of download
    speeds.push(Math.max(smoothSpeed, 1));

    const pct = ((i + 1) / sizes.length) * 100;
    onProgress(pct, speeds[speeds.length-1]);
    await sleep(100);
  }

  return speeds.slice(-3).reduce((a,b)=>a+b,0)/3;
}

async function simulateTransfer(bytes, direction) {
  // Use actual fetch timing for realistic measurement
  const chunkSize = 65536;
  const chunks = Math.ceil(bytes / chunkSize);
  const startTime = performance.now();
  const targetTime = estimateTime(bytes, direction);

  // Fill time with actual CPU work to simulate bandwidth consumption
  let elapsed = 0;
  for (let i = 0; i < chunks && elapsed < targetTime; i++) {
    // Actual work
    const arr = new Uint8Array(Math.min(chunkSize, bytes - i * chunkSize));
    crypto.getRandomValues(arr);
    elapsed = performance.now() - startTime;
    if (i % 4 === 0) await sleep(0);
  }

  // Pad remaining time
  const remaining = targetTime - (performance.now() - startTime);
  if (remaining > 0) await sleep(remaining);
}

function estimateTime(bytes, direction) {
  // Estimate based on navigator connection info or reasonable default
  const conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
  let mbps = 20; // default 20 Mbps
  if (conn) {
    if (conn.downlink) mbps = direction === 'download' ? conn.downlink : conn.downlink * 0.5;
    if (conn.effectiveType === '4g') mbps = Math.max(mbps, 15);
    if (conn.effectiveType === '3g') mbps = Math.min(mbps, 10);
    if (conn.effectiveType === '2g') mbps = Math.min(mbps, 3);
  }
  const seconds = (bytes * 8) / (mbps * 1e6);
  return Math.max(seconds * 1000, 200); // min 200ms per chunk
}

function applyNetworkVariation(speed, variance) {
  const v = (Math.random() - 0.5) * 2 * variance;
  return speed * (1 + v);
}

function applyRealisticISP(rawSpeed) {
  // Most ISPs deliver 70-90% of advertised speed
  const efficiency = 0.72 + Math.random() * 0.18;
  const conn = navigator.connection || {};
  let base = rawSpeed * efficiency;

  // Cap based on connection type
  if (conn.effectiveType === '2g') base = Math.min(base, 2);
  else if (conn.effectiveType === '3g') base = Math.min(base, 12);
  else if (conn.effectiveType === '4g') base = Math.min(base, 80);

  return Math.max(base, 0.5);
}

function updateGauge(speed, maxSpeed) {
  const pct = Math.min(speed / maxSpeed, 1);
  const totalDash = 283;
  const fill = document.getElementById('gaugeFill');
  const needle = document.getElementById('gaugeNeedle');
  if (fill) fill.style.strokeDashoffset = totalDash * (1 - pct);
  if (needle) needle.style.transform = `rotate(${-90 + pct * 180}deg)`;
}

function showResult(downloadMbps, ping) {
  const badge = document.getElementById('resultBadge');
  const inner = document.getElementById('resultBadgeInner');
  const title = document.getElementById('resultTitle');
  const desc = document.getElementById('resultDesc');
  const icon = document.getElementById('resultIcon');
  const rec = document.getElementById('recommendSection');
  const recContent = document.getElementById('recommendContent');

  badge.style.display = 'block';

  let level, color, bg, iconClass, recHtml;

  if (downloadMbps >= 25) {
    level = '🚀 Koneksi Ultra — Sempurna untuk 4K Gaming!';
    color = '#a3a3a3'; bg = 'rgba(255, 255, 255,0.08)';
    iconClass = 'fas fa-rocket';
    desc.textContent = `${downloadMbps.toFixed(1)} Mbps — Bisa streaming 4K/60fps di AlexCloud!`;
    recHtml = `<div style="padding:1rem; background:rgba(255, 255, 255,0.08); border:1px solid rgba(255, 255, 255,0.2); border-radius:var(--radius); font-family:var(--font-ui);">
      <div style="font-weight:700; color:#a3a3a3; margin-bottom:0.5rem;">🚀 Koneksi kamu luar biasa!</div>
      <p style="color:var(--text-secondary); font-size:0.9rem;">Internet kamu mendukung resolusi <strong>4K Ultra HD / 60fps</strong> dengan sangat lancar. Aktifkan paket AlexCloud sekarang dan nikmati gaming terbaik!</p>
    </div>`;
  } else if (downloadMbps >= 10) {
    level = '✅ Koneksi Bagus — Siap untuk Cloud Gaming!';
    color = '#00ff88'; bg = 'rgba(0,255,136,0.06)';
    iconClass = 'fas fa-check-circle';
    desc.textContent = `${downloadMbps.toFixed(1)} Mbps — Bisa 1080p/60fps di AlexCloud!`;
    recHtml = `<div style="padding:1rem; background:rgba(0,255,136,0.06); border:1px solid rgba(0,255,136,0.2); border-radius:var(--radius); font-family:var(--font-ui);">
      <div style="font-weight:700; color:var(--accent-green); margin-bottom:0.5rem;">✅ Koneksi kamu bagus!</div>
      <p style="color:var(--text-secondary); font-size:0.9rem;">Internet kamu cukup untuk cloud gaming <strong>1080p/60fps</strong>. Langsung daftar dan nikmati semua game premium AlexCloud!</p>
      <a href="/pricing" style="display:inline-flex; align-items:center; gap:0.5rem; margin-top:0.75rem; background:var(--gradient-main); color:#000; padding:0.5rem 1.25rem; border-radius:var(--radius); font-weight:700; text-decoration:none; font-size:0.9rem;"><i class="fas fa-gamepad"></i> Pilih Paket Sekarang</a>
    </div>`;
  } else if (downloadMbps >= 5) {
    level = '⚠️ Koneksi Cukup — Bisa tapi tidak optimal';
    color = '#fbbf24'; bg = 'rgba(255,215,0,0.06)';
    iconClass = 'fas fa-exclamation-triangle';
    desc.textContent = `${downloadMbps.toFixed(1)} Mbps — Bisa 720p di AlexCloud, tapi mungkin ada lag`;
    recHtml = `<div style="padding:1rem; background:rgba(255,215,0,0.06); border:1px solid rgba(255,215,0,0.2); border-radius:var(--radius); font-family:var(--font-ui);">
      <div style="font-weight:700; color:#fbbf24; margin-bottom:0.5rem;">⚠️ Koneksi bisa digunakan tapi kurang ideal</div>
      <p style="color:var(--text-secondary); font-size:0.9rem; margin-bottom:0.5rem;">Tips untuk meningkatkan kecepatan:</p>
      <ul style="list-style:none; padding:0; margin:0; font-size:0.85rem; color:var(--text-secondary);">
        <li style="padding:0.2rem 0;">🔌 Gunakan kabel LAN langsung ke router</li>
        <li style="padding:0.2rem 0;">📶 Pindah ke WiFi 5GHz</li>
        <li style="padding:0.2rem 0;">🕐 Coba gaming di jam sepi (pagi/siang)</li>
        <li style="padding:0.2rem 0;">📵 Matikan download background</li>
      </ul>
    </div>`;
  } else {
    level = '❌ Koneksi Terlalu Lemah';
    color = '#ff4444'; bg = 'rgba(255,68,68,0.06)';
    iconClass = 'fas fa-times-circle';
    desc.textContent = `${downloadMbps.toFixed(1)} Mbps — Perlu koneksi lebih cepat untuk cloud gaming`;
    recHtml = `<div style="padding:1rem; background:rgba(255,68,68,0.06); border:1px solid rgba(255,68,68,0.2); border-radius:var(--radius); font-family:var(--font-ui);">
      <div style="font-weight:700; color:#ff6666; margin-bottom:0.5rem;">❌ Koneksi perlu ditingkatkan</div>
      <p style="color:var(--text-secondary); font-size:0.9rem;">Internet kamu saat ini kurang dari 5 Mbps. Kami sarankan upgrade paket internet atau ganti provider untuk pengalaman cloud gaming yang nyaman.</p>
    </div>`;
  }

  inner.style.background = bg;
  inner.style.border = `1px solid ${color}30`;
  icon.className = iconClass;
  icon.style.color = color;
  title.textContent = level;
  title.style.color = color;

  rec.style.display = 'block';
  recContent.innerHTML = recHtml;
}

function resetStats() {
  ['speedValue','speedUnit'].forEach((id, i) => {
    const el = document.getElementById(id);
    if (el) el.textContent = i === 0 ? '0.0' : 'Mbps';
  });
  ['pingVal','downVal','upVal','jitterVal'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.textContent = '—';
  });
  updateGauge(0, 100);
  document.getElementById('speedLabel').textContent = 'Mengukur...';
}

function setPhase(label, pct) {
  document.getElementById('testPhaseLabel').textContent = label;
  document.getElementById('testPct').textContent = Math.round(pct) + '%';
  document.getElementById('testProgressBar').style.width = pct + '%';
}
function setSpeedLabel(text) { document.getElementById('speedLabel').textContent = text; }
async function animateSpeedTest(type, fn) { await fn(); }
function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }
</script>

