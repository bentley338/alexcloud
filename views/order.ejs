<%- include('partials/header') %>

<div style="min-height:100vh; padding:7rem 2rem 4rem;">
  <div style="max-width:640px; margin:0 auto;">
    <a href="/pricing" style="color:var(--text-muted); text-decoration:none; font-family:var(--font-ui); font-size:0.9rem; display:inline-block; margin-bottom:2rem;">
      <i class="fas fa-arrow-left"></i> Kembali
    </a>
    <h1 style="font-family:var(--font-display); font-size:2rem; margin-bottom:0.5rem;">
      Konfirmasi Order
    </h1>
    <p style="color:var(--text-muted); margin-bottom:2rem; font-family:var(--font-ui)">
      Kamu memesan paket <strong style="color:var(--accent-blue)"><%= plan.name %></strong>
    </p>

    <div style="background:var(--bg-card); border:1px solid var(--border-hover); border-radius:var(--radius-lg); padding:2rem; margin-bottom:1.5rem;">
      <div style="display:flex; justify-content:space-between; align-items:center; padding:0.75rem 0; border-bottom:1px solid var(--border);">
        <span style="color:var(--text-muted); font-family:var(--font-ui)">Paket</span>
        <span style="font-family:var(--font-ui); font-weight:700;"><%= plan.name %></span>
      </div>
      <div style="display:flex; justify-content:space-between; align-items:center; padding:0.75rem 0; border-bottom:1px solid var(--border);">
        <span style="color:var(--text-muted); font-family:var(--font-ui)">Durasi</span>
        <span style="font-family:var(--font-ui); font-weight:700;"><%= plan.duration %> Hari</span>
      </div>
      <div style="display:flex; justify-content:space-between; align-items:center; padding:0.75rem 0; border-bottom:1px solid var(--border);">
        <span style="color:var(--text-muted); font-family:var(--font-ui)">Akun</span>
        <span style="font-family:var(--font-ui); font-weight:700; font-size:0.9rem;"><%= user.email %></span>
      </div>
      <div id="priceRow" style="display:flex; justify-content:space-between; align-items:center; padding:1rem 0 0;">
        <span style="font-family:var(--font-ui); font-weight:700;">Total</span>
        <span id="totalDisplay" style="font-family:var(--font-display); font-size:1.5rem; font-weight:700; color:var(--accent-green);"><%= plan.priceDisplay %></span>
      </div>
      <div id="discountRow" style="display:none; margin-top:0.5rem;">
        <div style="display:flex; justify-content:space-between; font-size:0.85rem; color:var(--text-muted); font-family:var(--font-ui); margin-bottom:0.25rem;">
          <span>Harga Normal</span>
          <span style="text-decoration:line-through;" id="originalPriceDisplay"><%= plan.priceDisplay %></span>
        </div>
        <div style="display:flex; justify-content:space-between; font-size:0.9rem; color:var(--accent-green); font-family:var(--font-ui);">
          <span>Hemat (Promo 🎉)</span>
          <span id="discountDisplay">-Rp 0</span>
        </div>
      </div>
    </div>

    <!-- KODE PROMO (OPSIONAL) -->
    <div class="promo-input-card">
      <div class="promo-input-header">
        <i class="fas fa-tag"></i>
        <span>Punya Kode Promo? (Opsional)</span>
      </div>
      <div class="promo-input-wrap">
        <input type="text" id="promoInput" class="promo-text-input" placeholder="Masukkan kode promo..." maxlength="30" oninput="this.value = this.value.toUpperCase()">
        <button class="promo-apply-btn" onclick="applyPromo()">
          <i class="fas fa-check"></i> Pakai
        </button>
      </div>
      <div id="promoStatus" class="promo-status"></div>
    </div>

    <div style="background:rgba(232, 115, 42, 0.05); border:1px solid rgba(232, 115, 42, 0.15); border-radius:var(--radius); padding:1.25rem; margin-bottom:1.5rem; font-family:var(--font-ui); font-size:0.85rem; color:var(--text-secondary); line-height: 1.6;">
      <div style="color:white; font-weight:700; margin-bottom:0.5rem; display:flex; align-items:center; gap:0.4rem;">
        <i class="fas fa-info-circle" style="color:#e8732a;"></i>
        <span>Panduan Metode Pembayaran</span>
      </div>
      • Pilih <strong style="color:white;">QRIS Otomatis</strong> jika ingin membayar langsung & otomatis menggunakan aplikasi <strong style="color:white;">DANA, GoPay, OVO, ShopeePay, LinkAja, atau m-Banking</strong>. Cukup scan QR code yang muncul, bayar, dan akun langsung aktif instan.<br>
      • Pilih <strong style="color:white;">Manual</strong> jika ingin mentransfer secara manual ke nomor e-wallet admin lalu mengirim bukti transfer ke WhatsApp.
    </div>

    <form action="/order" method="POST" id="orderForm">
      <input type="hidden" name="planId" value="<%= plan.id %>">
      <input type="hidden" name="promoCode" id="hiddenPromoCode" value="">
      <input type="hidden" name="promoId" id="hiddenPromoId" value="">
      <input type="hidden" name="finalPrice" id="hiddenFinalPrice" value="<%= plan.price %>">

      <!-- METODE PEMBAYARAN -->
      <div style="margin-bottom: 2rem;">
        <h3 style="font-family: var(--font-display); font-size: 1.15rem; margin-bottom: 1rem; color: var(--text-primary);">Pilih Metode Pembayaran</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;">
          
          <!-- QRIS Otomatis -->
          <label class="payment-method-card active" id="labelQrisAuto" style="cursor: pointer;">
            <input type="radio" name="paymentMethod" value="auto" checked style="display: none;" onchange="selectPaymentMethod('auto')">
            <div class="payment-method-icon" style="color: #e8732a;"><i class="fas fa-bolt"></i></div>
            <div class="payment-method-title">QRIS Otomatis</div>
            <div class="payment-method-desc">DANA, GoPay, OVO, dll <span class="badge-fast">Instan</span></div>
          </label>
          
          <!-- DANA Manual -->
          <label class="payment-method-card" id="labelDana" style="cursor: pointer;">
            <input type="radio" name="paymentMethod" value="dana_manual" style="display: none;" onchange="selectPaymentMethod('dana_manual')">
            <div class="payment-method-icon" style="color: #108ee9;"><i class="fas fa-wallet"></i></div>
            <div class="payment-method-title">DANA (Manual)</div>
            <div class="payment-method-desc">Transfer DANA <span class="badge-manual">5-15 Mnt</span></div>
          </label>
          
          <!-- GoPay Manual -->
          <label class="payment-method-card" id="labelGopay" style="cursor: pointer;">
            <input type="radio" name="paymentMethod" value="gopay_manual" style="display: none;" onchange="selectPaymentMethod('gopay_manual')">
            <div class="payment-method-icon" style="color: #00a550;"><i class="fas fa-money-bill-wave"></i></div>
            <div class="payment-method-title">GoPay (Manual)</div>
            <div class="payment-method-desc">Transfer GoPay <span class="badge-manual">5-15 Mnt</span></div>
          </label>
          
          <!-- ShopeePay Manual -->
          <label class="payment-method-card" id="labelShopee" style="cursor: pointer;">
            <input type="radio" name="paymentMethod" value="shopeepay_manual" style="display: none;" onchange="selectPaymentMethod('shopeepay_manual')">
            <div class="payment-method-icon" style="color: #ee4d2d;"><i class="fas fa-mobile-alt"></i></div>
            <div class="payment-method-title">ShopeePay (Manual)</div>
            <div class="payment-method-desc">Transfer ShopeePay <span class="badge-manual">5-15 Mnt</span></div>
          </label>
          
        </div>
      </div>

      <button type="submit" class="btn-primary" style="width:100%; justify-content:center; padding:1rem; font-size:1.05rem;">
        <i class="fas fa-shopping-cart"></i> Buat Order & Lanjut Bayar
      </button>
    </form>
  </div>
</div>

<!-- Fullscreen Glassmorphism Loading Overlay -->
<div id="paymentLoadingOverlay" class="loading-overlay" style="display: none;">
  <div class="loading-content">
    <div class="loading-spinner-wrap">
      <div class="loading-spinner"></div>
      <div class="loading-spinner-inner"></div>
      <div class="loading-logo">⚡</div>
    </div>
    <h3 class="loading-title">Memproses Pesanan</h3>
    <p class="loading-subtitle">Sedang mendaftarkan QRIS otomatis Anda...</p>
    <div class="loading-progress-track">
      <div class="loading-progress-bar" id="loadingProgressBar"></div>
    </div>
    <p class="loading-tip">Mohon jangan menutup halaman ini atau menekan tombol kembali.</p>
  </div>
</div>

<style>
.payment-method-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.5rem;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}
.payment-method-card:hover {
  border-color: rgba(232, 115, 42, 0.4);
  background: rgba(232, 115, 42, 0.02);
}
.payment-method-card.active {
  border-color: #e8732a;
  background: rgba(232, 115, 42, 0.05);
  box-shadow: 0 0 15px rgba(232, 115, 42, 0.1);
}
.payment-method-icon {
  font-size: 1.5rem;
  color: var(--text-muted);
  transition: color 0.2s ease;
}
.payment-method-card.active .payment-method-icon {
  color: #e8732a;
}
.payment-method-title {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.95rem;
  color: var(--text-primary);
}
.payment-method-desc {
  font-family: var(--font-ui);
  font-size: 0.78rem;
  color: var(--text-muted);
}
.badge-fast {
  background: rgba(0, 212, 255, 0.15);
  color: var(--accent-blue);
  padding: 0.1rem 0.4rem;
  border-radius: 4px;
  font-weight: 700;
}
.badge-manual {
  background: rgba(255, 170, 0, 0.15);
  color: #ffaa00;
  padding: 0.1rem 0.4rem;
  border-radius: 4px;
  font-weight: 700;
}
.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(3, 7, 18, 0.9);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  z-index: 999999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}
.loading-overlay.active {
  opacity: 1;
}
.loading-content {
  text-align: center;
  max-width: 380px;
  width: 90%;
  padding: 2rem;
}
.loading-spinner-wrap {
  position: relative;
  width: 90px;
  height: 90px;
  margin: 0 auto 1.5rem;
}
.loading-spinner {
  position: absolute;
  inset: 0;
  border: 3px solid rgba(232, 115, 42, 0.1);
  border-top-color: #e8732a;
  border-radius: 50%;
  animation: spinnerRotate 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite;
}
.loading-spinner-inner {
  position: absolute;
  inset: 12px;
  border: 3px solid rgba(0, 212, 255, 0.05);
  border-bottom-color: var(--accent-blue);
  border-radius: 50%;
  animation: spinnerRotateReverse 1.5s cubic-bezier(0.5, 0, 0.5, 1) infinite;
}
.loading-logo {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.8rem;
  animation: logoPulse 1.5s ease-in-out infinite alternate;
}
.loading-title {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 800;
  color: white;
  margin-bottom: 0.5rem;
  letter-spacing: 0.5px;
}
.loading-subtitle {
  font-family: var(--font-ui);
  font-size: 0.88rem;
  color: var(--text-muted);
  margin-bottom: 1.5rem;
}
.loading-progress-track {
  width: 100%;
  height: 4px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 10px;
  overflow: hidden;
  margin-bottom: 1rem;
}
.loading-progress-bar {
  width: 0%;
  height: 100%;
  background: linear-gradient(90deg, #e8732a, var(--accent-blue));
  border-radius: 10px;
  transition: width 0.4s ease;
}
.loading-tip {
  font-family: var(--font-ui);
  font-size: 0.78rem;
  color: rgba(255, 255, 255, 0.4);
  line-height: 1.5;
}

@keyframes spinnerRotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
@keyframes spinnerRotateReverse {
  0% { transform: rotate(360deg); }
  100% { transform: rotate(0deg); }
}
@keyframes logoPulse {
  0% { transform: scale(0.9); opacity: 0.8; }
  100% { transform: scale(1.1); opacity: 1; }
}
</style>

<script>
const planPrice = <%= plan.price %>;
const planId = '<%= plan.id %>';
let appliedPromoId = '';
let appliedPromoCode = '';

async function applyPromo() {
  const code = document.getElementById('promoInput').value.trim();
  const status = document.getElementById('promoStatus');
  if (!code) {
    status.innerHTML = '<span class="promo-error"><i class="fas fa-times-circle"></i> Masukkan kode promo terlebih dahulu.</span>';
    return;
  }
  status.innerHTML = '<span style="color:var(--text-muted)"><i class="fas fa-spinner fa-spin"></i> Memvalidasi...</span>';
  try {
    const resp = await fetch('/api/promo/validate', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ code, planId })
    });
    const data = await resp.json();
    if (data.valid) {
      status.innerHTML = `<span class="promo-success"><i class="fas fa-check-circle"></i> ${data.message}</span>`;
      document.getElementById('totalDisplay').textContent = data.finalPriceDisplay;
      document.getElementById('discountRow').style.display = 'block';
      document.getElementById('discountDisplay').textContent = '- Rp ' + data.discount.toLocaleString('id-ID');
      document.getElementById('hiddenPromoCode').value = code;
      document.getElementById('hiddenPromoId').value = data.promoId;
      document.getElementById('hiddenFinalPrice').value = data.finalPrice;
      appliedPromoId = data.promoId;
      appliedPromoCode = code;
    } else {
      status.innerHTML = `<span class="promo-error"><i class="fas fa-times-circle"></i> ${data.message}</span>`;
      resetPromo();
    }
  } catch(e) {
    status.innerHTML = '<span class="promo-error"><i class="fas fa-exclamation-triangle"></i> Terjadi kesalahan. Coba lagi.</span>';
  }
}

function resetPromo() {
  document.getElementById('totalDisplay').textContent = '<%= plan.priceDisplay %>';
  document.getElementById('discountRow').style.display = 'none';
  document.getElementById('hiddenPromoCode').value = '';
  document.getElementById('hiddenPromoId').value = '';
  document.getElementById('hiddenFinalPrice').value = planPrice;
  appliedPromoId = '';
  appliedPromoCode = '';
}

document.getElementById('promoInput').addEventListener('keypress', (e) => {
  if (e.key === 'Enter') applyPromo();
});

function selectPaymentMethod(method) {
  const cards = ['QrisAuto', 'Dana', 'Gopay', 'Shopee'];
  cards.forEach(c => {
    const el = document.getElementById('label' + c);
    if (el) el.classList.remove('active');
  });
  
  const loadingSub = document.querySelector('.loading-subtitle');
  
  if (method === 'auto') {
    document.getElementById('labelQrisAuto').classList.add('active');
    if (loadingSub) loadingSub.textContent = 'Sedang mendaftarkan QRIS otomatis Anda...';
  } else if (method === 'dana_manual') {
    document.getElementById('labelDana').classList.add('active');
    if (loadingSub) loadingSub.textContent = 'Sedang menyiapkan petunjuk transfer DANA...';
  } else if (method === 'gopay_manual') {
    document.getElementById('labelGopay').classList.add('active');
    if (loadingSub) loadingSub.textContent = 'Sedang menyiapkan petunjuk transfer GoPay...';
  } else if (method === 'shopeepay_manual') {
    document.getElementById('labelShopee').classList.add('active');
    if (loadingSub) loadingSub.textContent = 'Sedang menyiapkan petunjuk transfer ShopeePay...';
  }
}

// Form submit loading logic
document.getElementById('orderForm').addEventListener('submit', function(e) {
  const overlay = document.getElementById('paymentLoadingOverlay');
  overlay.style.display = 'flex';
  
  // Trigger CSS transition
  setTimeout(() => {
    overlay.classList.add('active');
  }, 10);
  
  // Animate progress bar dynamically up to 90%
  const progressBar = document.getElementById('loadingProgressBar');
  let progress = 0;
  const progressInterval = setInterval(() => {
    if (progress < 90) {
      progress += Math.floor(Math.random() * 8) + 2;
      if (progress > 90) progress = 90;
      progressBar.style.width = progress + '%';
    }
  }, 400);

  // Disable submit button and add loading spinner inside it
  const submitBtn = this.querySelector('button[type="submit"]');
  if (submitBtn) {
    submitBtn.disabled = true;
    submitBtn.style.opacity = '0.6';
    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Memproses...';
  }
});
</script>

<%- include('partials/footer') %>
