<%- include('partials/header') %>

<div class="page-wrap" id="main-content">
  <div style="padding: 4rem 0 3rem; background: linear-gradient(180deg, rgba(255, 255, 255,0.04) 0%, transparent 100%);">
    <div class="container">
      <div class="section-tag" style="margin-bottom:1rem;">Game Library</div>
      <h1 class="section-title"><span class="accent">Semua Game</span> Tersedia</h1>
      <p class="section-desc"><%= games.length %> game siap dimainkan di AlexCloud!</p>
    </div>
  </div>

  <div class="container py-5">
    <!-- Genre Filter -->
    <div style="display:flex; gap:0.75rem; flex-wrap:wrap; margin-bottom:2.5rem;">
      <a href="/games" class="btn-action <%= activeGenre === 'all' ? 'btn-confirm' : '' %>"
        style="padding:0.5rem 1rem; border-radius:50px; font-size:0.9rem; text-decoration:none; background:<%= activeGenre === 'all' ? 'rgba(255, 255, 255,0.15)' : 'rgba(255,255,255,0.05)' %>; color:<%= activeGenre === 'all' ? 'var(--accent-blue)' : 'var(--text-secondary)' %>; border:1px solid <%= activeGenre === 'all' ? 'rgba(255, 255, 255,0.3)' : 'var(--border)' %>">
        Semua (<%= (genres.length > 0 ? games.length : 0) + (activeGenre === 'all' ? games.length : 0) %>)
      </a>
      <% genres.forEach(genre => { %>
      <a href="/games?genre=<%= encodeURIComponent(genre) %>" class="btn-action"
        style="padding:0.5rem 1rem; border-radius:50px; font-size:0.9rem; text-decoration:none; background:<%= activeGenre === genre ? 'rgba(255, 255, 255,0.15)' : 'rgba(255,255,255,0.05)' %>; color:<%= activeGenre === genre ? 'var(--accent-blue)' : 'var(--text-secondary)' %>; border:1px solid <%= activeGenre === genre ? 'rgba(255, 255, 255,0.3)' : 'var(--border)' %>">
        <%= genre %>
      </a>
      <% }) %>
    </div>

    <div class="games-grid">
      <% 
        const getGradient = (name) => {
          const gradients = [
            'radial-gradient(circle at center, #1e293b 0%, #0f172a 100%)', // Slate
            'radial-gradient(circle at center, #0f172a 0%, #1e1b4b 100%)', // Dark Indigo
            'radial-gradient(circle at center, #180828 0%, #0a0b0d 100%)', // Dark Purple
            'radial-gradient(circle at center, #2e1065 0%, #0f172a 100%)', // Violet
            'radial-gradient(circle at center, #064e3b 0%, #022c22 100%)', // Emerald
            'radial-gradient(circle at center, #831843 0%, #0f172a 100%)', // Rose
            'radial-gradient(circle at center, #083344 0%, #0f172a 100%)'  // Teal/Dark
          ];
          let hash = 0;
          for (let i = 0; i < name.length; i++) {
            hash = name.charCodeAt(i) + ((hash << 5) - hash);
          }
          const index = Math.abs(hash) % gradients.length;
          return gradients[index];
        };
      %>
      <% games.forEach(game => { %>
      <% const isPlaceholder = !game.image || game.image.includes('placehold.co'); %>
      <div class="game-card">
        <div class="game-img-wrap">
          <% if (isPlaceholder) { %>
          <div class="game-img-fallback" style="display: flex; width: 100%; height: 100%; background: <%= getGradient(game.name) %>; flex-direction: column; align-items: center; justify-content: center; padding: 1.5rem; text-align: center; box-sizing: border-box; border-bottom: 1px solid rgba(255,255,255,0.05);">
            <i class="fas fa-gamepad" style="font-size: 2.2rem; color: var(--accent); opacity: 0.6; margin-bottom: 1rem;"></i>
            <div style="font-family: var(--font-display); font-size: 1.05rem; font-weight: 700; color: #fff; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; text-shadow: 0 2px 4px rgba(0,0,0,0.5);"><%= game.name %></div>
          </div>
          <% } else { %>
          <img src="<%= game.image %>" alt="<%= game.name %>" width="300" height="450" loading="lazy" decoding="async" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
          <div class="game-img-fallback" style="display: none; width: 100%; height: 100%; background: <%= getGradient(game.name) %>; flex-direction: column; align-items: center; justify-content: center; padding: 1.5rem; text-align: center; box-sizing: border-box; border-bottom: 1px solid rgba(255,255,255,0.05);">
            <i class="fas fa-gamepad" style="font-size: 2.2rem; color: var(--accent); opacity: 0.6; margin-bottom: 1rem;"></i>
            <div style="font-family: var(--font-display); font-size: 1.05rem; font-weight: 700; color: #fff; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; text-shadow: 0 2px 4px rgba(0,0,0,0.5);"><%= game.name %></div>
          </div>
          <% } %>
          <% if (game.tag) { %><span class="game-tag"><%= game.tag %></span><% } %>
        </div>
        <div class="game-body">
          <div class="game-title"><%= game.name %></div>
          <div class="game-genre"><i class="fas fa-tag" aria-hidden="true"></i> <%= game.genre %></div>
          <p class="game-desc"><%= game.description %></p>
        </div>
        <div class="game-footer">
          <div class="game-rating"><i class="fas fa-star"></i> <%= game.rating %></div>
          <span class="game-platform"><i class="fas fa-cloud"></i> Cloud</span>
        </div>
      </div>
      <% }) %>
    </div>

    <% if (games.length === 0) { %>
    <div style="text-align:center; padding:5rem; color:var(--text-muted);">
      <i class="fas fa-gamepad" style="font-size:3rem; margin-bottom:1rem;"></i>
      <p>Tidak ada game di kategori ini.</p>
      <a href="/games" class="btn-primary" style="margin-top:1rem; display:inline-flex;">Lihat Semua Game</a>
    </div>
    <% } %>

    <div style="text-align:center; margin-top:4rem; padding:3rem; background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-lg);">
      <h2 style="font-family:var(--font-display); margin-bottom:0.75rem; font-size:1.5rem;">Siap Main?</h2>
      <p style="color:var(--text-muted); margin-bottom:1.5rem;">Subscribe sekarang dan mainkan semua game ini!</p>
      <a href="<%= typeof user !== 'undefined' && user ? '/pricing' : '/register' %>" class="btn-primary">
        <i class="fas fa-gamepad"></i> <%= typeof user !== 'undefined' && user ? 'Pilih Paket' : 'Daftar Sekarang' %>
      </a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
