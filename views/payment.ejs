<% if (payState === 'select') { %>
<script>
const SEL_ORDER_ID = <%- JSON.stringify(order.orderId) %>;
let selectedMethod = null;

const cards = document.querySelectorAll('.method-card');
const createBtn = document.getElementById('createBtn');
const errBox = document.getElementById('createError');

function showPane(method) {
  document.querySelectorAll('.sub-pane').forEach(p => p.classList.remove('show'));
  const pane = document.getElementById('sub-' + method);
  if (pane) pane.classList.add('show');
}

cards.forEach(card => {
  card.addEventListener('click', () => {
    if (card.dataset.disabled) return;
    cards.forEach(c => c.classList.remove('active'));
    card.classList.add('active');
    selectedMethod = card.dataset.method;
    showPane(selectedMethod);
    errBox.style.display = 'none';
    createBtn.disabled = false;
    createBtn.innerHTML = '<i class="fas fa-arrow-right"></i> Lanjut Bayar';
  });
});

function gatherPayload() {
  const p = { method: selectedMethod };
  if (selectedMethod === 'va') p.bank_code = document.getElementById('vaBank').value;
  if (selectedMethod === 'emoney') {
    p.product_code = document.getElementById('ewProvider').value;
    p.phone = document.getElementById('ewPhone').value.trim();
  }
  if (selectedMethod === 'retail') p.retail_outlet = document.getElementById('retailOutlet').value;
  return p;
}

createBtn.addEventListener('click', async () => {
  if (!selectedMethod) return;
  const payload = gatherPayload();

  if (selectedMethod === 'emoney' && !/^0\d{8,14}$/.test(payload.phone || '')) {
    errBox.textContent = 'Masukkan nomor HP e-wallet yang valid (contoh: 081234567890).';
    errBox.style.display = 'block';
    return;
  }

  errBox.style.display = 'none';
  createBtn.disabled = true;
  createBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Membuat pembayaran...';

  try {
    const r = await fetch(`/api/payment/create/${SEL_ORDER_ID}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await r.json();
    if (r.ok && data.ok) {
      window.location.reload();
    } else {
      errBox.textContent = data.error || 'Gagal membuat pembayaran. Coba metode lain.';
      errBox.style.display = 'block';
      createBtn.disabled = false;
      createBtn.innerHTML = '<i class="fas fa-arrow-right"></i> Lanjut Bayar';
    }
  } catch (e) {
    errBox.textContent = 'Terjadi kesalahan jaringan. Coba lagi.';
    errBox.style.display = 'block';
    createBtn.disabled = false;
    createBtn.innerHTML = '<i class="fas fa-arrow-right"></i> Lanjut Bayar';
  }
});
</script>
<% } %>

<% if (payState === 'instrument') { %>
<!-- Self-hosted dulu (same-origin, paling andal); cdnjs hanya cadangan kalau gagal -->
<script src="/js/qrcode.min.js" onerror="(function(){var s=document.createElement('script');s.src='https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js';document.head.appendChild(s);})()"></script>
<script>
const ORDER_ID = <%- JSON.stringify(order.orderId) %>;
const METHOD = <%- JSON.stringify(methodType || 'qris') %>;
const QR_STRING = <%- JSON.stringify(order.fr3QrString || '') %>;
const EXPIRY = <%- order.fr3Expiry ? (typeof order.fr3Expiry === 'number' ? order.fr3Expiry : new Date(order.fr3Expiry).getTime()) : (Date.now() + 10 * 60 * 1000) %>;
const METHOD_LABELS = { qris: 'QRIS', va: 'Virtual Account', emoney: 'E-Wallet', retail: 'Retail' };

let pollInterval;
let timerInterval;
let cancelled = false;

// ── QRIS render (hanya untuk metode qris) ──
function qrServerFallback(target) {
  const img = document.createElement('img');
  img.width = 220; img.height = 220; img.alt = 'QRIS Payment Code';
  img.style.cssText = 'border-radius:8px;display:block;';
  img.src = 'https://api.qrserver.com/v1/create-qr-code/?size=220x220&ecc=M&data=' + encodeURIComponent(QR_STRING);
  img.onerror = function () {
    target.innerHTML = '<div style="color:#999;font-size:0.8rem;text-align:center;"><i class="fas fa-exclamation-circle"></i><br>QR gagal dimuat</div>';
  };
  target.innerHTML = '';
  target.appendChild(img);
}

function renderQR() {
  const target = document.getElementById('qrRender');
  if (!target || !QR_STRING) return;
  if (typeof QRCode !== 'undefined') {
    try {
      target.innerHTML = '';
      new QRCode(target, {
        text: QR_STRING,
        width: 220, height: 220,
        colorDark: '#000000',
        colorLight: '#ffffff',
        correctLevel: QRCode.CorrectLevel.M
      });
      return;
    } catch (e) { /* jatuh ke qrserver di bawah */ }
  }
  qrServerFallback(target);
}

// ── Tombol salin (VA / kode retail) ──
document.querySelectorAll('.copy-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    const val = btn.getAttribute('data-copy') || '';
    try { await navigator.clipboard.writeText(val); }
    catch (e) {
      const ta = document.createElement('textarea');
      ta.value = val; document.body.appendChild(ta); ta.select();
      try { document.execCommand('copy'); } catch (_) {}
      document.body.removeChild(ta);
    }
    const orig = btn.innerHTML;
    btn.classList.add('copied');
    btn.innerHTML = '<i class="fas fa-check"></i> Tersalin';
    setTimeout(() => { btn.classList.remove('copied'); btn.innerHTML = orig; }, 1800);
  });
});

// ── Countdown timer ──
function markExpired() {
  clearInterval(timerInterval);
  clearInterval(pollInterval);
  const t = document.getElementById('payTimer'); if (t) t.textContent = '00:00';
  const ov = document.getElementById('qrExpired'); if (ov) ov.style.display = 'flex';
  const dot = document.getElementById('statusDot'); if (dot) dot.className = 'pay-status-dot expired';
  const st = document.getElementById('statusText'); if (st) st.textContent = 'Pembayaran Kadaluarsa';
  const cb = document.getElementById('cancelBtn'); if (cb) cb.style.display = 'none';
}

function startTimer() {
  timerInterval = setInterval(() => {
    const remaining = EXPIRY - Date.now();
    if (remaining <= 0) { markExpired(); return; }
    const m = Math.floor(remaining / 60000);
    const s = Math.floor((remaining % 60000) / 1000);
    const t = document.getElementById('payTimer');
    if (t) t.textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  }, 1000);
}

// ── Poll payment status ──
function startPolling() { pollInterval = setInterval(checkStatus, 5000); }

async function checkStatus() {
  if (cancelled) return;
  try {
    const r = await fetch(`/api/payment/status/${ORDER_ID}`);
    const data = await r.json();
    const st = (data.fr3Status || '').toUpperCase();
    if (st === 'SUCCESS' || st === 'PAID' || st === 'SETTLED' || data.status === 'confirmed') {
      clearInterval(pollInterval);
      clearInterval(timerInterval);
      showSuccess();
    } else if (st === 'EXPIRED' || data.status === 'expired') {
      markExpired();
    }
  } catch(e) {
    console.warn('Status check failed:', e);
  }
}

function showSuccess() {
  document.getElementById('statusBar').style.background = 'rgba(0,255,136,0.06)';
  document.getElementById('statusBar').style.borderColor = 'rgba(0,255,136,0.15)';
  document.getElementById('statusDot').className = 'pay-status-dot success';
  document.getElementById('statusText').textContent = '✅ Pembayaran Dikonfirmasi!';
  const t = document.getElementById('payTimer'); if (t) t.style.display = 'none';
  const cb = document.getElementById('cancelBtn'); if (cb) cb.style.display = 'none';

  const waNumber = <%- JSON.stringify(waNumber || '82328437656') %>;
  const userName = <%- JSON.stringify(user.name || '') %>;
  const userEmail = <%- JSON.stringify(user.email || '') %>;
  const planName = <%- JSON.stringify(plan.name || '') %>;
  const orderId = ORDER_ID;
  const totalBayar = 'Rp ' + <%- JSON.stringify(order.fr3TotalTransfer.toLocaleString('id-ID')) %>;

  const waMsg = [
    '✅ *KONFIRMASI PEMBAYARAN*',
    '',
    `📋 Order ID: *${orderId}*`,
    `👤 Nama: ${userName}`,
    `📧 Email: ${userEmail}`,
    `📦 Paket: *${planName}*`,
    `💰 Total Bayar: ${totalBayar}`,
    `💳 Metode: ${METHOD_LABELS[METHOD] || 'QRIS'} (MustikaPay)`,
    '',
    '✅ Pembayaran sudah terkonfirmasi otomatis.',
    'Mohon segera kirimkan akun cloud gaming saya.',
    'Terima kasih! 🙏'
  ].join('\n');

  const waLink = `https://wa.me/62${waNumber.replace(/^0/, '')}?text=${encodeURIComponent(waMsg)}`;
  document.getElementById('waConfirmBtn').href = waLink;

  document.getElementById('successState').style.display = 'block';
  document.getElementById('successState').scrollIntoView({ behavior: 'smooth', block: 'center' });
}

function cancelPayment() { document.getElementById('cancelConfirmModal').style.display = 'flex'; }
function closeCancelModal() { document.getElementById('cancelConfirmModal').style.display = 'none'; }

async function confirmCancelPayment() {
  closeCancelModal();
  cancelled = true;
  clearInterval(pollInterval);
  clearInterval(timerInterval);
  const btn = document.getElementById('cancelBtn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Membatalkan...';
  try {
    const r = await fetch(`/api/payment/cancel/${ORDER_ID}`, { method: 'POST' });
    const data = await r.json();
    if (data.success) {
      window.location.href = '/dashboard';
    } else {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-times"></i> Batalkan Pembayaran';
      alert('Gagal membatalkan: ' + (data.error || 'Unknown error'));
    }
  } catch(e) {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-times"></i> Batalkan Pembayaran';
  }
}

// Start
if (METHOD === 'qris') {
  renderQR();
  if (typeof QRCode === 'undefined') setTimeout(renderQR, 700);
}
startTimer();
startPolling();
setTimeout(checkStatus, 2000);
</script>
<% } %>

<%- include('partials/footer') %>
