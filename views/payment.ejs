<%- include('partials/header') %>

<%
  // Lookup label bank/provider untuk tampilan instrumen.
  const vaBankName = (banks.find(b => b.code === order.mpBankCode) || {}).name || order.mpBankCode || 'Bank';
%>

<div class="payment-page">
  <div class="payment-container">

    <!-- Header -->
    <div class="pay-header">
      <a href="/dashboard" class="pay-back"><i class="fas fa-arrow-left"></i></a>
      <div class="pay-header-info">
        <div class="pay-header-title">Pembayaran</div>
        <div class="pay-header-sub">Order #<%= order.orderId %></div>
      </div>
      <div class="pay-logo">⚡</div>
    </div>

    <% if (payState === 'select') { %>
    <!-- ======= PILIH METODE PEMBAYARAN ======= -->
    <div class="pay-card">
      <div class="pay-status-bar">
        <div class="pay-status-dot pending"></div>
        <span>Pilih metode pembayaran</span>
      </div>

      <!-- Ringkasan singkat -->
      <div class="pay-summary">
        <div class="pay-sum-row">
          <span>Paket</span>
          <span><strong><%= plan.name %></strong></span>
        </div>
        <% if (discount > 0) { %>
        <div class="pay-sum-row" style="color:var(--accent-green);">
          <span>Diskon Promo</span>
          <span>- Rp <%= discount.toLocaleString('id-ID') %></span>
        </div>
        <% } %>
        <div class="pay-sum-row total-row">
          <span>Total Bayar</span>
          <span class="total-val"><%= priceDisplay %></span>
        </div>
      </div>

      <!-- Daftar metode -->
      <div class="method-list">
        <%
          const vaOk = order.price >= minAmount.va;
          const retailOk = order.price >= minAmount.retail && order.price <= maxAmount.retail;
        %>
        <button type="button" class="method-card" data-method="qris">
          <div class="method-ic"><i class="fas fa-qrcode"></i></div>
          <div class="method-body">
            <div class="method-name">QRIS</div>
            <div class="method-desc">GoPay, OVO, DANA, ShopeePay, m-Banking</div>
          </div>
          <i class="fas fa-chevron-right method-arrow"></i>
        </button>

        <button type="button" class="method-card<%= vaOk ? '' : ' disabled' %>" data-method="va" <%= vaOk ? '' : 'data-disabled="1"' %>>
          <div class="method-ic"><i class="fas fa-building-columns"></i></div>
          <div class="method-body">
            <div class="method-name">Virtual Account</div>
            <div class="method-desc"><%= vaOk ? 'BCA, BNI, BRI, Mandiri, Permata, dll' : ('Min. Rp' + minAmount.va.toLocaleString('id-ID')) %></div>
          </div>
          <i class="fas fa-chevron-right method-arrow"></i>
        </button>

        <button type="button" class="method-card" data-method="emoney">
          <div class="method-ic"><i class="fas fa-wallet"></i></div>
          <div class="method-body">
            <div class="method-name">E-Wallet</div>
            <div class="method-desc">DANA, ShopeePay, OVO, LinkAja</div>
          </div>
          <i class="fas fa-chevron-right method-arrow"></i>
        </button>

        <button type="button" class="method-card<%= retailOk ? '' : ' disabled' %>" data-method="retail" <%= retailOk ? '' : 'data-disabled="1"' %>>
          <div class="method-ic"><i class="fas fa-store"></i></div>
          <div class="method-body">
            <div class="method-name">Retail / Minimarket</div>
            <div class="method-desc"><%= retailOk ? 'Alfamart, Indomaret' : ('Rp' + minAmount.retail.toLocaleString('id-ID') + ' – Rp' + maxAmount.retail.toLocaleString('id-ID')) %></div>
          </div>
          <i class="fas fa-chevron-right method-arrow"></i>
        </button>
      </div>

      <!-- Sub-opsi per metode -->
      <div id="subPanes" style="padding:0 1.25rem;">
        <div class="sub-pane" id="sub-va">
          <label class="sub-label">Pilih Bank</label>
          <select id="vaBank" class="sub-select">
            <% banks.forEach(function(b){ %>
            <option value="<%= b.code %>"><%= b.name %></option>
            <% }); %>
          </select>
        </div>

        <div class="sub-pane" id="sub-emoney">
          <label class="sub-label">Provider E-Wallet</label>
          <select id="ewProvider" class="sub-select">
            <% ewallets.forEach(function(e){ %>
            <option value="<%= e.code %>"><%= e.name %></option>
            <% }); %>
          </select>
          <label class="sub-label" style="margin-top:0.75rem;">No. HP terdaftar di e-wallet</label>
          <input type="tel" id="ewPhone" class="sub-input" placeholder="081234567890" inputmode="numeric">
        </div>

        <div class="sub-pane" id="sub-retail">
          <label class="sub-label">Pilih Gerai</label>
          <select id="retailOutlet" class="sub-select">
            <option value="ALFAMART">Alfamart</option>
            <option value="INDOMARET">Indomaret</option>
          </select>
        </div>
      </div>

      <div id="createError" class="create-error" style="display:none;"></div>

      <div style="padding:0.5rem 1.25rem 1.25rem;">
        <button id="createBtn" class="btn-primary" style="width:100%; justify-content:center;" disabled>
          <i class="fas fa-lock"></i> Pilih metode dulu
        </button>
      </div>
    </div>

    <% } else if (payState === 'instrument') { %>
    <!-- ======= INSTRUMEN PEMBAYARAN ======= -->
    <div class="pay-card qris-card">

      <!-- Status bar -->
      <div class="pay-status-bar" id="statusBar">
        <div class="pay-status-dot pending" id="statusDot"></div>
        <span id="statusText">Menunggu pembayaran...</span>
        <span class="pay-timer" id="payTimer">--:--</span>
      </div>

      <% if (methodType === 'qris') { %>
      <!-- QRIS -->
      <div class="qr-section">
        <div class="qr-brand-row">
          <img src="/images/qris-logo.svg" alt="QRIS" style="height:28px;">
          <span style="font-family:var(--font-ui); font-size:0.75rem; color:var(--text-muted); border-left:1px solid var(--border); padding-left:0.75rem; margin-left:0.25rem;">Scan dengan semua e-wallet</span>
        </div>
        <div class="qr-box" id="qrBox">
          <% if (order.fr3QrString) { %>
          <div id="qrRender" style="width:220px;height:220px;display:flex;align-items:center;justify-content:center;background:#fff;border-radius:8px;"></div>
          <% } else { %>
          <div style="width:220px;height:220px;display:flex;align-items:center;justify-content:center;background:#f0f0f0;border-radius:8px;">
            <div style="color:#999;font-size:0.8rem;text-align:center;"><i class="fas fa-exclamation-circle"></i><br>QR tidak tersedia</div>
          </div>
          <% } %>
          <div class="qr-overlay" id="qrExpired" style="display:none;">
            <div class="qr-expired-inner">
              <i class="fas fa-clock" style="font-size:2rem; color:#ff6666; margin-bottom:0.5rem;"></i>
              <div style="font-weight:700; color:#ff6666;">QR Kadaluarsa</div>
              <div style="font-size:0.8rem; color:var(--text-muted); margin-top:0.25rem;">Buat ulang pembayaran</div>
            </div>
          </div>
        </div>
        <div style="font-family:var(--font-ui); font-size:0.8rem; color:var(--text-muted); margin-bottom:0.5rem;">Bayar sejumlah tepat:</div>
        <div class="pay-total-amount">
          Rp <%= order.fr3TotalTransfer.toLocaleString('id-ID') %>
          <% if (order.fr3UniqueCode > 0) { %><span class="unique-code-badge">+<%= order.fr3UniqueCode %> kode unik</span><% } %>
        </div>
        <% if (order.fr3UniqueCode > 0) { %>
        <div class="unique-code-note">
          <i class="fas fa-info-circle"></i>
          Bayar tepat <strong>Rp <%= order.fr3TotalTransfer.toLocaleString('id-ID') %></strong> (termasuk kode unik). Kode unik akan dikembalikan otomatis.
        </div>
        <% } %>
      </div>

      <% } else if (methodType === 'va') { %>
      <!-- VIRTUAL ACCOUNT -->
      <div class="instr-section">
        <div class="instr-head"><i class="fas fa-building-columns"></i> <%= vaBankName %> Virtual Account</div>
        <div class="copy-field">
          <div class="copy-label">Nomor Virtual Account</div>
          <div class="copy-row">
            <span class="copy-value" id="copyVa"><%= order.mpVaNumber %></span>
            <button class="copy-btn" data-copy="<%= order.mpVaNumber %>"><i class="fas fa-copy"></i> Salin</button>
          </div>
        </div>
        <% if (order.mpVaName) { %>
        <div class="instr-sub">a.n. <strong><%= order.mpVaName %></strong></div>
        <% } %>
        <div class="instr-amount">Total: Rp <%= order.fr3TotalTransfer.toLocaleString('id-ID') %></div>
        <ol class="instr-steps">
          <li>Buka m-banking / ATM, pilih menu <strong>Transfer → Virtual Account</strong>.</li>
          <li>Masukkan nomor VA di atas, pastikan nama & nominal sesuai.</li>
          <li>Selesaikan pembayaran. Status terkonfirmasi otomatis di halaman ini.</li>
        </ol>
      </div>

      <% } else if (methodType === 'emoney') { %>
      <!-- E-WALLET -->
      <div class="instr-section">
        <div class="instr-head"><i class="fas fa-wallet"></i> <%= order.mpEwalletProvider || 'E-Wallet' %></div>
        <div class="instr-amount" style="margin-top:0.25rem;">Total: Rp <%= order.fr3TotalTransfer.toLocaleString('id-ID') %></div>
        <% if (order.mpPaymentLink) { %>
        <a href="<%= order.mpPaymentLink %>" target="_blank" rel="noopener" class="btn-primary instr-open">
          <i class="fas fa-arrow-up-right-from-square"></i> Buka aplikasi <%= order.mpEwalletProvider || 'E-Wallet' %>
        </a>
        <% } %>
        <ol class="instr-steps">
          <li>Klik tombol di atas <% if (!order.mpPaymentLink) { %>atau <% } %>buka aplikasi <strong><%= order.mpEwalletProvider || 'e-wallet' %></strong> kamu.</li>
          <li>Cek notifikasi tagihan masuk, periksa nominalnya, lalu <strong>setujui pembayaran</strong>.</li>
          <li>Status akan terkonfirmasi otomatis di halaman ini.</li>
        </ol>
      </div>

      <% } else if (methodType === 'retail') { %>
      <!-- RETAIL -->
      <div class="instr-section">
        <div class="instr-head"><i class="fas fa-store"></i> <%= (order.mpRetailOutlet === 'INDOMARET') ? 'Indomaret' : 'Alfamart' %></div>
        <div class="copy-field">
          <div class="copy-label">Kode Pembayaran</div>
          <div class="copy-row">
            <span class="copy-value" id="copyCode"><%= order.mpPaymentCode %></span>
            <button class="copy-btn" data-copy="<%= order.mpPaymentCode %>"><i class="fas fa-copy"></i> Salin</button>
          </div>
        </div>
        <div class="instr-amount">Total: Rp <%= order.fr3TotalTransfer.toLocaleString('id-ID') %></div>
        <ol class="instr-steps">
          <li>Datang ke kasir <strong><%= (order.mpRetailOutlet === 'INDOMARET') ? 'Indomaret' : 'Alfamart' %></strong> terdekat.</li>
          <li>Sebutkan ingin bayar <strong>tagihan / kode pembayaran</strong>, lalu berikan kode di atas.</li>
          <li>Bayar tunai sesuai total. Status terkonfirmasi otomatis di halaman ini.</li>
        </ol>
      </div>
      <% } %>

      <!-- Order Summary -->
      <div class="pay-summary">
        <div class="pay-sum-row">
          <span>Paket</span>
          <span><strong><%= plan.name %></strong></span>
        </div>
        <div class="pay-sum-row">
          <span>Harga Paket</span>
          <span><%= priceDisplay %></span>
        </div>
        <% if (discount > 0) { %>
        <div class="pay-sum-row" style="color:var(--accent-green);">
          <span>Diskon Promo</span>
          <span>- Rp <%= discount.toLocaleString('id-ID') %></span>
        </div>
        <% } %>
        <% if (order.fr3UniqueCode > 0) { %>
        <div class="pay-sum-row" style="color:var(--accent-blue);">
          <span>Kode Unik</span>
          <span>+ Rp <%= order.fr3UniqueCode %></span>
        </div>
        <% } %>
        <div class="pay-sum-row total-row">
          <span>Total Bayar</span>
          <span class="total-val">Rp <%= order.fr3TotalTransfer.toLocaleString('id-ID') %></span>
        </div>
      </div>

      <!-- Manual confirmation helper if stuck -->
      <div class="pay-stuck-helper" style="margin: 1.5rem 0; text-align: center; border-top: 1px dashed var(--border); padding-top: 1.5rem;">
        <div style="font-family: var(--font-ui); font-size: 0.82rem; color: var(--text-muted); margin-bottom: 0.75rem;">
          Sudah bayar tapi status belum terkonfirmasi otomatis?
        </div>
        <a href="https://wa.me/62<%= waNumber.replace(/^0/, '') %>?text=<%= encodeURIComponent('Halo Admin AlexCloud! 👋\n\nSaya sudah membayar namun statusnya masih stuck.\n\n📋 Order ID: *' + order.orderId + '*\n👤 Nama: ' + user.name + '\n📧 Email: ' + user.email + '\n📦 Paket: *' + plan.name + '*\n💰 Total: Rp ' + order.fr3TotalTransfer.toLocaleString('id-ID') + '\n\nMohon bantuannya untuk mengaktifkan akun saya. Terima kasih!') %>" target="_blank" class="wa-confirm-btn" style="margin: 0 auto; max-width: 320px; display: flex;">
          <i class="fab fa-whatsapp"></i> Konfirmasi Manual via WA
        </a>
      </div>

      <!-- Ganti metode -->
      <form action="/payment/<%= order.orderId %>/reset" method="POST" style="margin:0 1.25rem 0.25rem;">
        <button type="submit" class="btn-secondary" style="width:100%; justify-content:center;">
          <i class="fas fa-rotate-left"></i> Ganti metode pembayaran
        </button>
      </form>

      <!-- Cancel -->
      <button class="cancel-btn" id="cancelBtn" onclick="cancelPayment()">
        <i class="fas fa-times"></i> Batalkan Pembayaran
      </button>

      <!-- Cancel Confirmation Modal -->
      <div id="cancelConfirmModal" class="custom-modal" style="display: none;">
        <div class="modal-backdrop" onclick="closeCancelModal()"></div>
        <div class="modal-card">
          <div class="modal-glow"></div>
          <div class="modal-icon-wrap"><i class="fas fa-exclamation-triangle"></i></div>
          <h3 class="modal-title">Batalkan Pesanan?</h3>
          <p class="modal-desc">
            Apakah Anda yakin ingin membatalkan pesanan ini? Transaksi ini akan ditutup secara permanen.
          </p>
          <div class="modal-buttons">
            <button class="btn-confirm-yes" onclick="confirmCancelPayment()">Ya, Batalkan</button>
            <button class="btn-confirm-no" onclick="closeCancelModal()">Kembali</button>
          </div>
        </div>
      </div>

      <!-- Success state (hidden, shown on payment success) -->
      <div id="successState" style="display:none;" class="success-state">
        <div class="success-icon-wrap">
          <div class="success-icon"><i class="fas fa-check-circle"></i></div>
          <div class="success-burst"></div>
        </div>
        <div class="success-title">Pembayaran Berhasil! 🎉</div>
        <div class="success-sub">Transaksi kamu sudah terkonfirmasi otomatis oleh sistem.</div>

        <div class="success-recap">
          <div class="success-recap-row">
            <span><i class="fas fa-box"></i> Paket</span>
            <span><%= plan.name %></span>
          </div>
          <div class="success-recap-row">
            <span><i class="fas fa-receipt"></i> Order ID</span>
            <span style="font-family:var(--font-display); color:var(--accent-blue)">#<%= order.orderId %></span>
          </div>
          <div class="success-recap-row">
            <span><i class="fas fa-money-bill"></i> Total Bayar</span>
            <span style="color:var(--accent-green); font-weight:700;">Rp <%= order.fr3TotalTransfer.toLocaleString('id-ID') %></span>
          </div>
        </div>

        <div class="wa-step-box">
          <div class="wa-step-title">
            <i class="fas fa-exclamation-circle" style="color:#fbbf24;"></i>
            Langkah Terakhir!
          </div>
          <div class="wa-step-desc">
            Klik tombol di bawah untuk konfirmasi ke Admin via WhatsApp agar akun cloud gaming kamu segera dikirimkan.
            <strong style="color:white;">Jangan lewatkan langkah ini!</strong>
          </div>
          <a id="waConfirmBtn" href="#" target="_blank" class="wa-confirm-final">
            <i class="fab fa-whatsapp"></i>
            Konfirmasi & Minta Akun ke Admin
          </a>
          <div class="wa-step-note">
            <i class="fas fa-clock"></i>
            Akun akan dikirim dalam <strong>1–15 menit</strong> setelah konfirmasi WA
          </div>
        </div>

        <a href="/dashboard" class="success-dashboard-link">
          <i class="fas fa-tachometer-alt"></i> Lihat Dashboard
        </a>
      </div>
    </div>

    <% } else { %>
    <!-- ======= FALLBACK: Pembayaran Manual (semua gateway gagal) ======= -->
    <div class="pay-card qris-card">
      <div class="pay-status-bar" style="background: rgba(255, 255, 255,0.05); border-bottom: 1px solid rgba(255, 255, 255,0.1);">
        <div class="pay-status-dot pending" style="background: #ffffff; box-shadow: 0 0 8px #ffffff;"></div>
        <span>Pembayaran Manual (WhatsApp)</span>
      </div>

      <% if (fr3Error && typeof user !== 'undefined' && user && user.role === 'admin') { %>
      <div class="fr3-error-banner" style="display:flex; flex-direction:column; gap:0.5rem; align-items:flex-start; margin: 1.25rem; padding: 1rem; border-radius: 12px; background: rgba(255, 68, 68, 0.07); border: 1px solid rgba(255, 68, 68, 0.15); color: #ff8888; text-align: left;">
        <div style="display:flex; align-items:center; gap:0.5rem; font-weight:700;">
          <i class="fas fa-exclamation-triangle"></i>
          <span>Debug Admin: Gateway Error</span>
        </div>
        <span style="font-size:0.8rem; font-family:monospace; word-break:break-all;"><%= fr3Error %></span>
      </div>
      <% } %>

      <!-- Reset: kembali ke selector untuk coba metode/gateway lagi -->
      <form action="/payment/<%= order.orderId %>/reset" method="POST" style="margin: 0 1.25rem 0.25rem;">
        <button type="submit" class="btn-primary" style="width:100%; justify-content:center;">
          <i class="fas fa-rotate-right"></i> Coba pilih metode lagi
        </button>
      </form>

      <div style="padding: 1.25rem 1.25rem 0;">
        <div style="font-family:var(--font-ui); font-size:0.85rem; color:var(--text-muted); background:rgba(255,255,255,0.02); border:1px solid var(--border); border-radius:16px; padding:1.25rem; text-align:left;">
          <div style="color:white; font-family:var(--font-display); font-weight:800; font-size:1rem; margin-bottom:0.75rem; display:flex; align-items:center; gap:0.5rem;">
            <i class="fas fa-qrcode" style="color:#ffffff;"></i> Transfer Manual QRIS
          </div>
          <div style="margin-bottom:0.4rem;">Scan QRIS di bawah ini dengan e-wallet Anda.</div>
          <div style="margin-bottom:0.4rem;">Atas Nama: <strong style="color:white;">AlexCloud Admin</strong></div>
          <div style="font-size:0.78rem; color:#ffffff; margin-top:0.6rem; display:flex; align-items:center; gap:0.4rem;">
            <i class="fas fa-info-circle"></i> Silakan transfer tepat sejumlah total tagihan.
          </div>
        </div>
      </div>

      <div class="qr-section" style="padding-top:0.75rem;">
        <div style="font-family:var(--font-ui); font-size:0.78rem; color:var(--text-muted); margin-bottom:0.75rem;">
          — ATAU SCAN QRIS DI BAWAH INI —
        </div>
        <div class="qr-brand-row" style="margin-bottom:0.75rem;">
          <img src="/images/qris-logo.svg" alt="QRIS" style="height:24px;">
        </div>
        <div class="qr-box" style="padding:0.5rem; margin-bottom:0.75rem;">
          <% if (qrisImage) { %>
          <img src="<%= qrisImage %>" alt="QRIS" width="200" height="200" style="border-radius:8px; display:block; object-fit: contain; margin:0 auto;">
          <% } else { %>
          <div style="width:200px;height:200px;display:flex;align-items:center;justify-content:center;background:#f0f0f0;border-radius:8px;margin:0 auto;">
            <div style="color:#999;font-size:0.8rem;text-align:center;"><i class="fas fa-exclamation-circle"></i><br>QR tidak tersedia</div>
          </div>
          <% } %>
        </div>
        <div style="font-family:var(--font-ui); font-size:0.8rem; color:var(--text-muted); margin-bottom:0.25rem;">
          Jumlah yang harus dibayar:
        </div>
        <div class="pay-total-amount" style="font-size:1.8rem;"><%= priceDisplay %></div>
      </div>

      <div class="pay-summary">
        <div class="pay-sum-row">
          <span>Paket</span>
          <span><strong><%= plan.name %></strong></span>
        </div>
        <div class="pay-sum-row total-row">
          <span>Total</span>
          <span class="total-val"><%= priceDisplay %></span>
        </div>
      </div>

      <%
        let waMsg = 'Halo Admin AlexCloud! 👋\n\n';
        waMsg += 'Saya mau konfirmasi pembayaran manual:\n';
        waMsg += '📋 Order ID: *' + order.orderId + '*\n👤 Nama: ' + user.name + '\n📧 Email: ' + user.email + '\n📦 Paket: *' + plan.name + '*\n💰 Total: ' + priceDisplay + '\n\nMohon dibantu prosesnya. Terima kasih!';
      %>
      <a href="https://wa.me/62<%= waNumber.replace(/^0/, '') %>?text=<%= encodeURIComponent(waMsg) %>" target="_blank" class="wa-confirm-btn" style="margin:1.25rem auto; max-width:320px; display:flex;">
        <i class="fab fa-whatsapp"></i> Konfirmasi via WhatsApp
      </a>
    </div>
    <% } %>

    <!-- Info box -->
    <div class="pay-info-box">
      <i class="fas fa-shield-alt" style="color:var(--accent-blue); margin-top:2px;"></i>
      <div>
        <% if (payState === 'instrument') { %>
        Pembayaran diproses otomatis. Akun aktif dalam <strong>hitungan detik</strong> setelah pembayaran sukses & terkonfirmasi.
        <% } else if (payState === 'select') { %>
        Pilih metode pembayaran yang paling kamu sukai. Semua pembayaran diproses otomatis & aman.
        <% } else { %>
        Setelah transfer, kirim bukti ke admin WhatsApp untuk konfirmasi. Akun aktif dalam 1–15 menit.
        <% } %>
      </div>
    </div>

  </div>
</div>

<style>
.payment-page {
  min-height: 100vh;
  padding: 5rem 1rem 3rem;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  background: radial-gradient(ellipse at top, rgba(255, 255, 255,0.04), transparent 60%);
}
.payment-container { width: 100%; max-width: 480px; }

.pay-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
}
.pay-back {
  width: 38px; height: 38px;
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--border);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  color: var(--text-secondary);
  text-decoration: none;
  font-size: 0.9rem;
  transition: 0.2s;
}
