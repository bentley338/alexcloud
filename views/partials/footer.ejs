  <!-- ============================================ -->
  <!-- 🤖 AI CHATBOT ASSISTANT (Lazy-loaded on demand) -->
  <!-- ============================================ -->
  <div class="ai-chatbot-widget" id="aiChatbot">
    <div class="ai-chat-toggle" id="aiChatToggle" role="button" aria-label="Buka AI Chat AlexBot" aria-expanded="false" aria-controls="aiChatWindow" tabindex="0">
      <div class="ai-pulse-ring"></div>
      <i class="fas fa-robot" aria-hidden="true"></i>
      <span class="ai-badge-dot"></span>
    </div>
    <!-- Chat window injected dynamically when user opens chat -->
  </div>

  <script>
  // Lazy-load chatbot: inject DOM + script only on first interaction or idle
  (function() {
    var aiLoaded = false;
    var aiScriptLoaded = false;

    function loadAIScript(callback) {
      if (aiScriptLoaded) { if (callback) callback(); return; }
      aiScriptLoaded = true;
      var s = document.createElement('script');
      s.src = '/js/ai-engine.js?v=1.3';
      s.defer = true;
      s.fetchPriority = 'low';
      s.onload = function() { if (callback) callback(); };
      document.body.appendChild(s);
    }

    function injectChatWindow() {
      if (aiLoaded) return;
      aiLoaded = true;
      var widget = document.getElementById('aiChatbot');
      var chatHTML = '<div class="ai-chat-window" id="aiChatWindow" role="dialog" aria-modal="true" aria-label="AlexBot AI Chat">' +
        '<div class="ai-chat-header">' +
        '<div class="ai-header-info"><div class="ai-avatar" aria-hidden="true"><i class="fas fa-robot"></i></div>' +
        '<div><div class="ai-name">AlexBot AI</div><div class="ai-status"><span class="ai-online-dot" aria-hidden="true"></span>Online &amp; Siap Bantu</div></div></div>' +
        '<div class="ai-header-actions">' +
        '<button onclick="clearChat()" title="Hapus chat" aria-label="Hapus riwayat chat"><i class="fas fa-trash" aria-hidden="true"></i></button>' +
        '<button onclick="toggleAIChat()" title="Tutup" aria-label="Tutup AI Chat"><i class="fas fa-times" aria-hidden="true"></i></button>' +
        '</div></div>' +
        '<div class="ai-chat-messages" id="aiMessages">' +
        '<div class="ai-message bot"><div class="ai-msg-avatar"><i class="fas fa-robot"></i></div>' +
        '<div class="ai-msg-bubble">Halo! Saya <strong>AlexBot</strong> \uD83E\uDD16 \u2014 asisten AI AlexCloud.<br><br>' +
        'Saya bisa bantu kamu:' +
        '<div class="ai-quick-chips">' +
        '<button onclick="askAI(\'rekomendasi game terbaik\')">\uD83C\uDFAE Rekomendasi Game</button>' +
        '<button onclick="askAI(\'harga paket berlangganan\')">\uD83D\uDCB0 Info Harga</button>' +
        '<button onclick="askAI(\'cara bayar dan aktifkan akun\')">\uD83D\uDCB3 Cara Bayar</button>' +
        '<button onclick="askAI(\'fitur alexcloud\')">\u26A1 Fitur AlexCloud</button>' +
        '</div></div></div></div>' +
        '<div class="ai-chat-input-wrap">' +
        '<input type="text" id="aiChatInput" class="ai-chat-input" placeholder="Tanya apa saja..." onkeypress="handleChatEnter(event)" aria-label="Ketik pesan ke AlexBot">' +
        '<button class="ai-send-btn" onclick="sendAIMessage()" aria-label="Kirim pesan"><i class="fas fa-paper-plane" aria-hidden="true"></i></button>' +
        '</div></div>';
      widget.insertAdjacentHTML('beforeend', chatHTML);
      loadAIScript(function() {
        // After script loads, ai-engine init() sets up its own click handler on the toggle.
        // Remove our bootstrap handler to avoid double-toggling.
        if (toggle) toggle.removeEventListener('click', onToggleClick);
        // Re-trigger toggle if user already clicked
        if (window._aiPendingOpen && typeof toggleAIChat === 'function') {
          toggleAIChat();
          window._aiPendingOpen = false;
        }
      });
    }

    // Load on first click — inject chat window then open it
    var toggle = document.getElementById('aiChatToggle');
    function onToggleClick() {
      if (!aiLoaded) {
        window._aiPendingOpen = true;
        injectChatWindow();
        // Remove this handler after ai-engine.js loads (it sets its own handler)
        toggle.removeEventListener('click', onToggleClick);
      } else if (typeof toggleAIChat === 'function') {
        toggleAIChat();
      }
    }
    if (toggle) {
      toggle.addEventListener('click', onToggleClick);
    }

    // Also load after 8 seconds idle (so chatbot is ready if user scrolls down)
    if ('requestIdleCallback' in window) {
      requestIdleCallback(function() { setTimeout(injectChatWindow, 8000); }, { timeout: 15000 });
    } else {
      setTimeout(injectChatWindow, 8000);
    }
  })();
  </script>

  <script src="/js/main.js?v=1.3" defer></script>
</body>
