  <div class="ai-chatbot-widget" id="aiChatbot">
    <div class="ai-chat-toggle" id="aiChatToggle" onclick="toggleAIChat()" role="button" aria-label="Buka AI Chat AlexBot" aria-expanded="false" aria-controls="aiChatWindow" tabindex="0">
      <div class="ai-pulse-ring"></div>
      <i class="fas fa-robot" aria-hidden="true"></i>
      <span class="ai-badge-dot"></span>
    </div>
    <div class="ai-chat-window" id="aiChatWindow" role="dialog" aria-modal="true" aria-label="AlexBot AI Chat">
      <div class="ai-chat-header">
        <div class="ai-header-info">
          <div class="ai-avatar" aria-hidden="true"><i class="fas fa-robot"></i></div>
          <div>
            <div class="ai-name">AlexBot AI</div>
            <div class="ai-status"><span class="ai-online-dot" aria-hidden="true"></span>Online &amp; Siap Bantu</div>
          </div>
        </div>
        <div class="ai-header-actions">
          <button onclick="clearChat()" title="Hapus chat" aria-label="Hapus riwayat chat"><i class="fas fa-trash" aria-hidden="true"></i></button>
          <button onclick="toggleAIChat()" title="Tutup" aria-label="Tutup AI Chat"><i class="fas fa-times" aria-hidden="true"></i></button>
        </div>
      </div>
      <div class="ai-chat-messages" id="aiMessages">
        <div class="ai-message bot">
          <div class="ai-msg-avatar"><i class="fas fa-robot"></i></div>
          <div class="ai-msg-bubble">
            Halo! Saya <strong>AlexBot</strong> — asisten AI AlexCloud.<br><br>
            Saya bisa bantu kamu:
            <div class="ai-quick-chips">
              <button onclick="askAI('rekomendasi game terbaik')">Rekomendasi Game</button>
              <button onclick="askAI('harga paket berlangganan')">Info Harga</button>
              <button onclick="askAI('cara bayar dan aktifkan akun')">Cara Bayar</button>
              <button onclick="askAI('fitur alexcloud')">Fitur AlexCloud</button>
            </div>
          </div>
        </div>
      </div>
      <div class="ai-chat-input-wrap">
        <input type="text" id="aiChatInput" class="ai-chat-input" placeholder="Tanya apa saja..." onkeypress="handleChatEnter(event)" aria-label="Ketik pesan ke AlexBot">
        <button class="ai-send-btn" onclick="sendAIMessage()" aria-label="Kirim pesan"><i class="fas fa-paper-plane" aria-hidden="true"></i></button>
      </div>
    </div>
  </div>

  <!-- Chatbot engine: lazy-loaded on idle (or first toggle click) to keep it off the critical path / out of mobile TBT -->
  <script>
    (function () {
      var loaded = false;
      function loadAIEngine() {
        if (loaded) return;
        loaded = true;
        var s = document.createElement('script');
        s.src = '/js/ai-engine.js?v=2.5';
        document.body.appendChild(s);
      }
      // Stub: if the chat is opened before the engine loads, flag it and load now.
      window.toggleAIChat = function () { window.__aiOpenPending = true; loadAIEngine(); };
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadAIEngine, { timeout: 3000 });
      } else {
        setTimeout(loadAIEngine, 1800);
      }
    })();
  </script>
  <script src="/js/main.js?v=2.7" defer></script>
