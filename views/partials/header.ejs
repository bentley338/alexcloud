<body>
  <!-- Scroll Progress Indicator -->
  <div class="scroll-progress" id="scrollProgress"></div>

  <!-- Skip to main content (accessibility) -->
  <a href="#main-content" class="skip-link">Langsung ke konten utama</a>
  <nav class="navbar" id="navbar">
    <div class="nav-container">
      <a href="/?ref_=nav_logo" class="nav-logo">
        <img src="/images/logo-icon.png" class="logo-icon-img" alt="AlexCloud Logo" width="28" height="28" style="object-fit: contain; flex-shrink:0;">
        <span class="logo-text">ALEX<span class="logo-accent">CLOUD</span></span>
      </a>

      <!-- AI Smart Search -->
      <div class="nav-search-wrap" id="navSearchWrap">
        <div class="nav-search-box">
          <i class="fas fa-search nav-search-icon"></i>
          <input type="text" id="navSearchInput" class="nav-search-input" placeholder="Cari game...">
          <div class="search-results-dropdown" id="searchDropdown"></div>
        </div>
      </div>

      <div class="nav-links" id="navLinks">
        <% if (typeof user !== 'undefined' && user) { %>
          <!-- Mobile Profile Card (HP Only) -->
          <div class="mobile-user-card desktop-hidden">
            <div class="mobile-user-info">
              <% if (user.avatar) { %>
                <img src="<%= user.avatar %>" style="width:38px; height:38px; border-radius:50%; object-fit:cover; border:2px solid #fbbf24;" alt="<%= user.name %>">
              <% } else { %>
                <div class="mobile-avatar-placeholder"><%= user.name.charAt(0).toUpperCase() %></div>
              <% } %>
              <div>
                <div class="mobile-user-name">
                  <%= user.name.split(' ')[0] %>
                  <% if (user.isRoyal) { %>
                    <i class="fas fa-crown" style="color:#fbbf24; font-size:0.85rem;" title="VIP Member"></i>
                  <% } %>
                </div>
                <div class="mobile-user-balance">💰 Rp <%= (typeof balance !== 'undefined' ? balance : 0).toLocaleString('id-ID') %></div>
              </div>
            </div>
