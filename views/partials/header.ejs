  <!-- Main CSS: render-blocking on purpose — first paint uses final layout, so the
       desktop hero (hero-visual card, styled only in main.css) doesn't reflow when
       an async stylesheet applies. Same-origin ~14KB gzip; FCP cost is tiny, CLS→~0. -->
  <link href="/css/main.css?v=26.0" rel="stylesheet">

  <!-- FontAwesome: self-hosted subset (~11KB woff2 vs ~290KB full kit), load non-blocking -->
