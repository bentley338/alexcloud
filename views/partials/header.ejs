  <!-- ═══ CRITICAL CSS: Inlined for instant first paint ═══ -->
  <style>
    :root{--bg-primary:#0a0b0d;--bg-secondary:#0f1013;--bg-card:#131418;--bg-card-hover:#1a1c22;--bg-elevated:#20222a;--bg-surface:#16171c;--accent:#38bdf8;--accent-hover:#5fcdff;--accent-cyan:#22d3ee;--accent-soft:rgba(255, 255, 255,0.12);--accent-line:rgba(255, 255, 255,0.30);--accent-blue:#ffffff;--accent-purple:#ffffff;--accent-orange:#ffffff;--accent-secondary:#ffffff;--accent-indigo:#ffffff;--accent-violet:#ffffff;--accent-green:#34d399;--text-primary:#ededf0;--text-secondary:#a3a8bd;--text-muted:#6b7088;--border:rgba(255,255,255,0.07);--border-hover:rgba(255,255,255,0.16);--border-glass:rgba(255,255,255,0.07);--glow-blue:0 8px 28px rgba(0,0,0,0.45);--shadow-card:0 1px 2px rgba(0,0,0,0.3),0 6px 18px rgba(0,0,0,0.28);--shadow-card-hover:0 14px 40px rgba(0,0,0,0.55);--gradient-main:linear-gradient(120deg,#38bdf8 0%,#22d3ee 100%);--gradient-warm:linear-gradient(135deg,#ffffff 0%,#a3a3a3 100%);--gradient-dark:linear-gradient(180deg,#0a0b0d 0%,#0f1013 100%);--gradient-glass:linear-gradient(135deg,rgba(255,255,255,0.04) 0%,rgba(255,255,255,0.02) 100%);--gradient-accent:linear-gradient(120deg,#38bdf8 0%,#22d3ee 100%);--font-display:'Poppins','Plus Jakarta Sans','Inter','Segoe UI',sans-serif;--font-body:'Inter','Segoe UI',sans-serif;--font-ui:'Inter','Segoe UI',sans-serif;--radius:10px;--radius-lg:14px;--radius-xl:20px;--transition:0.2s cubic-bezier(0.4,0,0.2,1);--transition-fast:0.12s cubic-bezier(0.4,0,0.2,1)}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:var(--font-body);background:var(--bg-primary);color:var(--text-primary);min-height:100vh;overflow-x:hidden;line-height:1.6}
    .scroll-progress{display:none;position:fixed;top:0;left:0;width:0%;height:3px;background:var(--gradient-main);z-index:10001}
    .skip-link{position:absolute;top:-100%;left:50%;transform:translateX(-50%);background:var(--gradient-main);color:#fff;padding:0.75rem 1.5rem;border-radius:0 0 var(--radius) var(--radius);z-index:10000;font-weight:700;text-decoration:none;transition:top 0.3s ease}
    .skip-link:focus{top:0}
    .navbar{position:fixed;top:0;left:0;right:0;z-index:1000;padding:0.85rem 0;background:rgba(11,12,15,0.70);backdrop-filter:blur(20px) saturate(120%);-webkit-backdrop-filter:blur(20px) saturate(120%);border-bottom:1px solid var(--border);transition:var(--transition)}
    .navbar.scrolled{background:rgba(11,12,15,0.88);border-bottom-color:var(--border);box-shadow:0 1px 0 rgba(0,0,0,0.4),0 8px 30px rgba(0,0,0,0.5)}
    .nav-container{max-width:1280px;margin:0 auto;padding:0 2rem;display:flex;align-items:center;gap:2rem}
    .nav-logo{text-decoration:none;display:flex;align-items:center;gap:0.6rem;flex-shrink:0}
    .logo-text{font-family:var(--font-display);font-size:1.3rem;font-weight:700;color:var(--text-primary);letter-spacing:2px}
    .logo-accent{color:var(--accent-blue)}
    .nav-links{display:flex;align-items:center;gap:0.5rem;margin-left:auto;flex-wrap:wrap}
    .nav-link{color:var(--text-secondary);text-decoration:none;font-family:var(--font-ui);font-size:1rem;font-weight:500;padding:0.5rem 0.9rem;border-radius:8px;transition:var(--transition)}
    .btn-nav-cta{background:var(--gradient-main);color:#fff !important;text-decoration:none;font-family:var(--font-ui);font-size:0.95rem;font-weight:700;padding:0.5rem 1.4rem;border-radius:8px;transition:var(--transition)}
    .nav-toggle{display:none;flex-direction:column;justify-content:center;align-items:center;gap:5px;width:42px;height:42px;background:rgba(255,255,255,0.05);border:1px solid var(--border-glass);border-radius:12px;cursor:pointer;padding:0;margin-left:auto;transition:var(--transition)}
    .nav-toggle span{display:block;width:20px;height:2px;background:var(--text-primary);border-radius:2px}
    .hero{min-height:100vh;display:flex;align-items:center;position:relative;padding-top:80px;overflow:hidden}
    .page-hero{padding:6rem 0 2rem}body.has-announcement .page-hero{padding-top:8.5rem}
    .hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 70% at 72% 40%,rgba(255, 255, 255,0.06) 0%,transparent 62%)}
    .hero-grid-overlay{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.015) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.015) 1px,transparent 1px);background-size:80px 80px}
    .hero-container{max-width:1280px;margin:0 auto;padding:4rem 2rem;position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
    .hero-badge{display:inline-flex;align-items:center;gap:0.5rem;background:var(--accent-soft);border:1px solid var(--accent-line);color:var(--accent);padding:0.4rem 1rem;border-radius:50px;font-family:var(--font-ui);font-size:0.85rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;margin-bottom:1.5rem}
    .hero-title{font-family:var(--font-display);font-size:clamp(2.5rem,5vw,4.5rem);font-weight:800;line-height:1.08;letter-spacing:-1.5px;margin-bottom:1.5rem;color:var(--text-primary)}
    .hero-title .accent{background:var(--gradient-main);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .hero-subtitle{font-size:1.15rem;color:var(--text-secondary);max-width:500px;margin-bottom:2.5rem;line-height:1.7}
    .hero-actions{display:flex;gap:1rem;flex-wrap:wrap}
    .btn-primary{display:inline-flex;align-items:center;gap:0.5rem;background:var(--accent);color:#fff;text-decoration:none;font-family:var(--font-ui);font-size:1rem;font-weight:700;padding:0.9rem 2.2rem;border-radius:var(--radius);transition:var(--transition);border:none;cursor:pointer;position:relative}
    .btn-secondary{display:inline-flex;align-items:center;gap:0.5rem;background:transparent;color:var(--text-primary);text-decoration:none;font-family:var(--font-ui);font-size:1rem;font-weight:600;padding:0.9rem 2.2rem;border-radius:var(--radius);border:1px solid var(--border);transition:var(--transition);cursor:pointer}
    .hero-stats{display:flex;gap:2rem;margin-top:2.5rem;padding-top:2rem;border-top:1px solid var(--border)}
    .stat-item{text-align:center}
    .stat-num{display:block;font-family:var(--font-display);font-size:1.8rem;font-weight:700;color:var(--accent-blue)}
    .stat-label{font-family:var(--font-ui);font-size:0.8rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:1px}
    .hero-visual{position:relative;display:flex;align-items:center;justify-content:center}
    .nav-search-wrap{flex:1;max-width:320px}
    .nav-search-box{position:relative;display:flex;align-items:center}
    .nav-search-input{width:100%;padding:0.5rem 1rem 0.5rem 2.2rem;border-radius:8px;border:1px solid var(--border);background:rgba(255,255,255,0.04);color:var(--text-primary);font-family:var(--font-ui);font-size:0.9rem;outline:none;transition:var(--transition)}
    .nav-search-icon{position:absolute;left:0.75rem;color:var(--text-muted);font-size:0.85rem;pointer-events:none}
    .nav-user-btn{display:flex;align-items:center;gap:0.5rem;background:rgba(255,255,255,0.05);border:1px solid var(--border);color:var(--text-primary);padding:0.4rem 0.9rem 0.4rem 0.6rem;border-radius:8px;cursor:pointer;font-family:var(--font-ui);font-size:0.95rem;font-weight:500}
    .nav-user-menu{position:relative}
    .nav-avatar{width:28px;height:28px;border-radius:50%;object-fit:cover}
    .nav-avatar-placeholder{width:28px;height:28px;border-radius:50%;background:var(--gradient-main);display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;color:#fff}
    .testi-avatar-placeholder{width:44px;height:44px;border-radius:50%;background:var(--gradient-main);color:#fff;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:700;border:2px solid var(--accent-blue);flex-shrink:0}
    @media(max-width:1024px){.hero-container{grid-template-columns:1fr;text-align:center}.hero-visual{display:none}.hero-subtitle{margin:0 auto 2.5rem;max-width:540px}.hero-actions{justify-content:center}.hero-stats{justify-content:center;gap:1rem;flex-wrap:wrap}.hero-badge{margin-left:auto;margin-right:auto}}
    @media(max-width:768px){.nav-links{display:none}.nav-toggle{display:flex}.nav-search-wrap{display:none}.hero{min-height:auto;padding-top:100px;padding-bottom:2rem}.hero-container{padding:2rem 1.25rem}.hero-title{font-size:clamp(2rem,8vw,3rem)}.hero-subtitle{font-size:1rem}.hero-stats{gap:0.75rem;flex-wrap:wrap;justify-content:center}.hero-actions{flex-direction:column;align-items:center}.hero-actions .btn-primary,.hero-actions .btn-secondary{width:100%;justify-content:center}}
  </style>

  <!-- ═══ Self-hosted fonts (inlined @font-face = discovered instantly, no extra request/origin) ═══ -->
  <style>
    @font-face{font-family:'Inter';font-style:normal;font-weight:100 900;font-display:swap;src:url(/fonts/inter-latin.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
    @font-face{font-family:'Inter';font-style:normal;font-weight:100 900;font-display:swap;src:url(/fonts/inter-latin-ext.woff2) format('woff2');unicode-range:U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF}
    @font-face{font-family:'Plus Jakarta Sans';font-style:normal;font-weight:200 800;font-display:swap;src:url(/fonts/jakarta-latin.woff2) format('woff2');unicode-range:U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD}
    @font-face{font-family:'Plus Jakarta Sans';font-style:normal;font-weight:200 800;font-display:swap;src:url(/fonts/jakarta-latin-ext.woff2) format('woff2');unicode-range:U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF}
  </style>

  <!-- Main CSS: render-blocking on purpose — first paint uses final layout, so the
       desktop hero (hero-visual card, styled only in main.css) doesn't reflow when
       an async stylesheet applies. Same-origin ~14KB gzip; FCP cost is tiny, CLS→~0. -->
  <link href="/css/main.css?v=6.2" rel="stylesheet">

  <!-- FontAwesome: self-hosted subset (~11KB woff2 vs ~290KB full kit), load non-blocking -->
  <link rel="stylesheet" href="/css/fontawesome.min.css?v=1" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="/css/fontawesome.min.css?v=1"></noscript>
</head>
<body>
  <!-- Site Announcement Banner (managed from admin panel) -->
  <% if (typeof announcement !== 'undefined' && announcement) { %>
  <div class="site-announce site-announce--<%= announcement.type || 'info' %>" id="siteAnnounce" data-ann-id="<%= announcement.id || 'default' %>">
    <div class="site-announce-inner">
      <i class="fas fa-<%= announcement.type === 'promo' ? 'gift' : (announcement.type === 'warn' ? 'triangle-exclamation' : 'bullhorn') %>" aria-hidden="true"></i>
      <span class="site-announce-text"><%= announcement.text %></span>
      <% if (announcement.link && announcement.linkText) { %>
        <a href="<%= announcement.link %>" class="site-announce-link"><%= announcement.linkText %> →</a>
      <% } %>
    </div>
    <button class="site-announce-close" type="button" onclick="dismissAnnounce()" aria-label="Tutup pengumuman">✕</button>
  </div>
  <script>
    document.body.classList.add('has-announcement');
    (function () {
      var el = document.getElementById('siteAnnounce');
      if (!el) return;
      var id = el.getAttribute('data-ann-id') || 'default';
      try { if (localStorage.getItem('annDismissed') === id) { el.remove(); document.body.classList.remove('has-announcement'); } } catch (e) {}
    })();
    function dismissAnnounce() {
      var el = document.getElementById('siteAnnounce');
      if (!el) return;
      var id = el.getAttribute('data-ann-id') || 'default';
      try { localStorage.setItem('annDismissed', id); } catch (e) {}
      el.remove();
      document.body.classList.remove('has-announcement');
    }
  </script>
  <% } %>

  <!-- Scroll Progress Indicator -->
  <div class="scroll-progress" id="scrollProgress"></div>

  <!-- Skip to main content (accessibility) -->
  <a href="#main-content" class="skip-link">Langsung ke konten utama</a>
  <nav class="navbar" id="navbar">
    <div class="nav-container">
      <a href="/" class="nav-logo">
        <svg class="logo-icon-svg" width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0;">
          <defs>
            <linearGradient id="logoIconGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#38bdf8" />
              <stop offset="100%" stop-color="#22d3ee" />
            </linearGradient>
          </defs>
          <!-- Stylized Cloud outline -->
          <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z" fill="url(#logoIconGrad)" opacity="0.12" />
          <path d="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96z" stroke="url(#logoIconGrad)" stroke-width="1.5" stroke-linejoin="round" opacity="0.35" fill="none" />
          <!-- Sharp Central Lightning Bolt representing cloud speed -->
          <path d="M14 2L7 13H12L10 22L17 11H12L14 2Z" fill="url(#logoIconGrad)" />
        </svg>
        <span class="logo-text">ALEX<span class="logo-accent">CLOUD</span></span>
      </a>

      <!-- AI Smart Search -->
      <div class="nav-search-wrap" id="navSearchWrap">
        <div class="nav-search-box">
          <i class="fas fa-search nav-search-icon"></i>
          <input type="text" id="navSearchInput" class="nav-search-input" placeholder="Cari game...">
          <div class="search-results-dropdown" id="searchDropdown"></div>
        </div>
      </div>

      <div class="nav-links" id="navLinks">
        <a href="/" class="nav-link">Beranda</a>
        <a href="/games" class="nav-link">Game Library</a>
        <a href="/pricing" class="nav-link">Harga</a>
        <a href="/testimonials" class="nav-link">Testimoni</a>
        <a href="/community" class="nav-link" style="display:flex;align-items:center;gap:0.3rem;"><i class="fas fa-comments" style="font-size:0.8rem;"></i> Komunitas</a>
        <a href="/faq" class="nav-link">FAQ</a>
        <a href="/network-test" class="nav-link" style="display:flex;align-items:center;gap:0.3rem;"><i class="fas fa-wifi" style="font-size:0.8rem;"></i> Speed Test</a>
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/dashboard" class="nav-link">Dashboard</a>
          <% if (user.role === 'admin') { %>
            <a href="/admin" class="nav-link nav-admin"><i class="fas fa-cog" style="font-size:0.8rem;"></i> Admin</a>
          <% } %>
          <div class="nav-user-menu">
