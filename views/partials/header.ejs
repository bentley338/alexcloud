<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'AlexCloud | Platform Cloud Gaming Premium #1 Indonesia' %></title>
  <meta name="description" content="AlexCloud menghadirkan pengalaman cloud gaming premium #1 di Indonesia. Main game AAA terbaru seperti EA FC 26, GTA VI, MotoGP 25 langsung di HP, laptop, atau TV tanpa PC mahal. Mulai Rp 40.000/minggu dengan latency rendah!">
  <meta name="keywords" content="cloud gaming indonesia, cloud gaming murah, main game AAA di hp, game cloud server indonesia, sewa cloud gaming pc, alexcloud, alexcloud gaming">
  
  <!-- Open Graph / Facebook (Tampilan premium saat di-share di WhatsApp/Sosmed) -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://alexcloud.my.id/">
  <meta property="og:title" content="AlexCloud | Platform Cloud Gaming Premium #1 Indonesia">
  <meta property="og:description" content="Main game AAA terbaru langsung di HP, laptop, atau TV tanpa PC mahal. Mulai Rp 40.000/minggu dengan server lokal ping rendah!">
  <meta property="og:image" content="https://placehold.co/1200x630/030712/00d4ff?text=AlexCloud+Gaming&font=orbitron">
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="https://alexcloud.my.id/">
  <meta property="twitter:title" content="AlexCloud | Platform Cloud Gaming Premium #1 Indonesia">
  <meta property="twitter:description" content="Main game AAA terbaru langsung di HP, laptop, atau TV tanpa PC mahal. Mulai Rp 40.000/minggu dengan server lokal ping rendah!">
  <meta property="twitter:image" content="https://placehold.co/1200x630/030712/00d4ff?text=AlexCloud+Gaming&font=orbitron">

  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>☁️</text></svg>">

  <!-- Preconnect untuk performa (maksimal 2 agar tidak boros koneksi) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- CSS kritis inlined untuk mempercepat First Contentful Paint & cegah FOUC -->
  <style>
    body { background-color: #030712 !important; color: #e8f0ff; }
    .navbar { background: rgba(3, 7, 18, 0.85); backdrop-filter: blur(20px); min-height: 70px; }
  </style>

  <!-- Main stylesheet loaded asinkron (non-blocking) -->
  <link rel="stylesheet" href="/css/main.css" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="/css/main.css"></noscript>

  <!-- Google Fonts: load dengan font-display=swap asinkron -->
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=Rajdhani:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=Rajdhani:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet"></noscript>

  <!-- FontAwesome: load non-blocking menggunakan print-onload trick -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"></noscript>
</head>
<body>
  <!-- Skip to main content (accessibility) -->
  <a href="#main-content" class="skip-link">Langsung ke konten utama</a>
  <nav class="navbar" id="navbar">
    <div class="nav-container">
      <a href="/" class="nav-logo">
        <span class="logo-icon">⚡</span>
        <span class="logo-text">ALEX<span class="logo-accent">CLOUD</span></span>
      </a>

      <!-- AI Smart Search -->
      <div class="nav-search-wrap" id="navSearchWrap">
        <div class="nav-search-box">
          <i class="fas fa-search nav-search-icon"></i>
          <input type="text" id="navSearchInput" class="nav-search-input" placeholder="🤖 AI Search game...">
          <div class="search-results-dropdown" id="searchDropdown"></div>
        </div>
      </div>

      <div class="nav-links" id="navLinks">
        <a href="/" class="nav-link">Beranda</a>
        <a href="/games" class="nav-link">Game Library</a>
        <a href="/pricing" class="nav-link">Harga</a>
        <a href="/testimonials" class="nav-link">Testimoni</a>
        <a href="/faq" class="nav-link">FAQ</a>
        <a href="/network-test" class="nav-link" style="display:flex;align-items:center;gap:0.3rem;"><i class="fas fa-wifi" style="font-size:0.8rem;"></i> Speed Test</a>
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/dashboard" class="nav-link">Dashboard</a>
          <% if (user.role === 'admin') { %>
            <a href="/admin" class="nav-link nav-admin">⚙ Admin</a>
          <% } %>
          <div class="nav-user-menu">
            <button class="nav-user-btn" onclick="toggleUserMenu()">
              <% if (user.avatar) { %>
                <img src="<%= user.avatar %>" class="nav-avatar" alt="<%= user.name %>" width="28" height="28">
              <% } else { %>
                <div class="nav-avatar-placeholder"><%= user.name.charAt(0).toUpperCase() %></div>
              <% } %>
              <span><%= user.name.split(' ')[0] %></span>
              <i class="fas fa-chevron-down"></i>
            </button>
            <div class="user-dropdown" id="userDropdown">
              <a href="/profile"><i class="fas fa-user"></i> Profil</a>
              <a href="/dashboard"><i class="fas fa-chart-line"></i> Dashboard</a>
              <hr>
              <a href="/logout" class="logout-link"><i class="fas fa-sign-out-alt"></i> Logout</a>
            </div>
          </div>
        <% } else { %>
          <a href="/login" class="nav-link">Login</a>
          <a href="/register" class="btn-nav-cta">Daftar Gratis</a>
        <% } %>
      </div>
      <button class="nav-toggle" onclick="toggleNav()" aria-label="Buka menu navigasi" aria-expanded="false" aria-controls="navLinks" id="navToggleBtn">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
